<Window
        x:Class="HabitTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:HabitTracker"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="HabitTracker"
        Icon="/Assets/logo.png"
        Width="800"
        Height="750"
        MinWidth="1200"
        MinHeight="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">


        <Window.Resources>
                <Style x:Key="SidebarMenuItemStyle"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource TextMutedBrush}"/>
                        <Setter Property="FontWeight"
                                Value="SemiBold"/>
                        <Setter Property="FontSize"
                                Value="14"/>
                        <Setter Property="Padding"
                                Value="15,12"/>
                        <Setter Property="Margin"
                                Value="0,2"/>
                        <Setter Property="HorizontalContentAlignment"
                                Value="Left"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Grid Background="Transparent">
                                                        <Border x:Name="BgBorder"
                                                                Background="{DynamicResource InputBgBrush}"
                                                                CornerRadius="10"
                                                                Opacity="0"/>

                                                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="Center">
                                                                <ContentPresenter.RenderTransform>
                                                                        <TranslateTransform x:Name="ContentTransform"
                                                                                            X="0"/>
                                                                </ContentPresenter.RenderTransform>
                                                        </ContentPresenter>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource TextMainBrush}"/>

                                                                <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="BgBorder"
                                                                                                         Storyboard.TargetProperty="Opacity"
                                                                                                         To="1"
                                                                                                         Duration="0:0:0.2"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="ContentTransform"
                                                                                                         Storyboard.TargetProperty="X"
                                                                                                         To="5"
                                                                                                         Duration="0:0:0.2">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.EnterActions>

                                                                <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="BgBorder"
                                                                                                         Storyboard.TargetProperty="Opacity"
                                                                                                         To="0"
                                                                                                         Duration="0:0:0.2"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="ContentTransform"
                                                                                                         Storyboard.TargetProperty="X"
                                                                                                         To="0"
                                                                                                         Duration="0:0:0.2">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>
                <LinearGradientBrush x:Key="AppBgBrush"
                                     StartPoint="0,0"
                                     EndPoint="1,1">
                        <GradientStop Color="#FFF4F4E9"
                                      Offset="0.0"/>
                        <GradientStop Color="#FFE4E8E5"
                                      Offset="1.0"/>
                </LinearGradientBrush>
                <SolidColorBrush x:Key="CardBgBrush"
                                 Color="White"/>
                <SolidColorBrush x:Key="TextMainBrush"
                                 Color="#FF4E606C"/>
                <SolidColorBrush x:Key="TextMutedBrush"
                                 Color="#FF8B9AA2"/>
                <SolidColorBrush x:Key="AccentGreenBrush"
                                 Color="#FF328A5D"/>
                <SolidColorBrush x:Key="InputBgBrush"
                                 Color="#FFF8F9FA"/>
                <SolidColorBrush x:Key="InputBorderBrush"
                                 Color="#FFDDE2E5"/>

                <BooleanToVisibilityConverter x:Key="BoolToVis"/>

                <Style x:Key="ToggleSwitchStyle"
                       TargetType="ToggleButton">
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Border"
                                                        Width="44"
                                                        Height="24"
                                                        CornerRadius="12"
                                                        Background="#FFDDE2E5"
                                                        Cursor="Hand">
                                                        <Ellipse x:Name="Thumb"
                                                                 Width="18"
                                                                 Height="18"
                                                                 Fill="White"
                                                                 HorizontalAlignment="Left"
                                                                 Margin="3,0,0,0">
                                                                <Ellipse.RenderTransform>
                                                                        <TranslateTransform x:Name="ThumbTransform"
                                                                                            X="0"/>
                                                                </Ellipse.RenderTransform>
                                                        </Ellipse>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                                <Setter TargetName="Border"
                                                                        Property="Background"
                                                                        Value="#FF328A5D"/>
                                                                <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                                                                         Storyboard.TargetProperty="X"
                                                                                                         To="20"
                                                                                                         Duration="0:0:0.2"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                                                                         Storyboard.TargetProperty="X"
                                                                                                         To="0"
                                                                                                         Duration="0:0:0.2"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style TargetType="TextBox">
                        <Setter Property="Background"
                                Value="{DynamicResource InputBgBrush}"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource InputBorderBrush}"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource TextMainBrush}"/>
                        <Setter Property="FontSize"
                                Value="14"/>
                        <Setter Property="VerticalContentAlignment"
                                Value="Center"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                        <Border x:Name="InputBorder"
                                                                CornerRadius="10"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"/>
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      Margin="12,20,12,6"/>
                                                        <TextBlock x:Name="FloatingLabel"
                                                                   Text="{TemplateBinding Tag}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   IsHitTestVisible="False"
                                                                   Margin="12,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   RenderTransformOrigin="0,0.5">
                                                                <TextBlock.RenderTransform>
                                                                        <TransformGroup>
                                                                                <ScaleTransform x:Name="TextLabelScale"
                                                                                                ScaleX="1"
                                                                                                ScaleY="1"/>
                                                                                <TranslateTransform x:Name="TextLabelTranslate"
                                                                                                    X="0"
                                                                                                    Y="0"/>
                                                                        </TransformGroup>
                                                                </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="Text"
                                                                 Value="">
                                                                <Setter TargetName="FloatingLabel"
                                                                        Property="Foreground"
                                                                        Value="{DynamicResource TextMutedBrush}"/>
                                                                <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                                         To="1"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleY"
                                                                                                         To="1"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelTranslate"
                                                                                                         Storyboard.TargetProperty="Y"
                                                                                                         To="0"
                                                                                                         Duration="0:0:0.18"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                                         To="0.86"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleY"
                                                                                                         To="0.86"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelTranslate"
                                                                                                         Storyboard.TargetProperty="Y"
                                                                                                         To="-14"
                                                                                                         Duration="0:0:0.18"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                        </Trigger>
                                                        <Trigger Property="IsKeyboardFocusWithin"
                                                                 Value="True">
                                                                <Setter TargetName="InputBorder"
                                                                        Property="BorderBrush"
                                                                        Value="{DynamicResource AccentGreenBrush}"/>
                                                                <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                                         To="0.86"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleY"
                                                                                                         To="0.86"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TextLabelTranslate"
                                                                                                         Storyboard.TargetProperty="Y"
                                                                                                         To="-14"
                                                                                                         Duration="0:0:0.18"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                        <Condition Property="IsKeyboardFocusWithin"
                                                                                   Value="False"/>
                                                                        <Condition Property="Text"
                                                                                   Value=""/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter TargetName="InputBorder"
                                                                        Property="BorderBrush"
                                                                        Value="{DynamicResource InputBorderBrush}"/>
                                                        </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style TargetType="PasswordBox">
                        <Setter Property="Background"
                                Value="{DynamicResource InputBgBrush}"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource InputBorderBrush}"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource TextMainBrush}"/>
                        <Setter Property="FontSize"
                                Value="14"/>
                        <Setter Property="VerticalContentAlignment"
                                Value="Center"/>
                        <EventSetter Event="PasswordChanged"
                                     Handler="FloatingPasswordBox_PasswordChanged"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="PasswordBox">
                                                <Grid>
                                                        <Border x:Name="PasswordInputBorder"
                                                                CornerRadius="10"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"/>
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      Margin="12,20,12,6"/>
                                                        <TextBlock x:Name="PasswordFloatingLabel"
                                                                   Text="{TemplateBinding Tag}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   IsHitTestVisible="False"
                                                                   Margin="12,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   RenderTransformOrigin="0,0.5">
                                                                <TextBlock.RenderTransform>
                                                                        <TransformGroup>
                                                                                <ScaleTransform x:Name="PasswordLabelScale"
                                                                                                ScaleX="1"
                                                                                                ScaleY="1"/>
                                                                                <TranslateTransform x:Name="PasswordLabelTranslate"
                                                                                                    X="0"
                                                                                                    Y="0"/>
                                                                        </TransformGroup>
                                                                </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="local:MainWindow.HasText"
                                                                 Value="False">
                                                                <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                                         To="1"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleY"
                                                                                                         To="1"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelTranslate"
                                                                                                         Storyboard.TargetProperty="Y"
                                                                                                         To="0"
                                                                                                         Duration="0:0:0.18"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                                         To="0.86"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleY"
                                                                                                         To="0.86"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelTranslate"
                                                                                                         Storyboard.TargetProperty="Y"
                                                                                                         To="-14"
                                                                                                         Duration="0:0:0.18"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                        </Trigger>
                                                        <Trigger Property="IsKeyboardFocusWithin"
                                                                 Value="True">
                                                                <Setter TargetName="PasswordInputBorder"
                                                                        Property="BorderBrush"
                                                                        Value="{DynamicResource AccentGreenBrush}"/>
                                                                <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                                         To="0.86"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelScale"
                                                                                                         Storyboard.TargetProperty="ScaleY"
                                                                                                         To="0.86"
                                                                                                         Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="PasswordLabelTranslate"
                                                                                                         Storyboard.TargetProperty="Y"
                                                                                                         To="-14"
                                                                                                         Duration="0:0:0.18"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                        <Condition Property="IsKeyboardFocusWithin"
                                                                                   Value="False"/>
                                                                        <Condition Property="local:MainWindow.HasText"
                                                                                   Value="False"/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter TargetName="PasswordInputBorder"
                                                                        Property="BorderBrush"
                                                                        Value="{DynamicResource InputBorderBrush}"/>
                                                        </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style TargetType="Button">
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder"
                                                        Padding="10,8"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="BtnBorder"
                                                                        Property="Opacity"
                                                                        Value="0.85"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="BtnBorder"
                                                                        Property="Opacity"
                                                                        Value="0.7"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="LoginLoadingButtonStyle"
                       TargetType="Button">
                        <Setter Property="Width"
                                Value="310"/>
                        <Setter Property="Foreground"
                                Value="White"/>
                        <Setter Property="FontWeight"
                                Value="SemiBold"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border x:Name="LoginBtnBorder"
                                                        Padding="10,8"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="21"
                                                        Opacity="1">
                                                        <Grid>
                                                                <ContentPresenter x:Name="LoginButtonContent"
                                                                                  HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                                <StackPanel x:Name="LoginLoadingState"
                                                                            Orientation="Horizontal"
                                                                            Visibility="Collapsed"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center">
                                                                        <Grid Width="16"
                                                                              Height="16"
                                                                              Margin="0,0,8,0"
                                                                              RenderTransformOrigin="0.5,0.5">
                                                                                <Grid.RenderTransform>
                                                                                        <RotateTransform x:Name="SpinnerRotate"
                                                                                                         Angle="0"/>
                                                                                </Grid.RenderTransform>
                                                                                <Ellipse Stroke="White"
                                                                                         StrokeThickness="2"
                                                                                         StrokeDashArray="1.6,2.4"
                                                                                         Opacity="0.95"/>
                                                                        </Grid>
                                                                        <TextBlock Text="Signing in..."
                                                                                   Foreground="White"
                                                                                   FontWeight="SemiBold"
                                                                                   VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                        </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="LoginBtnBorder"
                                                                        Property="Opacity"
                                                                        Value="0.9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="LoginBtnBorder"
                                                                        Property="Opacity"
                                                                        Value="0.8"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsLoading}"
                                                                     Value="True">
                                                                <Setter Property="IsEnabled"
                                                                        Value="False"/>
                                                                <Setter TargetName="LoginButtonContent"
                                                                        Property="Visibility"
                                                                        Value="Collapsed"/>
                                                                <Setter TargetName="LoginLoadingState"
                                                                        Property="Visibility"
                                                                        Value="Visible"/>
                                                                <DataTrigger.EnterActions>
                                                                        <BeginStoryboard x:Name="ExpandButtonStoryboard">
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                                                         To="360"
                                                                                                         Duration="0:0:0.25">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                                                         Storyboard.TargetProperty="Angle"
                                                                                                         From="0"
                                                                                                         To="360"
                                                                                                         Duration="0:0:0.8"
                                                                                                         RepeatBehavior="Forever"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                        <StopStoryboard BeginStoryboardName="ExpandButtonStoryboard"/>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                                                         To="310"
                                                                                                         Duration="0:0:0.22">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="AccentLinkButtonStyle"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource TextMutedBrush}"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           FontWeight="{TemplateBinding FontWeight}">
                                                        <TextBlock.Foreground>
                                                                <SolidColorBrush x:Name="LinkForeground"
                                                                                 Color="#FF8B9AA2"/>
                                                        </TextBlock.Foreground>
                                                </TextBlock>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <ColorAnimation Storyboard.TargetName="LinkForeground"
                                                                                                        Storyboard.TargetProperty="Color"
                                                                                                        To="#FF328A5D"
                                                                                                        Duration="0:0:0.18"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                                <Storyboard>
                                                                                        <ColorAnimation Storyboard.TargetName="LinkForeground"
                                                                                                        Storyboard.TargetProperty="Color"
                                                                                                        To="#FF8B9AA2"
                                                                                                        Duration="0:0:0.2"/>
                                                                                </Storyboard>
                                                                        </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="SavedAccountCardStyle"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Margin"
                                Value="10"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border x:Name="CardHoverBg"
                                                        Background="Transparent"
                                                        CornerRadius="12"
                                                        Padding="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="CardHoverBg"
                                                                        Property="Background"
                                                                        Value="{DynamicResource InputBgBrush}"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>
        </Window.Resources>

        <Grid Background="{DynamicResource AppBgBrush}">
                <Grid Visibility="{Binding IsAuthVisible, Converter={StaticResource BoolToVis}}"
                      Margin="22,16,22,16">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4.5*"/>
                                <ColumnDefinition Width="5.5*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Margin="34,18,40,18"
                                    MaxWidth="560">
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,28">
                                        <Border Width="46"
                                                Height="46"
                                                CornerRadius="12"
                                                Background="#FF1F7D33">
                                                <Image Source="/Assets/logo.png"
                                                       Width="28"
                                                       Height="28"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <TextBlock Text="Habit Tracker"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#FF1F7D33"
                                                   Margin="14,0,0,0"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="#FF16213A"
                                           LineHeight="42"
                                           Margin="0,0,0,16"
                                           TextWrapping="Wrap">
                                        Plant habits. 
                                        <Run Text="Harvest success."
                                             Foreground="#FF1F7D33"
                                             FontStyle="Italic"/>
                                </TextBlock>

                                <TextBlock Text="Your dedicated tracker for productivity and health. Stay consistent, analyze your performance, and turn small steps into lasting lifestyle changes in just a few clicks a day."
                                           FontSize="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,20"
                                           TextWrapping="Wrap"
                                           LineHeight="24"/>

                                <Border Height="300"
                                        CornerRadius="28"
                                        BorderBrush="#22328A5D"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                        <Border.Background>
                                                <ImageBrush ImageSource="/Assets/logo.png"
                                                            Stretch="Uniform"
                                                            AlignmentX="Center"
                                                            AlignmentY="Center"
                                                            Opacity="0.78"/>
                                        </Border.Background>
                                        <Border.Effect>
                                                <DropShadowEffect BlurRadius="25"
                                                                  ShadowDepth="2"
                                                                  Opacity="0.06"
                                                                  Color="#FF1B2A2F"/>
                                        </Border.Effect>
                                </Border>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Margin="44,18,10,18"
                                CornerRadius="20"
                                Background="{DynamicResource CardBgBrush}">
                                <Border.Effect>
                                        <DropShadowEffect BlurRadius="12"
                                                          Opacity="0.04"
                                                          ShadowDepth="2"
                                                          Color="Black"/>
                                </Border.Effect>
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ScrollViewer Grid.Row="0"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Padding="40,34,40,14">
                                                <StackPanel>
                                                        <StackPanel Margin="0,0,0,18">
                                                                <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                                <Setter Property="Visibility"
                                                                                        Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsRegisterVisible}"
                                                                                                     Value="True">
                                                                                                <Setter Property="Visibility"
                                                                                                        Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                </Style.Triggers>
                                                                        </Style>
                                                                </StackPanel.Style>
                                                                <TextBlock Text="Welcome back"
                                                                           FontSize="28"
                                                                           FontWeight="Bold"
                                                                           Foreground="#FF121A2F"/>
                                                                <TextBlock Text="Select an account or sign in manually."
                                                                           FontSize="14"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Margin="0,8,0,0"/>
                                                        </StackPanel>

                                                        <StackPanel Margin="0,0,0,20">
                                                                <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                                <Setter Property="Visibility"
                                                                                        Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                        <MultiDataTrigger>
                                                                                                <MultiDataTrigger.Conditions>
                                                                                                        <Condition Binding="{Binding IsLoginVisible}"
                                                                                                                   Value="True"/>
                                                                                                        <Condition Binding="{Binding HasSavedAccounts}"
                                                                                                                   Value="True"/>
                                                                                                </MultiDataTrigger.Conditions>
                                                                                                <Setter Property="Visibility"
                                                                                                        Value="Visible"/>
                                                                                        </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                        </Style>
                                                                </StackPanel.Style>
                                                                <TextBlock Text="RECENTLY ACTIVE"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Margin="0,0,0,10"/>
                                                                <ItemsControl ItemsSource="{Binding SavedAccounts}">
                                                                        <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                        <WrapPanel Orientation="Horizontal"/>
                                                                                </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                        <Button Style="{StaticResource SavedAccountCardStyle}"
                                                                                                Click="SavedAccount_Click">
                                                                                                <StackPanel>
                                                                                                        <Border Width="66"
                                                                                                                Height="66"
                                                                                                                CornerRadius="33"
                                                                                                                Background="{DynamicResource InputBgBrush}"
                                                                                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                                                                                BorderThickness="1.5"
                                                                                                                Margin="0,0,0,6">
                                                                                                                <Grid>
                                                                                                                        <Image Source="/Assets/logo.png"
                                                                                                                               Margin="14"
                                                                                                                               Opacity="0.08"/>
                                                                                                                        <Border Width="60"
                                                                                                                                Height="60"
                                                                                                                                CornerRadius="30">
                                                                                                                                <Border.Background>
                                                                                                                                        <ImageBrush ImageSource="{Binding AvatarUrl}"
                                                                                                                                                    Stretch="UniformToFill"/>
                                                                                                                                </Border.Background>
                                                                                                                        </Border>
                                                                                                                </Grid>
                                                                                                        </Border>
                                                                                                        <TextBlock Text="{Binding Nickname}"
                                                                                                                   Foreground="{DynamicResource TextMainBrush}"
                                                                                                                   FontWeight="SemiBold"
                                                                                                                   FontSize="12"
                                                                                                                   TextAlignment="Center"/>
                                                                                                </StackPanel>
                                                                                        </Button>
                                                                                </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                        </StackPanel>

                                                        <StackPanel x:Name="LoginFormPanel"
                                                                    Margin="0,0,0,8"
                                                                    Visibility="{Binding IsLoginVisible, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="EMAIL ADDRESS"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Margin="0,0,0,8"/>
                                                                <TextBox x:Name="EmailInput"
                                                                         Height="56"
                                                                         Margin="0,0,0,14"
                                                                         Tag="E-mail"
                                                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                                                                <TextBlock Text="PASSWORD"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Margin="0,0,0,8"/>
                                                                <Grid Margin="0,0,0,14">
                                                                        <TextBox x:Name="LoginPasswordVisible"
                                                                                 Height="56"
                                                                                 Tag="Password"
                                                                                 Padding="0,0,44,0"
                                                                                 Visibility="Collapsed"/>

                                                                        <PasswordBox x:Name="LoginPassword"
                                                                                     Height="56"
                                                                                     Tag="Password"
                                                                                     Padding="0,0,44,0"/>

                                                                        <Button Width="34"
                                                                                Height="34"
                                                                                HorizontalAlignment="Right"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,8,0"
                                                                                Cursor="Hand"
                                                                                Background="Transparent"
                                                                                BorderThickness="0"
                                                                                Foreground="{DynamicResource TextMutedBrush}"
                                                                                Click="ToggleLoginPassword_Click">

                                                                                <TextBlock x:Name="LoginEyeIcon"
                                                                                           Text="👁"
                                                                                           FontSize="15"
                                                                                           VerticalAlignment="Center"
                                                                                           HorizontalAlignment="Center"/>
                                                                        </Button>
                                                                </Grid>

                                                                <Grid Margin="0,2,0,20">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    VerticalAlignment="Center">
                                                                                <TextBlock Text="Don't have an account?"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource TextMainBrush}"
                                                                                           FontSize="16"/>
                                                                                <Button Content="Register"
                                                                                        Click="NavToRegister_Click"
                                                                                        Cursor="Hand"
                                                                                        FontSize="16"
                                                                                        FontWeight="SemiBold"
                                                                                        Margin="6,0,0,0"
                                                                                        VerticalAlignment="Center"
                                                                                        Style="{StaticResource AccentLinkButtonStyle}"/>
                                                                        </StackPanel>
                                                                        <Button Grid.Column="1"
                                                                                HorizontalAlignment="Right"
                                                                                Content="Forgot password?"
                                                                                Click="NavToForgot_Click"
                                                                                FontSize="14"
                                                                                Style="{StaticResource AccentLinkButtonStyle}"/>
                                                                </Grid>

                                                                <Button Height="56"
                                                                        Margin="0,0,0,24"
                                                                        HorizontalAlignment="Stretch"
                                                                        Background="#FF1F7D33"
                                                                        Click="LoginButton_Click"
                                                                        Style="{StaticResource LoginLoadingButtonStyle}"
                                                                        Content="Sign In"
                                                                        Foreground="White"
                                                                        FontWeight="SemiBold"/>

                                                                <TextBlock x:Name="StatusMessage"
                                                                           Margin="0,0,0,14"
                                                                           HorizontalAlignment="Center"
                                                                           FontWeight="Medium"
                                                                           Foreground="{Binding StatusColor}"
                                                                           Text="{Binding StatusMessage}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel x:Name="RegisterFormPanel"
                                                                    Margin="0,0,0,8"
                                                                    Visibility="{Binding IsRegisterVisible, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Margin="0,0,0,5"
                                                                           FontSize="32"
                                                                           FontWeight="Bold"
                                                                           Foreground="#FF328A5D"
                                                                           Text="Create profile"/>
                                                                <TextBlock Margin="0,0,0,20"
                                                                           FontSize="15"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Text="Set up your account in a few quick steps."/>

                                                                <Grid HorizontalAlignment="Center"
                                                                      Margin="0,0,0,25">
                                                                        <Border x:Name="AvatarBorder"
                                                                                Width="90"
                                                                                Height="90"
                                                                                CornerRadius="45"
                                                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                                                BorderThickness="2"
                                                                                Background="{DynamicResource InputBgBrush}">
                                                                                <Grid>
                                                                                        <Image Source="/Assets/logo.png"
                                                                                               Margin="20"
                                                                                               Opacity="0.3"/>
                                                                                        <Border Width="90"
                                                                                                Height="90"
                                                                                                CornerRadius="45">
                                                                                                <Border.Background>
                                                                                                        <ImageBrush x:Name="AvatarImageBrush"
                                                                                                                    Stretch="UniformToFill"/>
                                                                                                </Border.Background>
                                                                                        </Border>
                                                                                        <Button VerticalAlignment="Bottom"
                                                                                                HorizontalAlignment="Right"
                                                                                                Width="28"
                                                                                                Height="28"
                                                                                                Background="#FF328A5D"
                                                                                                Padding="0"
                                                                                                Click="ChooseAvatar_Click"
                                                                                                Cursor="Hand">
                                                                                                <Button.Template>
                                                                                                        <ControlTemplate TargetType="Button">
                                                                                                                <Border CornerRadius="14"
                                                                                                                        Background="{TemplateBinding Background}">
                                                                                                                        <TextBlock Text="📷"
                                                                                                                                   Foreground="White"
                                                                                                                                   FontWeight="Bold"
                                                                                                                                   FontSize="16"
                                                                                                                                   HorizontalAlignment="Center"
                                                                                                                                   VerticalAlignment="Center"
                                                                                                                                   Margin="0,-2,0,0"/>
                                                                                                                </Border>
                                                                                                        </ControlTemplate>
                                                                                                </Button.Template>
                                                                                        </Button>
                                                                                </Grid>
                                                                        </Border>
                                                                </Grid>

                                                                <TextBox Height="50"
                                                                         Margin="0,0,0,15"
                                                                         Tag="Nickname"
                                                                         Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <TextBox Height="50"
                                                                         Margin="0,0,0,15"
                                                                         Tag="E-mail"
                                                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <PasswordBox x:Name="RegisterPassword"
                                                                             Height="50"
                                                                             Margin="0,0,0,15"
                                                                             Tag="Password"/>
                                                                <PasswordBox x:Name="RegisterRepeatPassword"
                                                                             Height="50"
                                                                             Margin="0,0,0,25"
                                                                             Tag="Repeat Password"/>

                                                                <Button Height="48"
                                                                        Margin="0,0,0,15"
                                                                        Background="#FF328A5D"
                                                                        Click="RegisterButton_Click"
                                                                        Content="Sign up"
                                                                        Foreground="White"
                                                                        FontWeight="SemiBold"/>
                                                                <TextBlock Margin="0,0,0,14"
                                                                           HorizontalAlignment="Center"
                                                                           FontWeight="Medium"
                                                                           Foreground="{Binding StatusColor}"
                                                                           Text="{Binding StatusMessage}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"/>
                                                                <Button HorizontalAlignment="Center"
                                                                        Background="Transparent"
                                                                        Click="NavToLogin_Click"
                                                                        Content="Back to Login"
                                                                        Cursor="Hand"
                                                                        FontSize="13"
                                                                        Style="{StaticResource AccentLinkButtonStyle}"/>
                                                        </StackPanel>

                                                        <StackPanel x:Name="ForgotFormPanel"
                                                                    Margin="0,0,0,8"
                                                                    Visibility="{Binding IsForgotVisible, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Margin="0,0,0,10"
                                                                           FontSize="32"
                                                                           FontWeight="Bold"
                                                                           Foreground="#FF328A5D"
                                                                           Text="Reset Password"/>

                                                                <StackPanel Visibility="{Binding IsForgotEmailStep, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Margin="0,0,0,30"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   Text="Enter your email to receive a reset code"
                                                                                   TextWrapping="Wrap"/>
                                                                        <TextBox Height="50"
                                                                                 Margin="0,0,0,25"
                                                                                 Tag="E-mail"
                                                                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                                                                        <Button Height="48"
                                                                                Margin="0,0,0,15"
                                                                                Background="#FF328A5D"
                                                                                Click="SendResetLink_Click"
                                                                                Content="Send reset code"
                                                                                Foreground="White"
                                                                                FontWeight="SemiBold"/>
                                                                </StackPanel>

                                                                <StackPanel Visibility="{Binding IsForgotCodeStep, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Margin="0,0,0,20"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   Text="Enter the verification code from your email"
                                                                                   TextWrapping="Wrap"/>
                                                                        <TextBox Height="50"
                                                                                 Margin="0,0,0,25"
                                                                                 Tag="Recovery Code"
                                                                                 Text="{Binding ResetToken, UpdateSourceTrigger=PropertyChanged}"/>
                                                                        <Button Height="48"
                                                                                Margin="0,0,0,15"
                                                                                Background="#FF328A5D"
                                                                                Click="VerifyOnlyCode_Click"
                                                                                Content="Verify code"
                                                                                Foreground="White"
                                                                                FontWeight="SemiBold"/>
                                                                </StackPanel>

                                                                <StackPanel Visibility="{Binding IsForgotNewPasswordStep, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Margin="0,0,0,20"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   Text="Create your new password"
                                                                                   TextWrapping="Wrap"/>
                                                                        <PasswordBox x:Name="ForgotNewPassword"
                                                                                     Height="50"
                                                                                     Tag="New Password"
                                                                                     Margin="0,0,0,15"/>
                                                                        <PasswordBox x:Name="ForgotRepeatPassword"
                                                                                     Height="50"
                                                                                     Tag="Repeat Password"
                                                                                     Margin="0,0,0,25"/>
                                                                        <Button Height="48"
                                                                                Margin="0,0,0,15"
                                                                                Background="#FF328A5D"
                                                                                Click="SaveNewPassword_Click"
                                                                                Content="Save new password"
                                                                                Foreground="White"
                                                                                FontWeight="SemiBold"/>
                                                                </StackPanel>

                                                                <Button HorizontalAlignment="Center"
                                                                        Background="Transparent"
                                                                        Click="NavToLogin_Click"
                                                                        Content="Back to Login"
                                                                        Cursor="Hand"
                                                                        FontSize="13"
                                                                        Style="{StaticResource AccentLinkButtonStyle}"/>
                                                        </StackPanel>
                                                </StackPanel>
                                        </ScrollViewer>

                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Left"
                                                    Margin="40,8,0,16">
                                                <TextBlock x:Name="LoginThemeIcon"
                                                           Text="☀️"
                                                           FontSize="16"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock x:Name="LoginThemeLabel"
                                                           Text="Light Mode"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextMainBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>
                                                <ToggleButton x:Name="LoginThemeToggle"
                                                              Style="{StaticResource ToggleSwitchStyle}"
                                                              Click="ThemeToggle_Click"/>
                                        </StackPanel>
                                </Grid>
                        </Border>
                </Grid>

                <Grid Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="0,0,1,0"
                                Padding="25,30,20,25">

                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Margin="0,0,0,40">
                                                <Border Width="42"
                                                        Height="42"
                                                        Background="#1B2A2F"
                                                        CornerRadius="12"
                                                        Margin="0,0,15,0">
                                                        <TextBlock Text="🌱"
                                                                   Foreground="#328A5D"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="20"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Habit Tracker"
                                                                   FontSize="18"
                                                                   FontWeight="Bold"
                                                                   Foreground="#1B2A2F"/>
                                                        <TextBlock Text="DAILY GROWTH"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1">
                                                <Border Background="#E8F0EA"
                                                        CornerRadius="10"
                                                        Margin="0,2"
                                                        Padding="15,12">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⊞"
                                                                           FontSize="18"
                                                                           Foreground="#328A5D"
                                                                           Margin="0,0,15,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="Dashboard"
                                                                           FontSize="14"
                                                                           FontWeight="Bold"
                                                                           Foreground="#328A5D"
                                                                           VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                </Border>

                                                <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="🔄"
                                                                           FontSize="16"
                                                                           Margin="0,0,15,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="Habits Manager"
                                                                           VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="📅"
                                                                           FontSize="16"
                                                                           Margin="0,0,15,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="Calendar"
                                                                           VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="📊"
                                                                           FontSize="16"
                                                                           Margin="0,0,15,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="Statistics"
                                                                           VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="📏"
                                                                           FontSize="16"
                                                                           Margin="0,0,15,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="Measurements"
                                                                           VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="📑"
                                                                           FontSize="16"
                                                                           Margin="0,0,15,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="PDF Report"
                                                                           VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⚙️"
                                                                           FontSize="16"
                                                                           Margin="0,0,15,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="Settings"
                                                                           VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                </Button>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2">

                                                <Button Background="#328A5D"
                                                        Foreground="White"
                                                        Margin="0,0,0,25"
                                                        Height="48"
                                                        Cursor="Hand"
                                                        BorderThickness="0">
                                                        <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                CornerRadius="12"
                                                                                x:Name="Bg">
                                                                                <StackPanel Orientation="Horizontal"
                                                                                            HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center">
                                                                                        <TextBlock Text="+"
                                                                                                   FontSize="18"
                                                                                                   FontWeight="Bold"
                                                                                                   Margin="0,0,8,0"
                                                                                                   VerticalAlignment="Center"/>
                                                                                        <TextBlock Text="New Habit"
                                                                                                   FontSize="14"
                                                                                                   FontWeight="SemiBold"
                                                                                                   VerticalAlignment="Center"/>
                                                                                </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver"
                                                                                         Value="True">
                                                                                        <Setter TargetName="Bg"
                                                                                                Property="Opacity"
                                                                                                Value="0.9"/>
                                                                                </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                        </Button.Template>
                                                </Button>

                                                <StackPanel Orientation="Horizontal"
                                                            Margin="15,10,0,10"
                                                            VerticalAlignment="Center"
                                                            Cursor="Hand">
                                                        <Border Width="24"
                                                                Height="24"
                                                                CornerRadius="12"
                                                                Margin="0,0,15,0">
                                                                <Border.Background>
                                                                        <ImageBrush ImageSource="{Binding AvatarPath}"
                                                                                    Stretch="UniformToFill"/>
                                                                </Border.Background>
                                                        </Border>
                                                        <TextBlock Text="{Binding Nickname}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal"
                                                            Margin="15,10,0,10"
                                                            VerticalAlignment="Center"
                                                            Cursor="Hand">
                                                        <TextBlock x:Name="DashboardThemeIcon"
                                                                   Text="☀️"
                                                                   FontSize="16"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   Margin="0,0,15,0"/>
                                                        <TextBlock x:Name="DashboardThemeLabel"
                                                                   Text="Light Mode"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   VerticalAlignment="Center"/>

                                                        <ToggleButton x:Name="DashboardThemeToggle"
                                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                                      Click="ThemeToggle_Click"
                                                                      Margin="25,0,0,0"/>
                                                </StackPanel>

                                                <Button Style="{StaticResource SidebarMenuItemStyle}"
                                                        Click="LogoutButton_Click"
                                                        Padding="15,10"
                                                        Margin="0">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="🚪"
                                                                           FontSize="16"
                                                                           Margin="0,0,15,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="Logout"
                                                                           FontSize="13"
                                                                           VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                </Button>
                                        </StackPanel>
                                </Grid>
                        </Border>
                        <Grid Grid.Column="1">
                                <TextBlock Text="Dashboard"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Grid>
                </Grid>

        </Grid>
</Window>