<Window
    x:Class="HabitTracker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HabitTracker"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="HabitTracker"
    Width="800"
    Height="600"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="10,8"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF4E606C" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>
    
    <Grid Background="#FFF4F4E9">
        <Border
            Width="380"
            Padding="35,35,35,45"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="20"
                    Opacity="0.08"
                    ShadowDepth="4"
                    Color="Black" />
            </Border.Effect>

            <Grid>
                
                <StackPanel Visibility="{Binding IsLoginVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Margin="0,0,0,5" FontSize="36" FontWeight="Bold" Foreground="#FF328A5D" Text="Habit Tracker" TextAlignment="Center" />
                    <TextBlock Margin="0,0,0,30" FontSize="14" Foreground="#FF8B9AA2" Text="Please log in to continue" TextAlignment="Center" />

                    <TextBlock Style="{StaticResource LabelStyle}" Text="E-mail" />
                    <TextBox x:Name="EmailInput" Height="38" Margin="0,0,0,15" Padding="10,8" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource LabelStyle}" Text="Password" />
                    <PasswordBox x:Name="LoginPassword" Height="38" Margin="0,0,0,15" Padding="10,8" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" />

                    <Button Height="42" Margin="0,0,0,15" Background="#FF328A5D" Click="LoginButton_Click" Content="Sign in" />

                    <Button Height="42" Background="#FF8EAD9C" Click="NavToRegister_Click" Content="Create new account" />

                    <Button Margin="0,15,0,0" HorizontalAlignment="Center" Background="Transparent" Click="NavToForgot_Click" Content="Forgot your password?" Cursor="Hand" FontSize="12" Foreground="#FF4E606C">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline" />
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel Visibility="{Binding IsRegisterVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Margin="0,0,0,5" FontSize="28" FontWeight="Bold" Foreground="#FF328A5D" Text="Sign Up" TextAlignment="Center" />
                    <TextBlock Margin="0,0,0,20" FontSize="14" Foreground="#FF8B9AA2" Text="Create your new account" TextAlignment="Center" />

                    <TextBlock Style="{StaticResource LabelStyle}" Text="Nickname" />
                    <TextBox Height="38" Margin="0,0,0,15" Padding="10,8" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource LabelStyle}" Text="E-mail" />
                    <TextBox Height="38" Margin="0,0,0,15" Padding="10,8" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource LabelStyle}" Text="Password" />
                    <PasswordBox x:Name="RegisterPassword" Height="38" Margin="0,0,0,15" Padding="10,8" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" />

                    <TextBlock Style="{StaticResource LabelStyle}" Text="Repeat Password" />
                    <PasswordBox x:Name="RegisterRepeatPassword" Height="38" Margin="0,0,0,25" Padding="10,8" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" />

                    <Button Height="42" Margin="0,0,0,15" Background="#FF328A5D" Click="RegisterButton_Click" Content="Sign up" />

                    <Button HorizontalAlignment="Center" Background="Transparent" Click="NavToLogin_Click" Content="Back to Login" Cursor="Hand" FontSize="13" Foreground="#FF8B9AA2">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline" />
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel Visibility="{Binding IsForgotVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Margin="0,0,0,10" FontSize="28" FontWeight="Bold" Foreground="#FF328A5D" Text="Reset Password" TextAlignment="Center" />
                    <TextBlock Margin="0,0,0,30" FontSize="14" Foreground="#FF8B9AA2" Text="Enter your email to receive a reset link" TextAlignment="Center" TextWrapping="Wrap" />

                    <TextBlock Style="{StaticResource LabelStyle}" Text="E-mail" />
                    <TextBox Height="38" Margin="0,0,0,25" Padding="10,8" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Height="42" Margin="0,0,0,15" Background="#FF328A5D" Click="SendResetLink_Click" Content="Send reset link" />

                    <Button HorizontalAlignment="Center" Background="Transparent" Click="NavToLogin_Click" Content="Back to Login" Cursor="Hand" FontSize="13" Foreground="#FF8B9AA2">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline" />
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <TextBlock
                    x:Name="StatusMessage"
                    Margin="0,0,0,-30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    FontWeight="Medium"
                    Text="{Binding StatusMessage}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                    
            </Grid>
        </Border>
    </Grid>
</Window>