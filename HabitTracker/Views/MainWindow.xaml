<Window
    x:Class="HabitTracker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HabitTracker"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="HabitTracker"
    Width="800"
    Height="550"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="10,8"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF4E606C" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>
    <Grid Background="#FFF4F4E9">
        <Border
            Width="380"
            Padding="35"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="20"
                    Opacity="0.08"
                    ShadowDepth="4"
                    Color="Black" />
            </Border.Effect>

            <StackPanel>

                <TextBlock
                    Margin="0,0,0,5"
                    FontSize="36"
                    FontWeight="Bold"
                    Foreground="#FF328A5D"
                    Text="Habit Tracker"
                    TextAlignment="Center" />

                <TextBlock
                    Margin="0,0,0,30"
                    FontSize="14"
                    Foreground="#FF8B9AA2"
                    Text="Please log in to continue"
                    TextAlignment="Center" />

                <TextBlock Style="{StaticResource LabelStyle}" Text="E-mail" />
                <TextBox
                    x:Name="EmailInput"
                    Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                    Height="38"
                    Margin="0,0,0,15"
                    Padding="10,8"
                    BorderBrush="#FFDDE2E5"
                    BorderThickness="1"
                    FontSize="14" />

                <TextBlock Style="{StaticResource LabelStyle}" Text="Password" />
                <PasswordBox
                    x:Name="PasswordInput"
                    Height="38"
                    Margin="0,0,0,25"
                    Padding="10,8"
                    BorderBrush="#FFDDE2E5"
                    BorderThickness="1"
                    FontSize="14" />

                <Button
                    Height="42"
                    Margin="0,0,0,12"
                    Background="#FF328A5D"
                    Click="LoginButton_Click"
                    Content="Sign in" />

                <Button
                    Height="42"
                    Background="#FF8EAD9C"
                    Click="RegisterButton_Click"
                    Content="Create new account" />

                <TextBlock
                    x:Name="StatusMessage"
                    Text="{Binding StatusMessage}"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    FontWeight="Medium"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
