<Window x:Class="HabitTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitTracker"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">
    <Grid Background="#FFF4F4E9">
        <StackPanel 
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            
            <TextBlock
                FontSize="32"
                FontWeight="Bold"
                Foreground="#FF4E606C"
                Margin="0,0,0,20" 
                Text="Habit Tracker" TextAlignment="Center"/>

            <TextBlock 
                Text="Email:" 
                Margin="0,0,0,5"/>
            <TextBox 
                x:Name="EmailInput" 
                Height="30" 
                Margin="0,0,0,15" 
                Padding="5"/>

            <TextBlock 
                Text="Hasło:" 
                Margin="0,0,0,5"/>
            <PasswordBox 
                x:Name="PasswordInput" 
                Height="30" 
                Margin="0,0,0,25" 
                Padding="5" 
                Password=""/>

            <Button 
                Content="Zaloguj się" 
                Background="#FF328A5D" 
                Foreground="White" 
                Height="40" 
                Margin="0,0,0,10" 
                Click="LoginButton_Click"/>
            
            <Button 
                Content="Zarejestruj się" 
                Background="#4BB16F" 
                Foreground="White" 
                Height="40" 
                Click="RegisterButton_Click"/>

            <TextBlock 
                x:Name="StatusMessage" 
                Foreground="Red" 
                HorizontalAlignment="Center" 
                Margin="0,20,0,0" 
                TextWrapping="Wrap"/>

        </StackPanel>
    </Grid>
</Window>