<Window x:Class="HabitTracker.Views.EditProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Profile"
        Width="400"
        SizeToContent="Height"
        Background="White"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        BorderThickness="0">
    <Border Background="White" CornerRadius="12" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="20" ShadowDepth="4"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Edit Profile" FontWeight="Bold" FontSize="16" Foreground="#1C1C1C" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="#1C1C1C" FontSize="16" Cursor="Hand" Click="Close_Click"/>
            </Grid>
            
            <!-- Avatar Section -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,24">
                <Grid Width="100" Height="100">
                    <Ellipse Fill="#F0F4F2" Width="100" Height="100"/>
                    <TextBlock Text="{Binding UserInitial}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="36" Foreground="#328A5D" FontWeight="Bold" />
                    <!-- Placeholder for image -->
                    
                    <Button Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,4" Background="#328A5D" Foreground="White" BorderThickness="2" BorderBrush="White" Cursor="Hand" Click="ChangePhoto_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="{TemplateBinding BorderThickness}"/>
                                    <TextBlock Text="+" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{TemplateBinding Foreground}" Margin="0,0,0,2"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <TextBlock Text="CHANGE PHOTO" Foreground="#328A5D" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" Margin="0,12,0,0" Cursor="Hand" MouseLeftButtonUp="ChangePhoto_Click"/>
            </StackPanel>
            
            <!-- Full Name -->
            <StackPanel Grid.Row="2" Margin="0,0,0,24">
                <TextBlock Text="FULL NAME" FontWeight="Bold" FontSize="11" Foreground="#8C9B9F" Margin="0,0,0,6"/>
                <TextBox x:Name="FullNameInput" Height="48" Padding="12,0" Background="#F2F3F5" BorderBrush="Transparent" BorderThickness="0" Foreground="#1C1C1C" FontSize="14" VerticalContentAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>
            
            <!-- Error message -->
            <TextBlock x:Name="ErrorText" Grid.Row="3" Foreground="#FFD32F2F" TextWrapping="Wrap" Margin="0,0,0,16" Visibility="Collapsed"/>
            
            <!-- Actions -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Height="38" Margin="0,0,12,0" Click="Close_Click" Background="Transparent" Foreground="#8C9B9F" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Save Changes" Width="120" Height="38" Click="Save_Click" Background="#328A5D" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
