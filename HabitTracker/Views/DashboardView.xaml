<UserControl x:Class="HabitTracker.Views.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HabitTracker"
        xmlns:views="clr-namespace:HabitTracker.Views">
        <Grid Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{DynamicResource InputBorderBrush}"
                        BorderThickness="0,0,1,0" Padding="25,30,20,25">

                        <Grid>
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,40">
                                        <Border Width="42" Height="42" Background="#1B2A2F"
                                                CornerRadius="12" Margin="0,0,15,0">
                                                <TextBlock Text="🌱" Foreground="#328A5D"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" FontSize="20" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Habit Tracker" FontSize="18"
                                                        FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                                <TextBlock Text="DAILY GROWTH" FontSize="10"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource TextMutedBrush}" />
                                        </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="1">
                                        <Button x:Name="NavDashboard" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToDashboard_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🏠" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Dashboard, Source={StaticResource Loc}}"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>

                                        <Button x:Name="NavHabits" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToHabits_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔄" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding HabitsManager, Source={StaticResource Loc}}"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavCalendar" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToCalendar_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📅" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Calendar, Source={StaticResource Loc}}"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavStatistics" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToStatistics_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📊" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Statistics, Source={StaticResource Loc}}"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavMeasurements" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToMeasurements_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📏" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Measurements, Source={StaticResource Loc}}"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavPdfReport" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToPdfReport_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📑" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding PdfReport, Source={StaticResource Loc}}"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavSettings" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToSettings_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⚙️" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Settings, Source={StaticResource Loc}}"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                </StackPanel>

                                <StackPanel Grid.Row="2">

                                        <!-- New Habit button removed from sidebar; adding now only in Habits Manager -->

                                        <StackPanel Orientation="Horizontal" Margin="15,10,0,10"
                                                VerticalAlignment="Center" Cursor="Hand">
                                                <Border Width="24" Height="24" CornerRadius="12"
                                                        Margin="0,0,15,0">
                                                        <Border.Background>
                                                                <ImageBrush
                                                                        ImageSource="{Binding AvatarPath}"
                                                                        Stretch="UniformToFill" />
                                                        </Border.Background>
                                                </Border>
                                                <TextBlock Text="{Binding Nickname}" FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        VerticalAlignment="Center" />
                                        </StackPanel>



                                        <Button Style="{StaticResource SidebarMenuItemStyle}"
                                                Click="LogoutButton_Click" Padding="15,10"
                                                Margin="0">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🚪" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Logout, Source={StaticResource Loc}}" FontSize="13"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                </StackPanel>
                        </Grid>
                </Border>
                <Grid Grid.Column="1" x:Name="MainContentArea" Margin="40,20,20,20">
                        <Grid Visibility="{Binding IsHabitsVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Header Section -->
                                <Grid Grid.Row="0" Margin="0,0,0,24">
                                        <StackPanel VerticalAlignment="Top">
                                                <TextBlock Text="{Binding HabitsManager, Source={StaticResource Loc}}" FontSize="32" FontWeight="Bold"
                                                        Foreground="{DynamicResource TextMainBrush}" />
                                                <TextBlock Text="{Binding WhatPlanToAchieve, Source={StaticResource Loc}}"
                                                        FontSize="14" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" />
                                        </StackPanel>

                                        <!-- Add Habit Button -->
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                Click="AddHabit_Click" 
                                                Background="{DynamicResource AccentGreenBrush}" 
                                                Foreground="White" 
                                                FontWeight="Bold" 
                                                FontSize="16"
                                                Padding="24,14" 
                                                BorderThickness="0" 
                                                Cursor="Hand">
                                                <StackPanel Orientation="Horizontal" Margin="0">
                                                        <TextBlock Text="+" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Add Habit" VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                </Grid>

                                <!-- Search Box -->
                                <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                                        <TextBox x:Name="SearchBox" Tag="Search habits..." Height="44" Margin="0" />
                                </Border>

                                <!-- Filter Boxes -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
                                        <!-- Priority Filter -->
                                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="12" MinWidth="180" Margin="0,0,12,0">
                                                <StackPanel>
                                                        <TextBlock Text="PRIORITY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" />
                                                        <ComboBox x:Name="PriorityFilter" ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority}" DisplayMemberPath="Name" Height="36" Padding="10,6" />
                                                </StackPanel>
                                        </Border>

                                        <!-- Category Filter -->
                                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="12" MinWidth="180" Margin="0,0,12,0">
                                                <StackPanel>
                                                        <TextBlock Text="CATEGORY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" />
                                                        <ComboBox x:Name="CategoryFilter" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategoryFilter}" DisplayMemberPath="Name" Height="36" Padding="10,6" />
                                                </StackPanel>
                                        </Border>

                                        <!-- Status Filter -->
                                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="12" MinWidth="180" Margin="0,0,12,0">
                                                <StackPanel>
                                                        <TextBlock Text="STATUS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" />
                                                        <ComboBox x:Name="StatusFilter" ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" DisplayMemberPath="Name" Height="36" Padding="10,6" />
                                                </StackPanel>
                                        </Border>

                                        <!-- Frequency Filter -->
                                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="12" MinWidth="180">
                                                <StackPanel>
                                                        <TextBlock Text="FREQUENCY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" />
                                                        <ComboBox x:Name="FrequencyFilter" ItemsSource="{Binding Frequencies}" SelectedItem="{Binding SelectedFrequency}" DisplayMemberPath="Name" Height="36" Padding="10,6" />
                                                </StackPanel>
                                        </Border>
                                </StackPanel>

                                <!-- Habits List Container -->
                                <Border Grid.Row="3" Background="{DynamicResource CardBgBrush}" CornerRadius="15" Padding="20">
                                        <Grid>
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <!-- List Header -->
                                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="140" />
                                                                <ColumnDefinition Width="100" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource InputBorderBrush}" Padding="0,0,0,12">
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="HABIT DETAILS" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" />
                                                                </Grid>
                                                        </Border>
                                                        
                                                        <TextBlock Grid.Column="1" Text="CATEGORY" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,12" />
                                                        <TextBlock Grid.Column="2" Text="FREQUENCY" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,12" />
                                                        <TextBlock Grid.Column="3" Text="ACTIONS" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12" />
                                                </Grid>

                                                <!-- Habits Items List -->
                                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                                                        <ItemsControl ItemsSource="{Binding Habits}">
                                                                <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                                <Border Background="Transparent" CornerRadius="12" Padding="0,12,0,12" Margin="0,0,0,0" BorderThickness="0,0,0,1" BorderBrush="#FFF0F3F1">
                                                                                        <Grid>
                                                                                                <Grid.ColumnDefinitions>
                                                                                                        <ColumnDefinition Width="*" />
                                                                                                        <ColumnDefinition Width="180" />
                                                                                                        <ColumnDefinition Width="140" />
                                                                                                        <ColumnDefinition Width="100" />
                                                                                                </Grid.ColumnDefinitions>

                                                                                                <!-- Habit Details (Icon + Name) -->
                                                                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                                                        <Border Width="40" Height="40" Background="#E9FFF3" CornerRadius="10" VerticalAlignment="Center">
                                                                                                                <TextBlock Text="💧" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                                                                                        </Border>
                                                                                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                                                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextMainBrush}" />
                                                                                                        </StackPanel>
                                                                                                </StackPanel>

                                                                                                <!-- Category -->
                                                                                                <TextBlock Grid.Column="1" Text="{Binding Category.Name}" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />

                                                                                                <!-- Frequency Badge -->
                                                                                                <Border Grid.Column="2" Background="#E6F8F0" CornerRadius="8" Padding="10,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                                                        <TextBlock Text="{Binding Period}" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" FontSize="11" />
                                                                                                </Border>

                                                                                                <!-- Actions -->
                                                                                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                                                        <Button Click="EditHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" Margin="0,0,8,0" ToolTip="Edit">
                                                                                                                <TextBlock Text="✏️" FontSize="14" />
                                                                                                        </Button>
                                                                                                        <Button Click="DeleteHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" ToolTip="Delete">
                                                                                                                <TextBlock Text="🗑️" FontSize="14" />
                                                                                                        </Button>
                                                                                                </StackPanel>
                                                                                        </Grid>
                                                                                </Border>
                                                                        </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                </ScrollViewer>
                                        </Grid>
                                </Border>
                        </Grid>

                        <!-- Dashboard personal habits visualization -->
                        <Grid Visibility="{Binding IsDashboardContent, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="2*" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Dashboard, Source={StaticResource Loc}}" FontSize="28" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding TodayDate}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>

                                <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}"
                                        CornerRadius="12" Padding="16" Margin="0,8,0,0">
                                        <StackPanel>
                                                <TextBlock Text="{Binding MyHabits, Source={StaticResource Loc}}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,8" />
                                                <TextBlock Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap">
                                                        Personal habits will appear here.
                                                        <LineBreak/>
                                                        Select from the built-in list or create your own in the Habits Manager.
                                                </TextBlock>

                                                <ItemsControl ItemsSource="{Binding Habits}" Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,6" VerticalAlignment="Center">
                                                                                <CheckBox Width="20" Height="20" Margin="0,0,10,0" />
                                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                                                <TextBox Width="100" Margin="10,0,0,0" />
                                                                        </StackPanel>
                                                                </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                        </StackPanel>
                                </Border>

                                <!-- Notes area: 1/3 height under habits -->
                                <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                                <TextBlock Text="{Binding MyNotes, Source={StaticResource Loc}}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,8" />
                                                <TextBox AcceptsReturn="True" TextWrapping="Wrap" Height="120" VerticalScrollBarVisibility="Auto" />
                                        </StackPanel>
                                </Border>
                        </Grid>

                        <views:MeasurementsView Visibility="{Binding IsMeasurementsVisible, Converter={StaticResource BoolToVis}}" />

                        <!-- Calendar Section -->
                        <Grid Visibility="{Binding IsCalendarVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <!-- Navigation arrows -->
                                            <Button Content="&lt;" Command="{Binding PreviousMonthCommand}" Background="Transparent" BorderThickness="0" FontSize="20" FontWeight="Bold" Margin="0,0,15,0" Cursor="Hand" Foreground="#111827" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CurrentMonthYear}" FontSize="28" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center" />
                                            <Button Content="&gt;" Command="{Binding NextMonthCommand}" Background="Transparent" BorderThickness="0" FontSize="20" FontWeight="Bold" Margin="15,0,0,0" Cursor="Hand" Foreground="#111827" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding CurrentProtocolText}" FontSize="14" Foreground="#6B7280" />
                                    </StackPanel>

                                    <!-- Monthly / Weekly toggle -->
                                    <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="10" Padding="4" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Command="{Binding SetMonthlyViewCommand}" BorderThickness="0" Cursor="Hand" Background="Transparent" Padding="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="8" Padding="15,8" Background="{TemplateBinding Background}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMonthlyView}" Value="True">
                                                                            <Setter Property="Background" Value="White" />
                                                                            <Setter Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.05" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="Monthly" FontSize="12">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#6B7280" />
                                                                        <Setter Property="FontWeight" Value="Normal" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMonthlyView}" Value="True">
                                                                                <Setter Property="Foreground" Value="#328A5D" />
                                                                                <Setter Property="FontWeight" Value="Bold" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            
                                            <Button Command="{Binding SetWeeklyViewCommand}" BorderThickness="0" Cursor="Hand" Background="Transparent" Padding="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="8" Padding="15,8" Background="{TemplateBinding Background}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMonthlyView}" Value="False">
                                                                            <Setter Property="Background" Value="White" />
                                                                            <Setter Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.05" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="Weekly" FontSize="12">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#6B7280" />
                                                                        <Setter Property="FontWeight" Value="Normal" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMonthlyView}" Value="False">
                                                                                <Setter Property="Foreground" Value="#328A5D" />
                                                                                <Setter Property="FontWeight" Value="Bold" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Days of week -->
                                    <Grid Grid.Row="0" Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="MON" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#9CA3AF" FontSize="11" />
                                        <TextBlock Grid.Column="1" Text="TUE" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#9CA3AF" FontSize="11" />
                                        <TextBlock Grid.Column="2" Text="WED" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#9CA3AF" FontSize="11" />
                                        <TextBlock Grid.Column="3" Text="THU" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#9CA3AF" FontSize="11" />
                                        <TextBlock Grid.Column="4" Text="FRI" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#9CA3AF" FontSize="11" />
                                        <TextBlock Grid.Column="5" Text="SAT" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#9CA3AF" FontSize="11" />
                                        <TextBlock Grid.Column="6" Text="SUN" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#9CA3AF" FontSize="11" />
                                    </Grid>

                                    <!-- Calendar Grid -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding CalendarDays}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="7" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="4" CornerRadius="10" Height="85" Cursor="Hand" Padding="8,8,8,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="True">
                                                                        <Setter Property="Background" Value="White" />
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2" Direction="270" Color="Black" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#328A5D" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Grid.Row="0" Text="{Binding DayNumber}" FontWeight="Bold" FontSize="11">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#111827" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                                <Setter Property="Foreground" Value="#D1D5DB" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                <Setter Property="Foreground" Value="White" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <Border Grid.Row="1" Background="{Binding BadgeColor}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="8,4" Margin="0,2,0,0">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding PercentageText}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding PercentageText}" FontSize="9" FontWeight="Bold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#328A5D" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding BadgeColor}" Value="#FFF0F0">
                                                                                    <Setter Property="Foreground" Value="#D32F2F" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                    <Setter Property="Foreground" Value="White" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                                            <Ellipse Grid.Row="2" Width="4" Height="4" Fill="{Binding DotColor}" HorizontalAlignment="Center" Margin="0,5,0,0" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                        </Grid>

                        <!-- Statistics Section -->
                        <Grid Visibility="{Binding IsStatisticsVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                        <TextBlock Text="{Binding Statistics, Source={StaticResource Loc}}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                        <TextBlock Text="{Binding ViewProgressAchievements, Source={StaticResource Loc}}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="20">
                                                Statistics content will be added here.
                                        </TextBlock>
                                </ScrollViewer>
                        </Grid>

                        <!-- PDF Report Section -->
                        <Grid Visibility="{Binding IsPdfReportVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                        <TextBlock Text="{Binding PdfReport, Source={StaticResource Loc}}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                        <TextBlock Text="{Binding GenerateDownloadReports, Source={StaticResource Loc}}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="20">
                                                PDF Report content will be added here.
                                        </TextBlock>
                                </ScrollViewer>
                        </Grid>


                        <Grid x:Name="SettingsPanel" Visibility="{Binding DataContext.IsSettingsVisible, ElementName=MainContentArea, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="0,0,0,24">
                                        <TextBlock Text="{Binding Settings, Source={StaticResource Loc}}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding ManageAccount, Source={StaticResource Loc}}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,14,20">
                                        <StackPanel Orientation="Vertical">

                                                <!-- Card 1: User Profile -->
                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                                                        <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <Grid Width="60" Height="60" VerticalAlignment="Center" Margin="0,0,16,0">
                                                                        <!-- Background circle with initial (always present as fallback) -->
                                                                        <Border CornerRadius="30" Background="#E6F4EA">
                                                                                <TextBlock Text="{Binding UserInitial}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" Foreground="#328A5D" FontWeight="Bold" />
                                                                        </Border>
                                                                        <!-- Avatar image overlay (shown when avatar is available) -->
                                                                        <Ellipse Width="60" Height="60">
                                                                                <Ellipse.Style>
                                                                                        <Style TargetType="Ellipse">
                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding HasAvatarImage}" Value="True">
                                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                                        </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                        </Style>
                                                                                </Ellipse.Style>
                                                                                <Ellipse.Fill>
                                                                                        <ImageBrush ImageSource="{Binding AvatarImageSource}" Stretch="UniformToFill"/>
                                                                                </Ellipse.Fill>
                                                                        </Ellipse>
                                                                </Grid>
                                                                
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                                <TextBlock Text="{Binding UserName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding UserEmail}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                                                </StackPanel>
                                                                
                                                                <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right" Orientation="Vertical">
                                                                        <Button Content="{Binding EditProfile, Source={StaticResource Loc}}" Width="100" Height="32" Margin="0,0,0,10" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" FontSize="12" BorderThickness="0" Cursor="Hand" Click="EditProfile_Click">
                                                                                <Button.Resources>
                                                                                        <Style TargetType="Border">
                                                                                                <Setter Property="CornerRadius" Value="16"/>
                                                                                        </Style>
                                                                                </Button.Resources>
                                                                        </Button>
                                                                        <TextBlock Text="{Binding ChangePassword, Source={StaticResource Loc}}" Foreground="#328A5D" FontSize="12" FontWeight="Bold" Cursor="Hand" HorizontalAlignment="Center" MouseLeftButtonUp="ChangePassword_Click" />
                                                                </StackPanel>
                                                        </Grid>
                                                </Border>

                                                <!-- Card 2: General -->
                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                                                        <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                                        <TextBlock Text="⚙️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding General, Source={StaticResource Loc}}" FontSize="15" FontWeight="Bold" Foreground="#328A5D" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                                
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        
                                                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                                <TextBlock Text="{Binding Language, Source={StaticResource Loc}}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,6" />
                                                                                <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding SelectedLanguage}" Height="36" />
                                                                        </StackPanel>
                                                                        
                                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                                                <TextBlock Text="{Binding StartOfWeek, Source={StaticResource Loc}}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,6" />
                                                                                <ComboBox ItemsSource="{Binding AvailableWeekStarts}" SelectedItem="{Binding SelectedWeekStart}" Height="36" />
                                                                        </StackPanel>
                                                                </Grid>
                                                        </StackPanel>
                                                </Border>

                                                <!-- Card 3: Appearance -->
                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                                                        <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                                        <TextBlock Text="🎨" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Appearance, Source={StaticResource Loc}}" FontSize="15" FontWeight="Bold" Foreground="#328A5D" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                                
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0">
                                                                                <TextBlock Text="{Binding DarkMode, Source={StaticResource Loc}}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,2"/>
                                                                                <TextBlock Text="{Binding DarkModeDesc, Source={StaticResource Loc}}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                        </StackPanel>
                                                                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" x:Name="DarkModeToggle" IsChecked="{Binding IsDarkMode, Mode=TwoWay}" />
                                                                </Grid>
                                                        </StackPanel>
                                                </Border>

                                                <!-- Card 4: Notifications -->
                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                                                        <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                                        <TextBlock Text="🔔" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Notifications, Source={StaticResource Loc}}" FontSize="15" FontWeight="Bold" Foreground="#328A5D" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                                
                                                                <Grid Margin="0,0,0,16">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0">
                                                                                <TextBlock Text="{Binding DailyReminders, Source={StaticResource Loc}}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,2"/>
                                                                                <TextBlock Text="{Binding DailyRemindersDesc, Source={StaticResource Loc}}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                        </StackPanel>
                                                                        
                                                                        <Border Grid.Column="1" Background="{DynamicResource InputBgBrush}" CornerRadius="8" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Text="⏱" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                                        <ComboBox ItemsSource="{Binding AvailableReminderTimes}" SelectedItem="{Binding SelectedReminderTime}" Height="36" Width="130" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextMainBrush}" FontSize="13" VerticalContentAlignment="Center"/>
                                                                                </StackPanel>
                                                                        </Border>
                                                                        
                                                                        <ToggleButton Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding IsDailyReminder}" VerticalAlignment="Center"/>
                                                                </Grid>



                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0">
                                                                                <TextBlock Text="{Binding AchievementBadges, Source={StaticResource Loc}}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,2"/>
                                                                                <TextBlock Text="{Binding AchievementBadgesDesc, Source={StaticResource Loc}}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                        </StackPanel>
                                                                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding IsAchievementBadgesEnabled}" VerticalAlignment="Center"/>
                                                                </Grid>
                                                        </StackPanel>
                                                </Border>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,40">
                                                        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="13">
                                                                <TextBlock.Foreground>
                                                                        <SolidColorBrush Color="{Binding StatusColor}" />
                                                                </TextBlock.Foreground>
                                                        </TextBlock>
                                                        <Button Content="{Binding SaveSettings, Source={StaticResource Loc}}" Click="SaveSettings_Click"
                                                                Background="#FF328A5D" Foreground="White"
                                                                FontWeight="Bold" Padding="24,10"
                                                                BorderThickness="0" Cursor="Hand"
                                                                FontSize="14" />
                                                </StackPanel>
                                        </StackPanel>
                                </ScrollViewer>
                </Grid>
        </Grid>
        
        <Border x:Name="DialogOverlay" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed" Panel.ZIndex="999" />
        </Grid>
</UserControl>