<UserControl x:Class="HabitTracker.Views.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HabitTracker">
        <Grid Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{DynamicResource InputBorderBrush}"
                        BorderThickness="0,0,1,0" Padding="25,30,20,25">

                        <Grid>
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,40">
                                        <Border Width="42" Height="42" Background="#1B2A2F"
                                                CornerRadius="12" Margin="0,0,15,0">
                                                <TextBlock Text="🌱" Foreground="#328A5D"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" FontSize="20" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Habit Tracker" FontSize="18"
                                                        FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                                <TextBlock Text="DAILY GROWTH" FontSize="10"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource TextMutedBrush}" />
                                        </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="1">
                                        <Button x:Name="NavDashboard" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToHabits_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⊞" FontSize="18"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Dashboard" FontSize="14"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>

                                        <Button x:Name="NavHabits" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToHabits_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔄" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Habits Manager"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📅" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Calendar"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📊" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Statistics"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavMeasurements" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToMeasurements_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📏" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Measurements"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📑" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="PDF Report"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SidebarMenuItemStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⚙️" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Settings"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                </StackPanel>

                                <StackPanel Grid.Row="2">

                                        <Button Background="#328A5D" Foreground="White"
                                                Margin="0,0,0,25" Height="48" Cursor="Hand"
                                                BorderThickness="0" Click="SidebarNewHabit_Click">
                                                <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                                <Border
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="12"
                                                                        x:Name="Bg">
                                                                        <StackPanel
                                                                                Orientation="Horizontal"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center">
                                                                                <TextBlock Text="+"
                                                                                        FontSize="18"
                                                                                        FontWeight="Bold"
                                                                                        Margin="0,0,8,0"
                                                                                        VerticalAlignment="Center" />
                                                                                <TextBlock
                                                                                        Text="New Habit"
                                                                                        FontSize="14"
                                                                                        FontWeight="SemiBold"
                                                                                        VerticalAlignment="Center" />
                                                                        </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                        <Trigger
                                                                                Property="IsMouseOver"
                                                                                Value="True">
                                                                                <Setter
                                                                                        TargetName="Bg"
                                                                                        Property="Opacity"
                                                                                        Value="0.9" />
                                                                        </Trigger>
                                                                </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                </Button.Template>
                                        </Button>

                                        <StackPanel Orientation="Horizontal" Margin="15,10,0,10"
                                                VerticalAlignment="Center" Cursor="Hand">
                                                <Border Width="24" Height="24" CornerRadius="12"
                                                        Margin="0,0,15,0">
                                                        <Border.Background>
                                                                <ImageBrush
                                                                        ImageSource="{Binding AvatarPath}"
                                                                        Stretch="UniformToFill" />
                                                        </Border.Background>
                                                </Border>
                                                <TextBlock Text="{Binding Nickname}" FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        VerticalAlignment="Center" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="15,10,0,10"
                                                VerticalAlignment="Center" Cursor="Hand">
                                                <TextBlock x:Name="DashboardThemeIcon" Text="☀️"
                                                        FontSize="16"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Margin="0,0,15,0" />
                                                <TextBlock x:Name="DashboardThemeLabel"
                                                        Text="Light Mode" FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        VerticalAlignment="Center" />

                                                <ToggleButton x:Name="DashboardThemeToggle"
                                                        Style="{StaticResource ToggleSwitchStyle}"
                                                        Click="ThemeToggle_Click" Margin="25,0,0,0" />
                                        </StackPanel>

                                        <Button Style="{StaticResource SidebarMenuItemStyle}"
                                                Click="LogoutButton_Click" Padding="15,10"
                                                Margin="0">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🚪" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Logout" FontSize="13"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                </StackPanel>
                        </Grid>
                </Border>
                <Grid Grid.Column="1" x:Name="MainContentArea" Margin="40,20,20,20">
                        <Grid Visibility="{Binding IsHabitsVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Your Habits" FontSize="28" FontWeight="Bold"
                                        Foreground="{DynamicResource TextMainBrush}" />
                                <TextBlock Text="What are you planning to achieve today?"
                                        FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
                                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,10,0,0"
                                        Foreground="#FF328A5D"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}"
                                CornerRadius="15" Margin="0,0,0,25" Padding="20"
                                Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                        <TextBlock Text="Create New Habit" FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource TextMainBrush}"
                                                Margin="0,0,0,15" />
                                        <Grid>
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBox
                                                        Text="{Binding NewHabitName, UpdateSourceTrigger=PropertyChanged}"
                                                        Margin="0,0,10,0"
                                                        VerticalContentAlignment="Center"
                                                        Height="50" Padding="10,0"
                                                        Tag="Habit name (e.g. Morning Run)..." />

                                                <ComboBox Grid.Column="1"
                                                        ItemsSource="{Binding Categories}"
                                                        SelectedItem="{Binding SelectedCategory}"
                                                        DisplayMemberPath="Name" Width="140"
                                                        Margin="0,0,10,0" Height="38"
                                                        VerticalContentAlignment="Center" />

                                                <ComboBox Grid.Column="2"
                                                        ItemsSource="{Binding HabitTypes}"
                                                        SelectedItem="{Binding SelectedType}"
                                                        DisplayMemberPath="Type" Width="120"
                                                        Margin="0,0,10,0" Height="38"
                                                        VerticalContentAlignment="Center" />

                                                <Button Grid.Column="3" Content="Save Habit"
                                                        Click="SaveHabit_Click"
                                                        Background="#FF328A5D" Foreground="White"
                                                        FontWeight="Bold" Padding="20,0" Height="38"
                                                        BorderThickness="0" Cursor="Hand" />
                                        </Grid>
                                </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                Padding="0,0,10,0">
                                <ItemsControl ItemsSource="{Binding Habits}">
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                        <Border
                                                                Background="{DynamicResource CardBgBrush}"
                                                                CornerRadius="15" Margin="0,0,0,15"
                                                                Padding="20">
                                                                <Border.Effect>
                                                                        <DropShadowEffect
                                                                                BlurRadius="10"
                                                                                Opacity="0.05"
                                                                                ShadowDepth="2" />
                                                                </Border.Effect>
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition
                                                                                        Width="*" />
                                                                                <ColumnDefinition
                                                                                        Width="Auto" />
                                                                                <ColumnDefinition
                                                                                        Width="Auto" />
                                                                                <ColumnDefinition
                                                                                        Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <StackPanel Grid.Column="0"
                                                                                Margin="0,0,15,0"
                                                                                VerticalAlignment="Bottom">
                                                                                <TextBlock
                                                                                        Text="Habit Name"
                                                                                        FontSize="12"
                                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                                        Margin="0,0,0,5"
                                                                                        FontWeight="SemiBold" />
                                                                                <TextBox
                                                                                        Text="{Binding NewHabitName, UpdateSourceTrigger=PropertyChanged}"
                                                                                        Padding="10,8"
                                                                                        Height="50"
                                                                                        VerticalAlignment="Center"
                                                                                        Tag="e.g. Morning Run..." />
                                                                        </StackPanel>

                                                                        <StackPanel Grid.Column="1"
                                                                                Margin="0,0,15,0"
                                                                                VerticalAlignment="Bottom">
                                                                                <TextBlock
                                                                                        Text="Category"
                                                                                        FontSize="12"
                                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                                        Margin="0,0,0,5"
                                                                                        FontWeight="SemiBold" />
                                                                                <ComboBox
                                                                                        ItemsSource="{Binding Categories}"
                                                                                        SelectedItem="{Binding SelectedCategory}"
                                                                                        DisplayMemberPath="Name"
                                                                                        Width="140"
                                                                                        Padding="10,8" />
                                                                        </StackPanel>

                                                                        <StackPanel Grid.Column="2"
                                                                                Margin="0,0,15,0"
                                                                                VerticalAlignment="Bottom">
                                                                                <TextBlock
                                                                                        Text="Type"
                                                                                        FontSize="12"
                                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                                        Margin="0,0,0,5"
                                                                                        FontWeight="SemiBold" />
                                                                                <ComboBox
                                                                                        ItemsSource="{Binding HabitTypes}"
                                                                                        SelectedItem="{Binding SelectedType}"
                                                                                        DisplayMemberPath="Type"
                                                                                        Width="120"
                                                                                        Padding="10,8" />
                                                                        </StackPanel>

                                                                        <Button Grid.Column="3"
                                                                                Content="Save Habit"
                                                                                Click="SaveHabit_Click"
                                                                                Background="#FF328A5D"
                                                                                Foreground="White"
                                                                                FontWeight="Bold"
                                                                                Padding="20,0"
                                                                                Height="36"
                                                                                BorderThickness="0"
                                                                                Cursor="Hand"
                                                                                VerticalAlignment="Bottom" />
                                                                </Grid>
                                                        </Border>
                                                </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                </ItemsControl>
                        </ScrollViewer>
                        </Grid>

                        <Grid Visibility="{Binding IsMeasurementsVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                        <TextBlock Text="Body Measurements" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                        <TextBlock Text="Track your physical progress (in cm)" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>

                                <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="15" Margin="0,0,0,25" Padding="20">
                                        <StackPanel>
                                                <TextBlock Text="Add New Measurement" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,15" />
                                                <Grid>
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <ComboBox Grid.Column="0" ItemsSource="{Binding BodyParts}" SelectedItem="{Binding SelectedBodyPart}" DisplayMemberPath="DisplayName" Margin="0,0,10,0" Height="38" VerticalContentAlignment="Center" />
                                                        <TextBox Grid.Column="1" Text="{Binding MeasurementValue, UpdateSourceTrigger=PropertyChanged}" Width="100" Margin="0,0,10,0" Height="38" VerticalContentAlignment="Center" Tag="Value (cm)" />
                                                        <Button Grid.Column="2" Content="Save" Click="SaveMeasurement_Click" Background="#FF328A5D" Foreground="White" FontWeight="Bold" Padding="20,0" Height="38" BorderThickness="0" Cursor="Hand" />
                                                </Grid>
                                        </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                        <ItemsControl ItemsSource="{Binding MeasurementLogs}">
                                                <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" Margin="0,0,0,15" Padding="20">
                                                                        <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="{Binding BodyPart.DisplayName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" />
                                                                                <TextBlock Grid.Column="1" Text="{Binding Value, StringFormat={}{0} cm}" FontSize="16" FontWeight="Bold" Foreground="#FF328A5D" VerticalAlignment="Center" />
                                                                        </Grid>
                                                                </Border>
                                                        </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                </ScrollViewer>
                        </Grid>
                </Grid>
        </Grid>
</UserControl>