<UserControl x:Class="HabitTracker.Views.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HabitTracker"
        xmlns:views="clr-namespace:HabitTracker.Views">
        <Grid Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{DynamicResource InputBorderBrush}"
                        BorderThickness="0,0,1,0" Padding="25,30,20,25">

                        <Grid>
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,40">
                                        <Border Width="42" Height="42" Background="#1B2A2F"
                                                CornerRadius="12" Margin="0,0,15,0">
                                                <TextBlock Text="🌱" Foreground="#328A5D"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" FontSize="20" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Habit Tracker" FontSize="18"
                                                        FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                                <TextBlock Text="DAILY GROWTH" FontSize="10"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource TextMutedBrush}" />
                                        </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="1">
                                        <Button x:Name="NavDashboard" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToDashboard_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🏠" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Dashboard"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>

                                        <Button x:Name="NavHabits" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToHabits_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔄" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Habits Manager"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavCalendar" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToCalendar_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📅" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Calendar"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavStatistics" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToStatistics_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📊" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Statistics"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavMeasurements" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToMeasurements_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📏" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Measurements"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavPdfReport" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToPdfReport_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📑" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="PDF Report"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                        <Button x:Name="NavSettings" Style="{StaticResource SidebarMenuItemStyle}" Click="SwitchToSettings_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⚙️" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Settings"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                </StackPanel>

                                <StackPanel Grid.Row="2">

                                        <!-- New Habit button removed from sidebar; adding now only in Habits Manager -->

                                        <StackPanel Orientation="Horizontal" Margin="15,10,0,10"
                                                VerticalAlignment="Center" Cursor="Hand">
                                                <Border Width="24" Height="24" CornerRadius="12"
                                                        Margin="0,0,15,0">
                                                        <Border.Background>
                                                                <ImageBrush
                                                                        ImageSource="{Binding AvatarPath}"
                                                                        Stretch="UniformToFill" />
                                                        </Border.Background>
                                                </Border>
                                                <TextBlock Text="{Binding Nickname}" FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        VerticalAlignment="Center" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="15,10,0,10"
                                                VerticalAlignment="Center" Cursor="Hand">
                                                <TextBlock x:Name="DashboardThemeIcon" Text="☀️"
                                                        FontSize="16"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Margin="0,0,15,0" />
                                                <TextBlock x:Name="DashboardThemeLabel"
                                                        Text="Light Mode" FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        VerticalAlignment="Center" />

                                                <ToggleButton x:Name="DashboardThemeToggle"
                                                        Style="{StaticResource ToggleSwitchStyle}"
                                                        Click="ThemeToggle_Click" Margin="25,0,0,0" />
                                        </StackPanel>

                                        <Button Style="{StaticResource SidebarMenuItemStyle}"
                                                Click="LogoutButton_Click" Padding="15,10"
                                                Margin="0">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🚪" FontSize="16"
                                                                Margin="0,0,15,0"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Text="Logout" FontSize="13"
                                                                VerticalAlignment="Center" />
                                                </StackPanel>
                                        </Button>
                                </StackPanel>
                        </Grid>
                </Border>
                <Grid Grid.Column="1" x:Name="MainContentArea" Margin="40,20,20,20">
                        <Grid Visibility="{Binding IsHabitsVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Habits Manager" FontSize="28" FontWeight="Bold"
                                        Foreground="{DynamicResource TextMainBrush}" />
                                <TextBlock Text="What are you planning to achieve?"
                                        FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
                                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,10,0,0"
                                        Foreground="#FF328A5D"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}"
                                CornerRadius="15" Margin="0,0,0,25" Padding="20"
                                Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                        <TextBlock Text="Add New Habit" FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource TextMainBrush}"
                                                Margin="0,0,0,15" />

                                        <!-- Mode selection: Built-in list vs Custom -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button Content="From List" Width="110" Margin="0,0,10,0" Click="ChooseBuiltIn_Click" />
                                                <Button Content="Custom" Width="110" Click="ChooseCustom_Click" />
                                        </StackPanel>

                                        <!-- Built-in mode -->
                                        <StackPanel Visibility="{Binding IsBuiltInMode, Converter={StaticResource BoolToVis}}">
                                                        <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <Grid>
                                                                        <ComboBox x:Name="BuiltInCombo" ItemsSource="{Binding BuiltInHabits}"
                                                                                  SelectedItem="{Binding SelectedBuiltInHabit}"
                                                                                  Margin="0,0,10,0" Height="50" Padding="10,8" VerticalContentAlignment="Center" FontSize="14" />

                                                                        <TextBlock Text="Choose a habit from the list"
                                                                                   IsHitTestVisible="False"
                                                                                   Margin="14,0,10,0"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   FontSize="14">
                                                                                <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                                <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding SelectedItem, ElementName=BuiltInCombo}" Value="{x:Null}">
                                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                        </Style>
                                                                                </TextBlock.Style>
                                                                        </TextBlock>
                                                                </Grid>

                                                                <Button Grid.Column="1" Content="Add Selected"
                                                                        Click="AddBuiltIn_Click"
                                                                        Background="#FF328A5D" Foreground="White"
                                                                        FontWeight="Bold" Padding="18,0" Height="50"
                                                                        BorderThickness="0" Cursor="Hand" />
                                                        </Grid>
                                        </StackPanel>

                                        <!-- Custom mode -->
                                        <StackPanel Visibility="{Binding IsCustomMode, Converter={StaticResource BoolToVis}}">
                                                <Grid>
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox
                                                                Text="{Binding NewHabitName, UpdateSourceTrigger=PropertyChanged}"
                                                                Margin="0,0,10,0"
                                                                VerticalContentAlignment="Center"
                                                                Height="50" Padding="10,8"
                                                                FontSize="14"
                                                                Tag="Habit name (e.g. Morning Run)..." />

                                                        <ComboBox Grid.Column="1"
                                                                ItemsSource="{Binding Categories}"
                                                                SelectedItem="{Binding SelectedCategory}"
                                                                DisplayMemberPath="Name" Width="140"
                                                                Margin="0,0,10,0" Height="50" Padding="10,8"
                                                                VerticalContentAlignment="Center" FontSize="14" />

                                                        <ComboBox Grid.Column="2"
                                                                ItemsSource="{Binding HabitTypes}"
                                                                SelectedItem="{Binding SelectedType}"
                                                                DisplayMemberPath="Type" Width="120"
                                                                Margin="0,0,10,0" Height="50" Padding="10,8"
                                                                VerticalContentAlignment="Center" FontSize="14" />

                                                        <Button Grid.Column="3" Content="Save Habit"
                                                                Click="SaveHabit_Click"
                                                                Background="#FF328A5D" Foreground="White"
                                                                FontWeight="Bold" Padding="20,0" Height="50"
                                                                BorderThickness="0" Cursor="Hand" />
                                                </Grid>
                                        </StackPanel>
                                </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                Padding="0,0,10,0">
                                <ItemsControl ItemsSource="{Binding Habits}">
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                        <Border
                                                                Background="{DynamicResource CardBgBrush}"
                                                                CornerRadius="15" Margin="0,0,0,15"
                                                                Padding="20">
                                                                <Border.Effect>
                                                                        <DropShadowEffect
                                                                                BlurRadius="10"
                                                                                Opacity="0.05"
                                                                                ShadowDepth="2" />
                                                                </Border.Effect>
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition
                                                                                        Width="*" />
                                                                                <ColumnDefinition
                                                                                        Width="Auto" />
                                                                                <ColumnDefinition
                                                                                        Width="Auto" />
                                                                                <ColumnDefinition
                                                                                        Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <StackPanel Grid.Column="0"
                                                                                Margin="0,0,15,0"
                                                                                VerticalAlignment="Bottom">
                                                                                <TextBlock
                                                                                        Text="Habit Name"
                                                                                        FontSize="12"
                                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                                        Margin="0,0,0,5"
                                                                                        FontWeight="SemiBold" />
                                                                                <TextBox
                                                                                        Text="{Binding NewHabitName, UpdateSourceTrigger=PropertyChanged}"
                                                                                        Padding="10,8"
                                                                                        Height="50"
                                                                                        VerticalAlignment="Center"
                                                                                        Tag="e.g. Morning Run..." />
                                                                        </StackPanel>

                                                                        <StackPanel Grid.Column="1"
                                                                                Margin="0,0,15,0"
                                                                                VerticalAlignment="Bottom">
                                                                                <TextBlock
                                                                                        Text="Category"
                                                                                        FontSize="12"
                                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                                        Margin="0,0,0,5"
                                                                                        FontWeight="SemiBold" />
                                                                                <ComboBox
                                                                                        ItemsSource="{Binding Categories}"
                                                                                        SelectedItem="{Binding SelectedCategory}"
                                                                                        DisplayMemberPath="Name"
                                                                                        Width="140"
                                                                                        Padding="10,8" />
                                                                        </StackPanel>

                                                                        <StackPanel Grid.Column="2"
                                                                                Margin="0,0,15,0"
                                                                                VerticalAlignment="Bottom">
                                                                                <TextBlock
                                                                                        Text="Type"
                                                                                        FontSize="12"
                                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                                        Margin="0,0,0,5"
                                                                                        FontWeight="SemiBold" />
                                                                                <ComboBox
                                                                                        ItemsSource="{Binding HabitTypes}"
                                                                                        SelectedItem="{Binding SelectedType}"
                                                                                        DisplayMemberPath="Type"
                                                                                        Width="120"
                                                                                        Padding="10,8" />
                                                                        </StackPanel>

                                                                        <Button Grid.Column="3"
                                                                                Content="Save Habit"
                                                                                Click="SaveHabit_Click"
                                                                                Background="#FF328A5D"
                                                                                Foreground="White"
                                                                                FontWeight="Bold"
                                                                                Padding="20,0"
                                                                                Height="36"
                                                                                BorderThickness="0"
                                                                                Cursor="Hand"
                                                                                VerticalAlignment="Bottom" />
                                                                </Grid>
                                                        </Border>
                                                </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                </ItemsControl>
                        </ScrollViewer>
                        </Grid>

                        <!-- Dashboard personal habits visualization -->
                        <Grid Visibility="{Binding IsDashboardContent, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="2*" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding TodayDate}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>

                                <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}"
                                        CornerRadius="12" Padding="16" Margin="0,8,0,0">
                                        <StackPanel>
                                                <TextBlock Text="My Habits" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,8" />
                                                <TextBlock Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap">
                                                        Personal habits will appear here.
                                                        <LineBreak/>
                                                        Select from the built-in list or create your own in the Habits Manager.
                                                </TextBlock>

                                                <ItemsControl ItemsSource="{Binding Habits}" Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,6" VerticalAlignment="Center">
                                                                                <CheckBox Width="20" Height="20" Margin="0,0,10,0" />
                                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                                                <TextBox Width="100" Margin="10,0,0,0" />
                                                                        </StackPanel>
                                                                </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                        </StackPanel>
                                </Border>

                                <!-- Notes area: 1/3 height under habits -->
                                <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                                <TextBlock Text="My Notes" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,8" />
                                                <TextBox AcceptsReturn="True" TextWrapping="Wrap" Height="120" VerticalScrollBarVisibility="Auto" />
                                        </StackPanel>
                                </Border>
                        </Grid>

                        <views:MeasurementsView Visibility="{Binding IsMeasurementsVisible, Converter={StaticResource BoolToVis}}" />

                        <!-- Calendar Section -->
                        <Grid Visibility="{Binding IsCalendarVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                        <TextBlock Text="Calendar" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                        <TextBlock Text="Track your habits over time" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="20">
                                                Calendar content will be added here.
                                        </TextBlock>
                                </ScrollViewer>
                        </Grid>

                        <!-- Statistics Section -->
                        <Grid Visibility="{Binding IsStatisticsVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                        <TextBlock Text="Statistics" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                        <TextBlock Text="View your progress and achievements" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="20">
                                                Statistics content will be added here.
                                        </TextBlock>
                                </ScrollViewer>
                        </Grid>

                        <!-- PDF Report Section -->
                        <Grid Visibility="{Binding IsPdfReportVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                        <TextBlock Text="PDF Report" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                        <TextBlock Text="Generate and download your reports" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="20">
                                                PDF Report content will be added here.
                                        </TextBlock>
                                </ScrollViewer>
                        </Grid>

                        <!-- Settings Section -->
                        <Grid Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,20" />

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                        <StackPanel Orientation="Vertical">
                                                <!-- Profile Section -->
                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                                        <StackPanel>
                                                                <TextBlock Text="User Profile" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,16" />
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Avatar -->
                                                                        <Border Width="100" Height="100" CornerRadius="50" Background="{DynamicResource InputBgBrush}" VerticalAlignment="Top" Margin="0,0,20,0">
                                                                                <TextBlock Text="A" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="36" Foreground="{DynamicResource TextMutedBrush}" FontWeight="Bold" />
                                                                        </Border>

                                                                        <!-- Profile Info -->
                                                                        <StackPanel Grid.Column="1">
                                                                                <TextBox Tag="Full Name" Text="John Doe" Height="45" Padding="10,8" FontSize="14" Margin="0,0,0,12" />
                                                                                <TextBlock Text="Email Address" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,4" />
                                                                                <TextBlock Text="john.doe@example.com" Foreground="{DynamicResource TextMainBrush}" FontSize="14" Margin="0,0,0,12" />

                                                                                <StackPanel Orientation="Horizontal">
                                                                                        <Button Content="Change Password" Width="120" Padding="10,8" Margin="0,0,10,0" Style="{StaticResource AccentLinkButtonStyle}" />
                                                                                        <Button Content="Change Avatar" Width="120" Padding="10,8" Style="{StaticResource AccentLinkButtonStyle}" />
                                                                                </StackPanel>
                                                                        </StackPanel>
                                                                </Grid>
                                                        </StackPanel>
                                                </Border>

                                                <!-- General Settings -->
                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                                        <StackPanel>
                                                                <TextBlock Text="General" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,16" />

                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                                                                        <TextBlock Text="Language" Width="180" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                                                        <ComboBox Width="240">
                                                                                <ComboBoxItem IsSelected="True">Polski</ComboBoxItem>
                                                                                <ComboBoxItem>English</ComboBoxItem>
                                                                                <ComboBoxItem>Deutsch</ComboBoxItem>
                                                                        </ComboBox>
                                                                </StackPanel>

                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                                                                        <TextBlock Text="Week Start" Width="180" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                                                        <ComboBox Width="240">
                                                                                <ComboBoxItem>Poniedziałek</ComboBoxItem>
                                                                                <ComboBoxItem IsSelected="True">Niedziela</ComboBoxItem>
                                                                        </ComboBox>
                                                                </StackPanel>

                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="Units" Width="180" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                                                        <ComboBox Width="240">
                                                                                <ComboBoxItem IsSelected="True">kg / ml</ComboBoxItem>
                                                                                <ComboBoxItem>lb / oz</ComboBoxItem>
                                                                        </ComboBox>
                                                                </StackPanel>
                                                        </StackPanel>
                                                </Border>

                                                <!-- Notifications -->
                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                                        <StackPanel>
                                                                <TextBlock Text="Notifications" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,16" />

                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                                                                        <TextBlock Text="Daily Reminder" Width="180" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                                                        <ToggleButton Style="{StaticResource ToggleSwitchStyle}" Width="44" Height="24" IsChecked="True" />
                                                                </StackPanel>

                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                                                                        <TextBlock Text="Reminder Time" Width="180" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                                                        <ComboBox Width="240">
                                                                                <ComboBoxItem>08:00</ComboBoxItem>
                                                                                <ComboBoxItem>12:00</ComboBoxItem>
                                                                                <ComboBoxItem IsSelected="True">20:00</ComboBoxItem>
                                                                        </ComboBox>
                                                                </StackPanel>

                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="Sounds / Vibrations" Width="180" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                                                        <StackPanel Orientation="Horizontal">
                                                                                <ToggleButton Style="{StaticResource ToggleSwitchStyle}" Width="44" Height="24" IsChecked="True" Margin="0,0,8,0" />
                                                                                <ToggleButton Style="{StaticResource ToggleSwitchStyle}" Width="44" Height="24" IsChecked="False" />
                                                                        </StackPanel>
                                                                </StackPanel>
                                                        </StackPanel>
                                                </Border>

                                                <!-- About -->
                                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20">
                                                        <StackPanel>
