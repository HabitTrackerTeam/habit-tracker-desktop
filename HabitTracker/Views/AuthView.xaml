<UserControl x:Class="HabitTracker.Views.AuthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker">
                <Grid Visibility="{Binding IsAuthVisible, Converter={StaticResource BoolToVis}}"
                      Margin="22,16,22,16">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4.5*"/>
                                <ColumnDefinition Width="5.5*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Margin="34,18,40,18"
                                    MaxWidth="560">
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,28">
                                        <Border Width="46"
                                                Height="46"
                                                CornerRadius="12"
                                                Background="#FF1F7D33">
                                                <Image Source="/Assets/logo.png"
                                                       Width="28"
                                                       Height="28"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <TextBlock Text="Habit Tracker"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#FF1F7D33"
                                                   Margin="14,0,0,0"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           LineHeight="42"
                                           Margin="0,0,0,16"
                                           TextWrapping="Wrap">
                                        Plant habits. 
                                        <Run Text="Harvest success."
                                             Foreground="#FF1F7D33"/>
                                </TextBlock>

                                <TextBlock Text="Your dedicated tracker for productivity and health. Stay consistent, analyze your performance, and turn small steps into lasting lifestyle changes in just a few clicks a day."
                                           FontSize="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,20"
                                           TextWrapping="Wrap"
                                           LineHeight="24"/>

                                <Border Height="300"
                                        CornerRadius="28"
                                        BorderBrush="#22328A5D"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                        <Border.Background>
                                                <ImageBrush ImageSource="/Assets/logo.png"
                                                            Stretch="Uniform"
                                                            AlignmentX="Center"
                                                            AlignmentY="Center"
                                                            Opacity="0.78"/>
                                        </Border.Background>
                                        <Border.Effect>
                                                <DropShadowEffect BlurRadius="25"
                                                                  ShadowDepth="2"
                                                                  Opacity="0.06"
                                                                  Color="#FF1B2A2F"/>
                                        </Border.Effect>
                                </Border>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Margin="44,18,10,18"
                                CornerRadius="20"
                                Background="{DynamicResource CardBgBrush}">
                                <Border.Effect>
                                        <DropShadowEffect BlurRadius="12"
                                                          Opacity="0.04"
                                                          ShadowDepth="2"
                                                          Color="Black"/>
                                </Border.Effect>
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ScrollViewer Grid.Row="0"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Padding="40,34,40,14">
                                                <StackPanel>
                                                        <StackPanel Margin="0,0,0,18">
                                                                <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                                <Setter Property="Visibility"
                                                                                        Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsRegisterVisible}"
                                                                                                     Value="True">
                                                                                                <Setter Property="Visibility"
                                                                                                        Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                </Style.Triggers>
                                                                        </Style>
                                                                </StackPanel.Style>
                                                                <TextBlock Text="Welcome back"
                                                                           FontSize="28"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextMainBrush}"/>
                                                                <TextBlock Text="Select an account or sign in manually."
                                                                           FontSize="14"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Margin="0,8,0,0"/>
                                                        </StackPanel>

                                                        <StackPanel Margin="0,0,0,20">
                                                                <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                                <Setter Property="Visibility"
                                                                                        Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                        <MultiDataTrigger>
                                                                                                <MultiDataTrigger.Conditions>
                                                                                                        <Condition Binding="{Binding IsLoginVisible}"
                                                                                                                   Value="True"/>
                                                                                                        <Condition Binding="{Binding HasSavedAccounts}"
                                                                                                                   Value="True"/>
                                                                                                </MultiDataTrigger.Conditions>
                                                                                                <Setter Property="Visibility"
                                                                                                        Value="Visible"/>
                                                                                        </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                        </Style>
                                                                </StackPanel.Style>
                                                                <TextBlock Text="RECENTLY ACTIVE"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Margin="0,0,0,10"/>
                                                                <ItemsControl ItemsSource="{Binding SavedAccounts}">
                                                                        <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                        <WrapPanel Orientation="Horizontal"/>
                                                                                </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                        <Button Style="{StaticResource SavedAccountCardStyle}"
                                                                                                Click="SavedAccount_Click">
                                                                                                <StackPanel>
                                                                                                        <Border Width="66"
                                                                                                                Height="66"
                                                                                                                CornerRadius="33"
                                                                                                                Background="{DynamicResource InputBgBrush}"
                                                                                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                                                                                BorderThickness="1.5"
                                                                                                                Margin="0,0,0,6">
                                                                                                                <Grid>
                                                                                                                        <Image Source="/Assets/logo.png"
                                                                                                                               Margin="14"
                                                                                                                               Opacity="0.08"/>
                                                                                                                        <Border Width="60"
                                                                                                                                Height="60"
                                                                                                                                CornerRadius="30">
                                                                                                                                <Border.Background>
                                                                                                                                        <ImageBrush ImageSource="{Binding AvatarUrl}"
                                                                                                                                                    Stretch="UniformToFill"/>
                                                                                                                                </Border.Background>
                                                                                                                        </Border>
                                                                                                                </Grid>
                                                                                                        </Border>
                                                                                                        <TextBlock Text="{Binding Nickname}"
                                                                                                                   Foreground="{DynamicResource TextMainBrush}"
                                                                                                                   FontWeight="SemiBold"
                                                                                                                   FontSize="12"
                                                                                                                   TextAlignment="Center"/>
                                                                                                </StackPanel>
                                                                                        </Button>
                                                                                </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                        </StackPanel>

                                                        <StackPanel x:Name="LoginFormPanel"
                                                                    Margin="0,0,0,8"
                                                                    Visibility="{Binding IsLoginVisible, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="EMAIL ADDRESS"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Margin="0,0,0,8"/>
                                                                <TextBox x:Name="EmailInput"
                                                                         Height="56"
                                                                         Margin="0,0,0,14"
                                                                         Tag="E-mail"
                                                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                                                                <TextBlock Text="PASSWORD"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Margin="0,0,0,8"/>
                                                                <Grid Margin="0,0,0,14">
                                                                        <TextBox x:Name="LoginPasswordVisible"
                                                                                 Height="56"
                                                                                 Tag="Password"
                                                                                 Padding="0,0,44,0"
                                                                                 Visibility="Collapsed"/>

                                                                        <PasswordBox x:Name="LoginPassword"
                                                                                     Height="56"
                                                                                     Tag="Password"
                                                                                     Padding="0,0,44,0"/>

                                                                        <Button Width="34"
                                                                                Height="34"
                                                                                HorizontalAlignment="Right"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,8,0"
                                                                                Cursor="Hand"
                                                                                Background="Transparent"
                                                                                BorderThickness="0"
                                                                                Foreground="{DynamicResource TextMutedBrush}"
                                                                                Click="ToggleLoginPassword_Click">

                                                                                <TextBlock x:Name="LoginEyeIcon"
                                                                                           Text="👁"
                                                                                           FontSize="15"
                                                                                           VerticalAlignment="Center"
                                                                                           HorizontalAlignment="Center"/>
                                                                        </Button>
                                                                </Grid>

                                                                <Grid Margin="0,2,0,20">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    VerticalAlignment="Center">
                                                                                <TextBlock Text="Don't have an account?"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource TextMainBrush}"
                                                                                           FontSize="16"/>
                                                                                <Button Content="Register"
                                                                                        Click="NavToRegister_Click"
                                                                                        Cursor="Hand"
                                                                                        FontSize="16"
                                                                                        FontWeight="SemiBold"
                                                                                        Margin="6,0,0,0"
                                                                                        VerticalAlignment="Center"
                                                                                        Style="{StaticResource AccentLinkButtonStyle}"/>
                                                                        </StackPanel>
                                                                        <Button Grid.Column="1"
                                                                                HorizontalAlignment="Right"
                                                                                Content="Forgot password?"
                                                                                Click="NavToForgot_Click"
                                                                                FontSize="14"
                                                                                Style="{StaticResource AccentLinkButtonStyle}"/>
                                                                </Grid>

                                                                <Button Height="56"
                                                                        Margin="0,0,0,24"
                                                                        HorizontalAlignment="Stretch"
                                                                        Background="#FF1F7D33"
                                                                        Click="LoginButton_Click"
                                                                        Style="{StaticResource LoginLoadingButtonStyle}"
                                                                        Content="Sign In"
                                                                        Foreground="White"
                                                                        FontWeight="SemiBold"/>

                                                                <TextBlock x:Name="StatusMessage"
                                                                           Margin="0,0,0,14"
                                                                           HorizontalAlignment="Center"
                                                                           FontWeight="Medium"
                                                                           Foreground="{Binding StatusColor}"
                                                                           Text="{Binding StatusMessage}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel x:Name="RegisterFormPanel"
                                                                    Margin="0,0,0,8"
                                                                    Visibility="{Binding IsRegisterVisible, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Margin="0,0,0,5"
                                                                           FontSize="32"
                                                                           FontWeight="Bold"
                                                                           Foreground="#FF328A5D"
                                                                           Text="Create profile"/>
                                                                <TextBlock Margin="0,0,0,20"
                                                                           FontSize="15"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           Text="Set up your account in a few quick steps."/>

                                                                <Grid HorizontalAlignment="Center"
                                                                      Margin="0,0,0,25">
                                                                        <Border x:Name="AvatarBorder"
                                                                                Width="90"
                                                                                Height="90"
                                                                                CornerRadius="45"
                                                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                                                BorderThickness="2"
                                                                                Background="{DynamicResource InputBgBrush}">
                                                                                <Grid>
                                                                                        <Image Source="/Assets/logo.png"
                                                                                               Margin="20"
                                                                                               Opacity="0.3"/>
                                                                                        <Border Width="90"
                                                                                                Height="90"
                                                                                                CornerRadius="45">
                                                                                                <Border.Background>
                                                                                                        <ImageBrush x:Name="AvatarImageBrush"
                                                                                                                    Stretch="UniformToFill"/>
                                                                                                </Border.Background>
                                                                                        </Border>
                                                                                        <Button VerticalAlignment="Bottom"
                                                                                                HorizontalAlignment="Right"
                                                                                                Width="28"
                                                                                                Height="28"
                                                                                                Background="#FF328A5D"
                                                                                                Padding="0"
                                                                                                Click="ChooseAvatar_Click"
                                                                                                Cursor="Hand">
                                                                                                <Button.Template>
                                                                                                        <ControlTemplate TargetType="Button">
                                                                                                                <Border CornerRadius="14"
                                                                                                                        Background="{TemplateBinding Background}">
                                                                                                                        <TextBlock Text="📷"
                                                                                                                                   Foreground="White"
                                                                                                                                   FontWeight="Bold"
                                                                                                                                   FontSize="16"
                                                                                                                                   HorizontalAlignment="Center"
                                                                                                                                   VerticalAlignment="Center"
                                                                                                                                   Margin="0,-2,0,0"/>
                                                                                                                </Border>
                                                                                                        </ControlTemplate>
                                                                                                </Button.Template>
                                                                                        </Button>
                                                                                </Grid>
                                                                        </Border>
                                                                </Grid>

                                                                <TextBox Height="50"
                                                                         Margin="0,0,0,15"
                                                                         Tag="Nickname"
                                                                         Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <TextBox Height="50"
                                                                         Margin="0,0,0,15"
                                                                         Tag="E-mail"
                                                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <Grid Margin="0,0,0,6">
                                                                    <TextBox x:Name="RegisterPasswordVisible"
                                                                             Height="50"
                                                                             Tag="Password"
                                                                             Padding="0,0,44,0"
                                                                             Visibility="Collapsed"
                                                                             TextChanged="RegisterPasswordVisible_TextChanged"/>
                                                                    <PasswordBox x:Name="RegisterPassword"
                                                                                 Height="50"
                                                                                 Tag="Password"
                                                                                 Padding="0,0,44,0"
                                                                                 PasswordChanged="PasswordField_PasswordChanged"/>
                                                                    <Button Width="34"
                                                                            Height="34"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            Margin="0,0,8,0"
                                                                            Cursor="Hand"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Foreground="{DynamicResource TextMutedBrush}"
                                                                            Click="ToggleRegisterPassword_Click">
                                                                        <TextBlock Text="👁"
                                                                                   FontSize="15"
                                                                                   VerticalAlignment="Center"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </Button>
                                                                </Grid>
                                                                <StackPanel x:Name="RegisterPasswordChecklist"
                                                                            Margin="4,0,0,10"
                                                                            Visibility="{Binding IsPasswordChecklistVisible, Converter={StaticResource BoolToVis}}">
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                        <TextBlock Width="16" FontSize="12">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="✗"/>
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasMinLength}" Value="True">
                                                                                            <Setter Property="Text" Value="✓"/>
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasMinLength}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                            At least 6 characters
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                        <TextBlock Width="16" FontSize="12">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="✗"/>
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasUppercase}" Value="True">
                                                                                            <Setter Property="Text" Value="✓"/>
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasUppercase}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                            At least 1 uppercase letter
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                        <TextBlock Width="16" FontSize="12">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="✗"/>
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasLowercase}" Value="True">
                                                                                            <Setter Property="Text" Value="✓"/>
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasLowercase}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                            At least 1 lowercase letter
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                        <TextBlock Width="16" FontSize="12">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="✗"/>
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasDigit}" Value="True">
                                                                                            <Setter Property="Text" Value="✓"/>
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasDigit}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                            At least 1 digit
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                        <TextBlock Width="16" FontSize="12">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="✗"/>
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasSpecialChar}" Value="True">
                                                                                            <Setter Property="Text" Value="✓"/>
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasSpecialChar}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                            At least 1 special character
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <Grid Margin="0,0,0,25">
                                                                    <TextBox x:Name="RegisterRepeatPasswordVisible"
                                                                             Height="50"
                                                                             Tag="Repeat Password"
                                                                             Padding="0,0,44,0"
                                                                             Visibility="Collapsed"/>
                                                                    <PasswordBox x:Name="RegisterRepeatPassword"
                                                                                 Height="50"
                                                                                 Tag="Repeat Password"
                                                                                 Padding="0,0,44,0"/>
                                                                    <Button Width="34"
                                                                            Height="34"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            Margin="0,0,8,0"
                                                                            Cursor="Hand"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Foreground="{DynamicResource TextMutedBrush}"
                                                                            Click="ToggleRegisterRepeatPassword_Click">
                                                                        <TextBlock Text="👁"
                                                                                   FontSize="15"
                                                                                   VerticalAlignment="Center"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </Button>
                                                                </Grid>

                                                                <Button Height="48"
                                                                        Margin="0,0,0,15"
                                                                        Background="#FF328A5D"
                                                                        Click="RegisterButton_Click"
                                                                        Content="Sign up"
                                                                        Foreground="White"
                                                                        FontWeight="SemiBold"/>
                                                                <TextBlock Margin="0,0,0,14"
                                                                           HorizontalAlignment="Center"
                                                                           FontWeight="Medium"
                                                                           Foreground="{Binding StatusColor}"
                                                                           Text="{Binding StatusMessage}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"/>
                                                                <Button HorizontalAlignment="Center"
                                                                        Background="Transparent"
                                                                        Click="NavToLogin_Click"
                                                                        Content="Back to Login"
                                                                        Cursor="Hand"
                                                                        FontSize="13"
                                                                        Style="{StaticResource AccentLinkButtonStyle}"/>
                                                        </StackPanel>

                                                        <StackPanel x:Name="ForgotFormPanel"
                                                                    Margin="0,0,0,8"
                                                                    Visibility="{Binding IsForgotVisible, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Margin="0,0,0,10"
                                                                           FontSize="32"
                                                                           FontWeight="Bold"
                                                                           Foreground="#FF328A5D"
                                                                           Text="Reset Password"/>

                                                                <StackPanel Visibility="{Binding IsForgotEmailStep, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Margin="0,0,0,30"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   Text="Enter your email to receive a reset code"
                                                                                   TextWrapping="Wrap"/>
                                                                        <TextBox Height="50"
                                                                                 Margin="0,0,0,25"
                                                                                 Tag="E-mail"
                                                                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                                                                        <Button Height="48"
                                                                                Margin="0,0,0,15"
                                                                                Background="#FF328A5D"
                                                                                Click="SendResetLink_Click"
                                                                                Content="Send reset code"
                                                                                Foreground="White"
                                                                                FontWeight="SemiBold"/>
                                                                </StackPanel>

                                                                <StackPanel Visibility="{Binding IsForgotCodeStep, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Margin="0,0,0,20"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   Text="Enter the verification code from your email"
                                                                                   TextWrapping="Wrap"/>
                                                                        <TextBox Height="50"
                                                                                 Margin="0,0,0,25"
                                                                                 Tag="Recovery Code"
                                                                                 Text="{Binding ResetToken, UpdateSourceTrigger=PropertyChanged}"/>
                                                                        <Button Height="48"
                                                                                Margin="0,0,0,15"
                                                                                Background="#FF328A5D"
                                                                                Click="VerifyOnlyCode_Click"
                                                                                Content="Verify code"
                                                                                Foreground="White"
                                                                                FontWeight="SemiBold"/>
                                                                </StackPanel>

                                                                <StackPanel Visibility="{Binding IsForgotNewPasswordStep, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Margin="0,0,0,20"
                                                                                   FontSize="14"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   Text="Create your new password"
                                                                                   TextWrapping="Wrap"/>
                                                                        <Grid Margin="0,0,0,6">
                                                                            <TextBox x:Name="ForgotNewPasswordVisible"
                                                                                     Height="50"
                                                                                     Tag="New Password"
                                                                                     Padding="0,0,44,0"
                                                                                     Visibility="Collapsed"
                                                                                     TextChanged="ForgotNewPasswordVisible_TextChanged"/>
                                                                            <PasswordBox x:Name="ForgotNewPassword"
                                                                                         Height="50"
                                                                                         Tag="New Password"
                                                                                         Padding="0,0,44,0"
                                                                                         PasswordChanged="PasswordField_PasswordChanged"/>
                                                                            <Button Width="34"
                                                                                    Height="34"
                                                                                    HorizontalAlignment="Right"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="0,0,8,0"
                                                                                    Cursor="Hand"
                                                                                    Background="Transparent"
                                                                                    BorderThickness="0"
                                                                                    Foreground="{DynamicResource TextMutedBrush}"
                                                                                    Click="ToggleForgotNewPassword_Click">
                                                                                <TextBlock Text="👁"
                                                                                           FontSize="15"
                                                                                           VerticalAlignment="Center"
                                                                                           HorizontalAlignment="Center"/>
                                                                            </Button>
                                                                        </Grid>
                                                                        <StackPanel x:Name="ForgotPasswordChecklist"
                                                                                    Margin="4,0,0,10"
                                                                                    Visibility="{Binding IsPasswordChecklistVisible, Converter={StaticResource BoolToVis}}">
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                <TextBlock Width="16" FontSize="12">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Text" Value="✗"/>
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasMinLength}" Value="True">
                                                                                                    <Setter Property="Text" Value="✓"/>
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasMinLength}" Value="True">
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                    At least 6 characters
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                <TextBlock Width="16" FontSize="12">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Text" Value="✗"/>
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasUppercase}" Value="True">
                                                                                                    <Setter Property="Text" Value="✓"/>
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasUppercase}" Value="True">
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                    At least 1 uppercase letter
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                <TextBlock Width="16" FontSize="12">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Text" Value="✗"/>
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasLowercase}" Value="True">
                                                                                                    <Setter Property="Text" Value="✓"/>
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasLowercase}" Value="True">
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                    At least 1 lowercase letter
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                <TextBlock Width="16" FontSize="12">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Text" Value="✗"/>
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasDigit}" Value="True">
                                                                                                    <Setter Property="Text" Value="✓"/>
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasDigit}" Value="True">
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                    At least 1 digit
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                <TextBlock Width="16" FontSize="12">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Text" Value="✗"/>
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasSpecialChar}" Value="True">
                                                                                                    <Setter Property="Text" Value="✓"/>
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasSpecialChar}" Value="True">
                                                                                                    <Setter Property="Foreground" Value="#FF328A5D"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                    At least 1 special character
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                        <Grid Margin="0,0,0,25">
                                                                            <TextBox x:Name="ForgotRepeatPasswordVisible"
                                                                                     Height="50"
                                                                                     Tag="Repeat Password"
                                                                                     Padding="0,0,44,0"
                                                                                     Visibility="Collapsed"/>
                                                                            <PasswordBox x:Name="ForgotRepeatPassword"
                                                                                         Height="50"
                                                                                         Tag="Repeat Password"
                                                                                         Padding="0,0,44,0"/>
                                                                            <Button Width="34"
                                                                                    Height="34"
                                                                                    HorizontalAlignment="Right"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="0,0,8,0"
                                                                                    Cursor="Hand"
                                                                                    Background="Transparent"
                                                                                    BorderThickness="0"
                                                                                    Foreground="{DynamicResource TextMutedBrush}"
                                                                                    Click="ToggleForgotRepeatPassword_Click">
                                                                                <TextBlock Text="👁"
                                                                                           FontSize="15"
                                                                                           VerticalAlignment="Center"
                                                                                           HorizontalAlignment="Center"/>
                                                                            </Button>
                                                                        </Grid>
                                                                        <Button Height="48"
                                                                                Margin="0,0,0,15"
                                                                                Background="#FF328A5D"
                                                                                Click="SaveNewPassword_Click"
                                                                                Content="Save new password"
                                                                                Foreground="White"
                                                                                FontWeight="SemiBold"/>
                                                                </StackPanel>

                                                                <Button HorizontalAlignment="Center"
                                                                        Background="Transparent"
                                                                        Click="NavToLogin_Click"
                                                                        Content="Back to Login"
                                                                        Cursor="Hand"
                                                                        FontSize="13"
                                                                        Style="{StaticResource AccentLinkButtonStyle}"/>
                                                        </StackPanel>
                                                </StackPanel>
                                        </ScrollViewer>

                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Left"
                                                    Margin="40,8,0,16">
                                                <TextBlock x:Name="LoginThemeIcon"
                                                           Text="☀️"
                                                           FontSize="16"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock x:Name="LoginThemeLabel"
                                                           Text="Light Mode"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextMainBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>
                                                <ToggleButton x:Name="LoginThemeToggle"
                                                              Style="{StaticResource ToggleSwitchStyle}"
                                                              Click="ThemeToggle_Click"/>
                                        </StackPanel>
                                </Grid>
                        </Border>
                </Grid>
</UserControl>
