<Window x:Class="HabitTracker.Views.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification" Height="220" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" BorderBrush="{DynamicResource AccentGreenBrush}" BorderThickness="2" Margin="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="15" ShadowDepth="5" />
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock x:Name="TitleText" Text="Notification" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                <Button Content="✕" Click="Close_Click" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMutedBrush}" FontSize="16" FontWeight="Bold" Cursor="Hand" HorizontalAlignment="Right" />
            </Grid>

            <!-- Content -->
            <TextBlock x:Name="MessageText" Grid.Row="1" Text="Message" TextWrapping="Wrap" FontSize="14" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" />

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="OK" Click="Ok_Click" Background="{DynamicResource AccentGreenBrush}" Foreground="White" FontWeight="Bold" Padding="30,10" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
