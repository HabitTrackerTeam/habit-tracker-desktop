<Window x:Class="HabitTracker.Views.AddHabitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HabitTracker"
        Title="Add New Habit"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Width="520"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Background="#80000000">
        <Border Background="White" CornerRadius="16" Margin="20" MaxWidth="520">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="0">
                    <!-- Header -->
                    <Border Background="White" CornerRadius="16,16,0,0" Margin="0">
                        <StackPanel Margin="24,24,24,0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Add New Habit" FontSize="24" FontWeight="Bold" Foreground="#FF4E606C" />
                                    <TextBlock Text="Plant a new seed for your personal growth journey." FontSize="13" Foreground="#FF8B9AA2" Margin="0,6,0,0" />
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="CloseButton_Click" Margin="0,0,0,0">
                                    <TextBlock Text="✕" FontSize="18" Foreground="#FF8B9AA2" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Main Content -->
                    <StackPanel Margin="24,20,24,24">
                        <!-- Habit Name -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="HABIT NAME" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,8" />
                            <TextBox x:Name="HabitNameBox" Tag="e.g., Daily Meditation" Height="40" />
                        </StackPanel>

                        <!-- Habit Type -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="HABIT TYPE" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="TypeNumeric" Content="Numeric" GroupName="HabitType" IsChecked="True" Margin="0,0,20,0" VerticalAlignment="Center" />
                                <RadioButton x:Name="TypeCheckbox" Content="Checkbox" GroupName="HabitType" Margin="0,0,20,0" VerticalAlignment="Center" />
                                <RadioButton x:Name="TypeTimer" Content="Timer" GroupName="HabitType" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Priority -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="PRIORITY" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="PriorityLow" Content="Low" GroupName="Priority" Margin="0,0,30,0" VerticalAlignment="Center" />
                                <RadioButton x:Name="PriorityMedium" Content="Medium" GroupName="Priority" IsChecked="True" Margin="0,0,30,0" VerticalAlignment="Center" />
                                <RadioButton x:Name="PriorityHigh" Content="High" GroupName="Priority" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Category -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="CATEGORY" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CategoryCombo" ItemsSource="{Binding Categories}" DisplayMemberPath="Name" Height="40" />
                                <Button Grid.Column="1" Content="🔍" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>

                        <!-- Category Style -->
                        <StackPanel Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="CATEGORY STYLE" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" />
                                <Button Content="+ New Category" Background="Transparent" BorderThickness="0" Foreground="#FF328A5D" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" Margin="0" />
                            </StackPanel>
                            
                            <!-- Icons -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="ICON" FontSize="11" FontWeight="Bold" Foreground="#FF8B9AA2" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Button Content="✓" Width="36" Height="36" Background="#E6F8F0" BorderThickness="0" FontSize="14" Foreground="#FF328A5D" FontWeight="Bold" />
                                <Button Content="📋" Width="36" Height="36" Background="Transparent" BorderThickness="1" BorderBrush="#FFDDE2E5" FontSize="14" Margin="8,0,0,0" />
                                <Button Content="🎯" Width="36" Height="36" Background="Transparent" BorderThickness="1" BorderBrush="#FFDDE2E5" FontSize="14" Margin="8,0,0,0" />
                            </StackPanel>

                            <!-- Colors -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="COLOR" FontSize="11" FontWeight="Bold" Foreground="#FF8B9AA2" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Button Width="28" Height="28" Background="#3CAEA3" BorderThickness="0" Margin="0,0,8,0" />
                                <Button Width="28" Height="28" Background="#0066CC" BorderThickness="0" Margin="0,0,8,0" />
                                <Button Width="28" Height="28" Background="#FF6B6B" BorderThickness="0" Margin="0,0,8,0" />
                                <Button Width="28" Height="28" Background="#FFD93D" BorderThickness="0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Frequency -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="FREQUENCY" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="FreqDaily" Content="Daily" GroupName="Frequency" IsChecked="True" Margin="0,0,24,0" VerticalAlignment="Center" />
                                <RadioButton x:Name="FreqWeekly" Content="Weekly" GroupName="Frequency" Margin="0,0,24,0" VerticalAlignment="Center" />
                                <RadioButton x:Name="FreqMonthly" Content="Monthly" GroupName="Frequency" Margin="0,0,24,0" VerticalAlignment="Center" />
                                <RadioButton x:Name="FreqSpecific" Content="Specific" GroupName="Frequency" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Schedule (Days of Week) -->
                        <StackPanel x:Name="SchedulePanel" Visibility="Collapsed" Margin="0,0,0,20">
                            <TextBlock Text="SCHEDULE" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="DayMonday" Content="M" Width="40" Height="40" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" Margin="0,0,8,0" />
                                <TextBlock Text="T" VerticalAlignment="Center" Foreground="#FF8B9AA2" Margin="8,0,8,0" />
                                <ToggleButton x:Name="DayWednesday" Content="W" Width="40" Height="40" Background="#FF328A5D" Foreground="White" BorderThickness="0" Margin="0,0,8,0" />
                                <TextBlock Text="T" VerticalAlignment="Center" Foreground="#FF8B9AA2" Margin="8,0,8,0" />
                                <ToggleButton x:Name="DayFriday" Content="F" Width="40" Height="40" Background="#FF328A5D" Foreground="White" BorderThickness="0" Margin="0,0,8,0" />
                                <TextBlock Text="S" VerticalAlignment="Center" Foreground="#FF8B9AA2" Margin="8,0,8,0" />
                                <TextBlock Text="S" VerticalAlignment="Center" Foreground="#FF8B9AA2" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Goal / Target -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="GOAL / TARGET" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,8" />
                            <TextBox x:Name="GoalBox" Tag="20" Height="40" />
                        </StackPanel>

                        <!-- Units -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="UNITS" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,8" />
                            <ComboBox x:Name="UnitsCombo" Height="40">
                                <ComboBoxItem Content="mins" />
                                <ComboBoxItem Content="hours" />
                                <ComboBoxItem Content="pages" />
                                <ComboBoxItem Content="count" />
                                <ComboBoxItem Content="custom" />
                            </ComboBox>
                        </StackPanel>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Content="Cancel" Background="Transparent" BorderThickness="0" Foreground="#FF4E606C" FontSize="14" FontWeight="Bold" Click="CancelButton_Click" Cursor="Hand" Margin="0,0,12,0" />
                            <Button Content="🌱 Plant Habit" Background="#FF328A5D" BorderThickness="0" Foreground="White" FontSize="14" FontWeight="Bold" Click="PlantButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
