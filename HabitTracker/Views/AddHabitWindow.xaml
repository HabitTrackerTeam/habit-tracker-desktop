<Window x:Class="HabitTracker.Views.AddHabitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HabitTracker"
        Title="Add New Habit"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Width="650"
        Height="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#B0000000">
        <Border Background="White" CornerRadius="16" Margin="10">
            <StackPanel>
                <Border Background="White"
                        CornerRadius="16,16,0,0"
                        Padding="24,24,24,20"
                        BorderBrush="#FFF0F0F0"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Add New Habit"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#FF4E606C" />
                            <TextBlock Text="Plant a new seed for your personal growth journey."
                                       FontSize="13"
                                       Foreground="#FF8B9AA2"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="CloseButton_Click"
                                Cursor="Hand">
                            <TextBlock Text="✕" FontSize="18" Foreground="#FF8B9AA2" />
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Margin="24,16,24,20">
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="HABIT NAME" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <TextBox x:Name="HabitNameBox" Tag="e.g., Daily Meditation" Height="40" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="HABIT TYPE" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal" Height="44">
                            <Button x:Name="TypeNumericBtn" Content="Numeric" Background="#E6F8F0" BorderBrush="#FF328A5D" BorderThickness="2" Foreground="#FF328A5D" FontSize="13" FontWeight="Bold" Padding="16,0" Margin="0,0,12,0" Click="TypeButton_Click" Cursor="Hand" />
                            <Button x:Name="TypeCheckboxBtn" Content="Checkbox" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Padding="16,0" Margin="0,0,12,0" Click="TypeButton_Click" Cursor="Hand" />
                            <Button x:Name="TypeTimerBtn" Content="Timer" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Padding="16,0" Click="TypeButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="PRIORITY" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal" Height="44">
                            <Button x:Name="PriorityLowBtn" Content="Low" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Padding="20,0" Margin="0,0,12,0" Click="PriorityButton_Click" Cursor="Hand" />
                            <Button x:Name="PriorityMediumBtn" Content="Medium" Background="#E6F8F0" BorderBrush="#FF328A5D" BorderThickness="2" Foreground="#FF328A5D" FontSize="13" FontWeight="Bold" Padding="20,0" Margin="0,0,12,0" Click="PriorityButton_Click" Cursor="Hand" />
                            <Button x:Name="PriorityHighBtn" Content="High" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Padding="20,0" Click="PriorityButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="CATEGORY" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CategoryCombo" Grid.Column="0" ItemsSource="{Binding Categories}" DisplayMemberPath="Name" Height="40" />
                            <Button Grid.Column="1" Content="+" Background="Transparent" BorderThickness="0" Foreground="#FF328A5D" FontSize="18" FontWeight="Bold" Click="NewCategory_Click" VerticalAlignment="Center" Margin="8,0,0,0" Cursor="Hand" />
                        </Grid>
                    </StackPanel>



                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="FREQUENCY" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="FreqDaily" Content="Daily" GroupName="Frequency" IsChecked="True" Margin="0,0,24,0" VerticalAlignment="Center" />
                            <RadioButton x:Name="FreqWeekly" Content="Weekly" GroupName="Frequency" Margin="0,0,24,0" VerticalAlignment="Center" />
                            <RadioButton x:Name="FreqMonthly" Content="Monthly" GroupName="Frequency" Margin="0,0,24,0" VerticalAlignment="Center" />
                            <RadioButton x:Name="FreqSpecific" Content="Specific" GroupName="Frequency" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="SchedulePanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <TextBlock Text="SCHEDULE" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="DayMonday" Content="M" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                            <Button x:Name="DayTuesday" Content="T" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                            <Button x:Name="DayWednesday" Content="W" Width="44" Height="44" Background="#E6F8F0" BorderBrush="#FF328A5D" BorderThickness="2" FontSize="14" FontWeight="Bold" Foreground="#FF328A5D" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                            <Button x:Name="DayThursday" Content="T" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                            <Button x:Name="DayFriday" Content="F" Width="44" Height="44" Background="#E6F8F0" BorderBrush="#FF328A5D" BorderThickness="2" FontSize="14" FontWeight="Bold" Foreground="#FF328A5D" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                            <Button x:Name="DaySaturday" Content="S" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                            <Button x:Name="DaySunday" Content="S" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Click="DayButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="GOAL / TARGET" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <TextBox x:Name="GoalBox" Tag="20" Height="40" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="UNITS" FontSize="12" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <ComboBox x:Name="UnitsCombo" Height="40">
                            <ComboBoxItem Content="mins" />
                            <ComboBoxItem Content="hours" />
                            <ComboBoxItem Content="pages" />
                            <ComboBoxItem Content="count" />
                            <ComboBoxItem Content="custom" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Cancel" Background="Transparent" BorderThickness="0" Foreground="#FF4E606C" FontSize="14" FontWeight="Bold" Click="CancelButton_Click" Cursor="Hand" Margin="0,0,12,0" />
                        <Button Content="🌱 Plant Habit" Background="#FF328A5D" BorderThickness="0" Foreground="White" FontSize="14" FontWeight="Bold" Click="PlantButton_Click" Cursor="Hand" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
