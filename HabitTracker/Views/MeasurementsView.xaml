<UserControl x:Class="HabitTracker.Views.MeasurementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HabitTracker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <!-- Przekierowujemy wywołanie Save do Parent UserControl (DashboardView) po którym szukamy nazwy, lub używamy eventów. 
         Ponieważ to view używa DataContext ten sam co parent, Command będzie lepszy, ale puki co przekażemy click event do rodzica. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Body Measurements" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
            <TextBlock Text="Track your physical progress (in cm)" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="15" Margin="0,0,0,25" Padding="20">
            <StackPanel>
                <TextBlock Text="Add New Measurement" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,15" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" ItemsSource="{Binding BodyParts}" SelectedItem="{Binding SelectedBodyPart}" DisplayMemberPath="DisplayName" Margin="0,0,15,0" Height="42" Padding="15,0" VerticalContentAlignment="Center" FontSize="14" Foreground="{DynamicResource TextMainBrush}" Background="{DynamicResource InputBgBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>

                    <TextBox Grid.Column="1" Text="{Binding MeasurementValue, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,15,0" Height="42" Padding="15,0" VerticalContentAlignment="Center" FontSize="14" Tag="Value (cm)" Foreground="{DynamicResource TextMainBrush}" Background="{DynamicResource InputBgBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Grid.Column="2" Content="Save" Click="SaveMeasurement_Click" Background="#FF328A5D" Foreground="White" FontWeight="Bold" Padding="30,0" Height="42" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <ItemsControl ItemsSource="{Binding MeasurementLogs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" Margin="0,0,0,15" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding BodyPart.DisplayName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Value, StringFormat={}{0} cm}" FontSize="16" FontWeight="Bold" Foreground="#FF328A5D" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>