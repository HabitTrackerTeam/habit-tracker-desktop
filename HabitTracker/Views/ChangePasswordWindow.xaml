<Window x:Class="HabitTracker.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password"
        Width="400"
        SizeToContent="Height"
        Background="White"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        BorderThickness="0">
    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="20" ShadowDepth="4"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{Binding ChangePassword, Source={StaticResource Loc}}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMainBrush}" FontSize="16" Cursor="Hand" Click="Cancel_Click"/>
            </Grid>
            
            <!-- Old Password -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="{Binding OldPassword, Source={StaticResource Loc}}" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="OldPasswordBox" Height="48" Padding="12,0" Background="{DynamicResource InputBgBrush}" BorderBrush="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMainBrush}" FontSize="14" VerticalContentAlignment="Center">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
            </StackPanel>
            
            <!-- New Password -->
            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Text="{Binding NewPassword, Source={StaticResource Loc}}" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="NewPasswordBox" Height="48" Padding="12,0" Background="{DynamicResource InputBgBrush}" BorderBrush="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMainBrush}" FontSize="14" VerticalContentAlignment="Center">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
            </StackPanel>
            
            <!-- Repeat New Password -->
            <StackPanel Grid.Row="3" Margin="0,0,0,24">
                <TextBlock Text="{Binding RepeatNewPassword, Source={StaticResource Loc}}" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="RepeatPasswordBox" Height="48" Padding="12,0" Background="{DynamicResource InputBgBrush}" BorderBrush="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMainBrush}" FontSize="14" VerticalContentAlignment="Center">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
            </StackPanel>
            
            <!-- Error message -->
            <TextBlock x:Name="ErrorText" Grid.Row="4" Foreground="#FFD32F2F" TextWrapping="Wrap" Margin="0,0,0,16" Visibility="Collapsed"/>
            
            <!-- Actions -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding Cancel, Source={StaticResource Loc}}" Width="90" Height="38" Margin="0,0,12,0" Click="Cancel_Click" Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                <Button Content="{Binding SavePassword, Source={StaticResource Loc}}" Width="130" Height="38" Click="Save_Click" Background="{DynamicResource AccentGreenBrush}" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
