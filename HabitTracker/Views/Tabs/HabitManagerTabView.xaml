<UserControl x:Class="HabitTracker.Views.Tabs.HabitManagerTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Section (Habits Manager) -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="{Binding HabitsManager, Source={StaticResource Loc}}" FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource TextMainBrush}" />
                <TextBlock Text="{Binding WhatPlanToAchieve, Source={StaticResource Loc}}"
                           FontSize="14" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" />
            </StackPanel>

            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Click="AddHabit_Click" 
                    Background="{DynamicResource AccentGreenBrush}" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    FontSize="16"
                    Padding="24,14" 
                    BorderThickness="0" 
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal" Margin="0">
                    <TextBlock Text="+" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Add Habit" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Search Box -->
        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <TextBox x:Name="SearchBox" Tag="Search habits..." Height="44" Margin="0" />
        </Border>

        <!-- Filters and List (Grid.Row=2 & 3) -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
            <!-- priority/category/status/frequency filters copied from original -->
            <!-- ... (kept intentionally concise in the new UserControl) ... -->
        </StackPanel>

        <Border Grid.Row="3" Background="{DynamicResource CardBgBrush}" CornerRadius="15" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- List Header -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>

                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource InputBorderBrush}" Padding="0,0,0,12">
                        <Grid>
                            <TextBlock Text="HABIT DETAILS" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" />
                        </Grid>
                    </Border>

                    <TextBlock Grid.Column="1" Text="CATEGORY" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,12" />
                    <TextBlock Grid.Column="2" Text="FREQUENCY" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,12" />
                    <TextBlock Grid.Column="3" Text="ACTIONS" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12" />
                </Grid>

                <!-- Habits Items List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <ItemsControl ItemsSource="{Binding Habits}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" CornerRadius="12" Padding="0,12,0,12" Margin="0,0,0,0" BorderThickness="0,0,0,1" BorderBrush="#FFF0F3F1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="40" Height="40" Background="#E9FFF3" CornerRadius="10" VerticalAlignment="Center">
                                                <TextBlock Text="đź’§" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                            </Border>
                                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextMainBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding Category.Name}" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />

                                        <Border Grid.Column="2" Background="#E6F8F0" CornerRadius="8" Padding="10,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Period}" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" FontSize="11" />
                                        </Border>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Button Click="EditHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" Margin="0,0,8,0" ToolTip="Edit">
                                                <TextBlock Text="âśŹď¸Ź" FontSize="14" />
                                            </Button>
                                            <Button Click="DeleteHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" ToolTip="Delete">
                                                <TextBlock Text="đź—‘ď¸Ź" FontSize="14" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ========== ADD HABIT MODAL ========== -->
        <Grid Visibility="{Binding IsAddHabitModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" Margin="0" Padding="30" Width="600" MaxHeight="750"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="24,24,24,20" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Add New Habit" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                                <TextBlock Text="Plant a new seed for your personal growth journey." FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="CloseAddHabitModal_Click" Cursor="Hand">
                                <TextBlock Text="âś•" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Form -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,20">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="HABIT NAME" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                <TextBox x:Name="HabitNameBox" Tag="e.g., Daily Meditation" Height="40" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="HABIT TYPE" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal" Height="44">
                                    <Button x:Name="TypeNumericBtn" Content="Numeric" Background="#E6F8F0" BorderBrush="#FF328A5D" BorderThickness="2" Foreground="#FF328A5D" FontSize="13" FontWeight="Bold" Padding="16,0" Margin="0,0,12,0" Click="TypeButton_Click" Cursor="Hand" />
                                    <Button x:Name="TypeCheckboxBtn" Content="Checkbox" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Padding="16,0" Margin="0,0,12,0" Click="TypeButton_Click" Cursor="Hand" />
                                    <Button x:Name="TypeTimerBtn" Content="Timer" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Padding="16,0" Click="TypeButton_Click" Cursor="Hand" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="PRIORITY" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal" Height="44">
                                    <Button x:Name="PriorityLowBtn" Content="Low" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Padding="20,0" Margin="0,0,12,0" Click="PriorityButton_Click" Cursor="Hand" />
                                    <Button x:Name="PriorityMediumBtn" Content="Medium" Background="#E6F8F0" BorderBrush="#FF328A5D" BorderThickness="2" Foreground="#FF328A5D" FontSize="13" FontWeight="Bold" Padding="20,0" Margin="0,0,12,0" Click="PriorityButton_Click" Cursor="Hand" />
                                    <Button x:Name="PriorityHighBtn" Content="High" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Padding="20,0" Click="PriorityButton_Click" Cursor="Hand" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="CATEGORY" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CategoryCombo" Grid.Column="0" ItemsSource="{Binding Categories}" DisplayMemberPath="Name" Height="40" />
                                    <Button Grid.Column="1" Content="+" Background="Transparent" BorderThickness="0" Foreground="#FF328A5D" FontSize="18" FontWeight="Bold" Click="NewCategory_Click" VerticalAlignment="Center" Margin="8,0,0,0" Cursor="Hand" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="FREQUENCY" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="FreqDaily" Content="Daily" GroupName="Frequency" IsChecked="True" Margin="0,0,24,0" VerticalAlignment="Center" Checked="FreqRadio_Checked" />
                                    <RadioButton x:Name="FreqWeekly" Content="Weekly" GroupName="Frequency" Margin="0,0,24,0" VerticalAlignment="Center" Checked="FreqRadio_Checked" />
                                    <RadioButton x:Name="FreqMonthly" Content="Monthly" GroupName="Frequency" Margin="0,0,24,0" VerticalAlignment="Center" Checked="FreqRadio_Checked" />
                                    <RadioButton x:Name="FreqSpecific" Content="Specific" GroupName="Frequency" VerticalAlignment="Center" Checked="FreqRadio_Checked" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="SchedulePanel" Visibility="Collapsed" Margin="0,0,0,16">
                                <TextBlock Text="SCHEDULE" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="DayMonday" Content="M" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                                    <Button x:Name="DayTuesday" Content="T" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                                    <Button x:Name="DayWednesday" Content="W" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                                    <Button x:Name="DayThursday" Content="T" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                                    <Button x:Name="DayFriday" Content="F" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                                    <Button x:Name="DaySaturday" Content="S" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Margin="0,0,8,0" Click="DayButton_Click" Cursor="Hand" />
                                    <Button x:Name="DaySunday" Content="S" Width="44" Height="44" Background="White" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="14" FontWeight="Bold" Foreground="#FF4E606C" Click="DayButton_Click" Cursor="Hand" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="GOAL / TARGET" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                <TextBox x:Name="GoalBox" Tag="20" Height="40" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="UNITS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                <ComboBox x:Name="UnitsCombo" Height="40">
                                    <ComboBoxItem Content="mins" />
                                    <ComboBoxItem Content="hours" />
                                    <ComboBoxItem Content="pages" />
                                    <ComboBoxItem Content="count" />
                                    <ComboBoxItem Content="custom" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="Cancel" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMainBrush}" FontSize="14" FontWeight="Bold" Click="CancelAddHabit_Click" Cursor="Hand" Margin="0,0,12,0" />
                                <Button Content="đźŚ± Plant Habit" Background="#FF328A5D" BorderThickness="0" Foreground="White" FontSize="14" FontWeight="Bold" Click="PlantHabit_Click" Cursor="Hand" Padding="20,10" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== CREATE CATEGORY MODAL ========== -->
        <Grid Visibility="{Binding IsCreateCategoryModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" Margin="0" Padding="30" Width="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5" />
                </Border.Effect>
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Create New Category" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                            <TextBlock Text="Give your habit category a name, color and icon." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="CloseCreateCategoryModal_Click" Cursor="Hand">
                            <TextBlock Text="âś•" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" />
                        </Button>
                    </Grid>

                    <!-- Category Name -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CATEGORY NAME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox x:Name="CategoryNameBoxCreateCategory" Tag="e.g., Health &amp; Fitness" Height="40" Padding="12,8,12,8" />
                    </StackPanel>

                    <!-- Choose Icon -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CHOOSE ICON" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="IconBtnCategory1" Content="âś“" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="CategoryIconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtnCategory2" Content="đź“‹" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="CategoryIconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtnCategory3" Content="đźŽŻ" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="CategoryIconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtnCategory4" Content="đź’Ş" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="CategoryIconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtnCategory5" Content="đź§ " Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Click="CategoryIconButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Choose Color -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CHOOSE COLOR" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ColorBtnCategory1" Width="40" Height="40" Background="#328A5D" BorderThickness="0" Margin="0,0,12,0" Click="CategoryColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtnCategory2" Width="40" Height="40" Background="#0066CC" BorderThickness="0" Margin="0,0,12,0" Click="CategoryColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtnCategory3" Width="40" Height="40" Background="#FF6B6B" BorderThickness="0" Margin="0,0,12,0" Click="CategoryColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtnCategory4" Width="40" Height="40" Background="#FFD93D" BorderThickness="0" Margin="0,0,12,0" Click="CategoryColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtnCategory5" Width="40" Height="40" Background="#9B59B6" BorderThickness="0" Click="CategoryColorButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Cancel" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMainBrush}" FontSize="13" FontWeight="Bold" Click="CancelCreateCategory_Click" Cursor="Hand" Margin="0,0,12,0" Width="70" />
                        <Button Content="Create Category" Background="#FF328A5D" BorderThickness="0" Foreground="White" FontSize="13" FontWeight="Bold" Click="CreateCategoryButton_Click" Cursor="Hand" Width="130" Height="40" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
