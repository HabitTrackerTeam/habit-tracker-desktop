<UserControl x:Class="HabitTracker.Views.Tabs.HabitManagerTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="EmojiButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScheduleDayButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" BorderBrush="Transparent" Background="Transparent" BorderThickness="0" FocusVisualStyle="{x:Null}" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="30" />
                                            </Grid.ColumnDefinitions>
                                            <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2" />
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="12,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Name="DropDownBorder" Background="{DynamicResource CardBgBrush}" BorderThickness="1" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="8" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="4,2">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBgBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBgBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- Main Content -->
        <Grid Margin="40,20,20,20">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAddHabitModalOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15" KernelType="Gaussian" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>

                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding HabitsManager, Source={StaticResource Loc}}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                <TextBlock Text="{Binding WhatPlanToAchieve, Source={StaticResource Loc}}" 
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
            
            <Button Grid.Column="1" VerticalAlignment="Top"
                    Click="AddHabit_Click" 
                    Background="#166534" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    FontSize="16"
                    Padding="24,14" 
                    BorderThickness="0" 
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding AddHabit, Source={StaticResource Loc}}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="12" Margin="0,0,0,24">
            <TextBox x:Name="SearchBox" Tag="{Binding SearchHabits, Source={StaticResource Loc}}" Height="44" Background="Transparent" BorderThickness="0" Padding="16,0" VerticalContentAlignment="Center" Foreground="{DynamicResource TextMainBrush}" />
        </Border>

        <!-- Filters -->
        <Grid Grid.Row="2" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="{Binding FrequencyLabel, Source={StaticResource Loc}}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <ComboBox Style="{StaticResource FilterComboBoxStyle}" ItemsSource="{Binding Frequencies}" SelectedItem="{Binding SelectedFrequency}" DisplayMemberPath="Name" />
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                <TextBlock Text="{Binding PriorityLabel, Source={StaticResource Loc}}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <ComboBox Style="{StaticResource FilterComboBoxStyle}" ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority}" DisplayMemberPath="Name" />
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                <TextBlock Text="{Binding StatusLabel, Source={StaticResource Loc}}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <ComboBox Style="{StaticResource FilterComboBoxStyle}" ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" DisplayMemberPath="Name" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- Habits List (Scrollable) -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Table Headers -->
            <Border Grid.Row="0" Margin="0,0,0,8" Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding HabitDetailsLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding FrequencyLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding PriorityLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="{Binding StatusLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="{Binding ActionsLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Scrollable Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <ItemsControl ItemsSource="{Binding FilteredHabits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12" AllowDrop="True" Drop="HabitRow_Drop" DragOver="HabitRow_DragOver">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="4" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Border Background="{DynamicResource InputBgBrush}" Width="40" Height="40" CornerRadius="8">
                                            <TextBlock Text="{Binding Icon, FallbackValue=💧}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="16,0,0,0" />
                                    </StackPanel>
                                    
                                    <Border Grid.Column="1" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Height="24" HorizontalAlignment="Center" Padding="8,0">
                                        <TextBlock Text="{Binding Period}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                                    </Border>

                                    <Border Grid.Column="2" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Height="24" HorizontalAlignment="Center" Padding="8,0">
                                        <TextBlock x:Name="PriorityText" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                                    </Border>

                                    <Border Grid.Column="3" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Height="24" HorizontalAlignment="Center" Padding="8,0">
                                        <TextBlock x:Name="StatusText" Text="{Binding StatusActive, Source={StaticResource Loc}}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                                    </Border>
                                    
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Ikonka kropek (Drag Handle) -->
                                        <Border Background="Transparent" Padding="4" Margin="0,0,8,0" 
                                                PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown">
                                            <Path Data="M9,3H11V5H9V3M13,3H15V5H13V3M9,7H11V9H9V7M13,7H15V9H13V7M9,11H11V13H9V11M13,11H15V13H13V11M9,15H11V17H9V15M13,15H15V17H13V15M9,19H11V21H9V19M13,19H15V21H13V19Z" Fill="#94A3B8" Width="14" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button Click="EditHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" Margin="0,0,4,0" ToolTip="Edit">
                                            <TextBlock Text="✏️" FontSize="14" />
                                        </Button>
                                        <Button Click="DeleteHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" ToolTip="Delete">
                                            <TextBlock Text="🗑️" FontSize="14" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Priority}" Value="1">
                                    <Setter TargetName="PriorityText" Property="Text" Value="{Binding Source={StaticResource Loc}, Path=PriorityHigh}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Priority}" Value="2">
                                    <Setter TargetName="PriorityText" Property="Text" Value="{Binding Source={StaticResource Loc}, Path=PriorityMedium}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Priority}" Value="3">
                                    <Setter TargetName="PriorityText" Property="Text" Value="{Binding Source={StaticResource Loc}, Path=PriorityLow}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                    <Setter TargetName="StatusText" Property="Text" Value="{Binding Source={StaticResource Loc}, Path=StatusArchived}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        </Grid>

        <!-- ========== ADD HABIT MODAL ========== -->
        <Grid Visibility="{Binding IsAddHabitModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <Border Background="#4D000000" />
            
            <Grid Width="600" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                <!-- Shadow Border (separate to prevent ComboBox popup clipping bug in WPF) -->
                <Border Background="White" CornerRadius="15">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5" />
                    </Border.Effect>
                </Border>
                
                <!-- Main Content Border -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" Padding="30">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Habit Name & Icon -->
                        <RowDefinition Height="Auto"/> <!-- Type & Priority -->
                        <RowDefinition Height="Auto"/> <!-- Frequency -->
                        <RowDefinition Height="Auto"/> <!-- Goal & Units -->
                        <RowDefinition Height="*"/>    <!-- Spacer -->
                        <RowDefinition Height="Auto"/> <!-- Footer Actions -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="{Binding ModalTitle}" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="{Binding PlantNewSeed, Source={StaticResource Loc}}" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseAddHabitModal_Click">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="#64748B" Stretch="Uniform" Width="14"/>
                        </Button>
                    </Grid>

                    <!-- Habit Name & Icon -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Label -->
                            <RowDefinition Height="Auto"/> <!-- Controls -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Icon Button -->
                            <ColumnDefinition Width="*"/>    <!-- Textbox -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{Binding HabitNameLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>

                        <!-- Left-aligned Select Icon Button (styled like habit list cards) -->
                        <Button Grid.Row="1" Grid.Column="0" x:Name="SelectIconButton" Click="SelectIconButton_Click" Cursor="Hand" Background="#F0FDF4" Width="48" Height="48" BorderThickness="0" Margin="0,0,16,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock x:Name="SelectedIconPreview" Text="{Binding NewHabitIcon, FallbackValue=❓}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <Popup Grid.Row="1" Grid.Column="0" x:Name="IconPickerPopup" PlacementTarget="{Binding ElementName=SelectIconButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="12,12,4,12" Width="300" Height="220">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="3"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding ChooseIcon, Source={StaticResource Loc}}" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <WrapPanel x:Name="EmojiWrapPanel" HorizontalAlignment="Center" Width="252"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>

                        <!-- Right-aligned Habit Name input box -->
                        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Padding="16,12" Height="48">
                            <TextBox Style="{StaticResource CenteredTextBoxStyle}" x:Name="HabitNameBox" Text="" VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" FocusVisualStyle="{x:Null}" />
                        </Border>
                    </Grid>

                    <!-- Type & Priority -->
                    <Grid Grid.Row="2" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding HabitTypeLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="TypeNumericBtn" Grid.Column="0" Content="{Binding TypeNumeric, Source={StaticResource Loc}}" Background="White" BorderThickness="0" Foreground="#166534" FontWeight="Bold" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="TypeCheckboxBtn" Grid.Column="1" Content="{Binding TypeCheckbox, Source={StaticResource Loc}}" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="TypeTimerBtn" Grid.Column="2" Content="{Binding TypeTimer, Source={StaticResource Loc}}" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding PriorityLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PriorityLowBtn" Grid.Column="0" Content="{Binding PriorityLow, Source={StaticResource Loc}}" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="PriorityMediumBtn" Grid.Column="1" Content="{Binding PriorityMedium, Source={StaticResource Loc}}" Background="White" BorderThickness="0" Foreground="#166534" FontWeight="Bold" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="PriorityHighBtn" Grid.Column="2" Content="{Binding PriorityHigh, Source={StaticResource Loc}}" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Frequency -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,20">
                        <TextBlock Text="{Binding FrequencyLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                            <Grid>
                                <Grid.Resources>
                                    <Style TargetType="RadioButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border x:Name="border" Background="Transparent" CornerRadius="8" Padding="0,8" Cursor="Hand">
                                                        <TextBlock x:Name="txt" Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="White"/>
                                                            <Setter TargetName="txt" Property="Foreground" Value="#166534"/>
                                                            <Setter TargetName="txt" Property="FontWeight" Value="Bold"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Grid.Resources>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="FreqDaily" Grid.Column="0" Content="{Binding FreqDaily, Source={StaticResource Loc}}" GroupName="Frequency" IsChecked="True" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqWeekly" Grid.Column="1" Content="{Binding FreqWeekly, Source={StaticResource Loc}}" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqMonthly" Grid.Column="2" Content="{Binding FreqMonthly, Source={StaticResource Loc}}" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqSpecific" Grid.Column="3" Content="{Binding FreqSpecific, Source={StaticResource Loc}}" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                            </Grid>
                        </Border>
                        
                        <!-- Specific Schedule Display -->
                        <Border x:Name="SchedulePanel" Visibility="Collapsed" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                            <Grid>
                                <TextBlock Text="{Binding ScheduleLabel, Source={StaticResource Loc}}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="DayMonday" Content="{Binding MondayShort, Source={StaticResource Loc}}" Style="{StaticResource ScheduleDayButtonStyle}" Background="#166534" Foreground="White" FontWeight="Bold" Click="DayButton_Click" />
                                    <Button x:Name="DayTuesday" Content="{Binding TuesdayShort, Source={StaticResource Loc}}" Style="{StaticResource ScheduleDayButtonStyle}" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextMutedBrush}" Click="DayButton_Click" />
                                    <Button x:Name="DayWednesday" Content="{Binding WednesdayShort, Source={StaticResource Loc}}" Style="{StaticResource ScheduleDayButtonStyle}" Background="#166534" Foreground="White" FontWeight="Bold" Click="DayButton_Click" />
                                    <Button x:Name="DayThursday" Content="{Binding ThursdayShort, Source={StaticResource Loc}}" Style="{StaticResource ScheduleDayButtonStyle}" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextMutedBrush}" Click="DayButton_Click" />
                                    <Button x:Name="DayFriday" Content="{Binding FridayShort, Source={StaticResource Loc}}" Style="{StaticResource ScheduleDayButtonStyle}" Background="#166534" Foreground="White" FontWeight="Bold" Click="DayButton_Click" />
                                    <Button x:Name="DaySaturday" Content="{Binding SaturdayShort, Source={StaticResource Loc}}" Style="{StaticResource ScheduleDayButtonStyle}" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextMutedBrush}" Click="DayButton_Click" />
                                    <Button x:Name="DaySunday" Content="{Binding SundayShort, Source={StaticResource Loc}}" Style="{StaticResource ScheduleDayButtonStyle}" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextMutedBrush}" Margin="0" Click="DayButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Goal & Units -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding GoalTargetLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12" Padding="16,12">
                                <TextBox Style="{StaticResource CenteredTextBoxStyle}" x:Name="GoalBox" Background="Transparent" BorderThickness="0" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" FocusVisualStyle="{x:Null}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding UnitsLabel, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12" Padding="16,12">
                                <ComboBox x:Name="UnitsCombo" OverridesDefaultStyle="True" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Padding="8,0,0,0" Margin="4,0,0,0" FocusVisualStyle="{x:Null}">
                                    <ComboBox.Template>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton Name="ToggleButton" BorderBrush="Transparent" Background="Transparent" BorderThickness="0" FocusVisualStyle="{x:Null}" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Grid Background="Transparent">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="20" />
                                                                </Grid.ColumnDefinitions>
                                                                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2" />
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                                <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="0,0,20,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                    <Border Name="DropDownBorder" Background="{DynamicResource CardBgBrush}" BorderThickness="1" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="8" Margin="0,4,0,0">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="2"/>
                                                        </Border.Effect>
                                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </ComboBox.Template>
                                    <ComboBoxItem Content="mins" />
                                    <ComboBoxItem Content="hours" />
                                    <ComboBoxItem Content="pages" />
                                    <ComboBoxItem Content="count" />
                                    <ComboBoxItem Content="custom" />
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Footer Actions -->
                    <Grid Grid.Row="6" Margin="0,32,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{Binding Cancel, Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" Background="Transparent" BorderThickness="0" Margin="0,0,24,0" Cursor="Hand" Click="CancelAddHabit_Click"/>
                            <Button Background="#166534" BorderThickness="0" Padding="24,14" Cursor="Hand" Click="PlantHabit_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="12"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                    <TextBlock Text="{Binding ModalButtonText}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
        </Grid>


    </Grid>
</UserControl>
