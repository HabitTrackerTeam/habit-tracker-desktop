<UserControl x:Class="HabitTracker.Views.Tabs.HabitManagerTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <!-- Main Content -->
        <Grid Margin="40,20,20,20">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAddHabitModalOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15" KernelType="Gaussian" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsCreateCategoryModalOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15" KernelType="Gaussian" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding HabitsManager, Source={StaticResource Loc}}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                <TextBlock Text="{Binding WhatPlanToAchieve, Source={StaticResource Loc}}" 
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
            
            <Button Grid.Column="1" VerticalAlignment="Top"
                    Click="AddHabit_Click" 
                    Background="#166534" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    FontSize="16"
                    Padding="24,14" 
                    BorderThickness="0" 
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Add Habit" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="12" Margin="0,0,0,24">
            <TextBox x:Name="SearchBox" Tag="Search habits..." Height="44" Background="Transparent" BorderThickness="0" Padding="16,0" VerticalContentAlignment="Center" Foreground="{DynamicResource TextMainBrush}" />
        </Border>

        <!-- Filters -->
        <Grid Grid.Row="2" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="PRIORITY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <TextBlock Text="All Priorities" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextMainBrush}"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                <TextBlock Text="CATEGORY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <TextBlock Text="All Categories" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextMainBrush}"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0,8,0">
                <TextBlock Text="STATUS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <TextBlock Text="Active Habits" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextMainBrush}"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="8,0,0,0">
                <TextBlock Text="FREQUENCY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <TextBlock Text="Every Day" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextMainBrush}"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Habits List (Scrollable) -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Table Headers -->
            <Border Grid.Row="0" Margin="0,0,0,8" Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="HABIT DETAILS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="1" Text="CATEGORY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="FREQUENCY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="ACTIONS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Scrollable Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <ItemsControl ItemsSource="{Binding Habits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="4" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Border Background="#ECFDF5" Width="40" Height="40" CornerRadius="8">
                                            <TextBlock Text="{Binding Category.Icon, FallbackValue=đź’§}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="16,0,0,0" />
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding Category.Name}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                    
                                    <Border Grid.Column="2" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Height="24" HorizontalAlignment="Center" Padding="8,0">
                                        <TextBlock Text="{Binding Period}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                                    </Border>
                                    
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Click="EditHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" Margin="0,0,4,0" ToolTip="Edit">
                                            <TextBlock Text="âśŹď¸Ź" FontSize="14" />
                                        </Button>
                                        <Button Click="DeleteHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" ToolTip="Delete">
                                            <TextBlock Text="đź—‘ď¸Ź" FontSize="14" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        </Grid>

        <!-- ========== ADD HABIT MODAL ========== -->
        <Grid Visibility="{Binding IsAddHabitModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <Border Background="#4D000000" />
            <Border Background="{DynamicResource CardBgBrush}" 
                    CornerRadius="15" 
                    Margin="0" 
                    Padding="30" 
                    Width="600" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Habit Name -->
                        <RowDefinition Height="Auto"/> <!-- Type & Priority -->
                        <RowDefinition Height="Auto"/> <!-- Category -->
                        <RowDefinition Height="Auto"/> <!-- Frequency -->
                        <RowDefinition Height="Auto"/> <!-- Goal & Units -->
                        <RowDefinition Height="*"/>    <!-- Spacer -->
                        <RowDefinition Height="Auto"/> <!-- Footer Actions -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Add New Habit" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Plant a new seed for your personal growth journey." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseAddHabitModal_Click">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="#64748B" Stretch="Uniform" Width="14"/>
                        </Button>
                    </Grid>

                    <!-- Habit Name -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="HABIT NAME" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12">
                            <TextBox x:Name="HabitNameBox" Tag="e.g., Daily Meditation" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#0F172A" Padding="0" />
                        </Border>
                    </StackPanel>

                    <!-- Type & Priority -->
                    <Grid Grid.Row="2" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="HABIT TYPE" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="TypeNumericBtn" Grid.Column="0" Content="Numeric" Background="White" BorderThickness="0" Foreground="#166534" FontWeight="Bold" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="TypeCheckboxBtn" Grid.Column="1" Content="Checkbox" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="TypeTimerBtn" Grid.Column="2" Content="Timer" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PRIORITY" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PriorityLowBtn" Grid.Column="0" Content="Low" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="PriorityMediumBtn" Grid.Column="1" Content="Medium" Background="White" BorderThickness="0" Foreground="#166534" FontWeight="Bold" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="PriorityHighBtn" Grid.Column="2" Content="High" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Category -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,20">
                        <TextBlock Text="CATEGORY" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CategoryCombo" Grid.Column="0" ItemsSource="{Binding Categories}" DisplayMemberPath="Name" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#0F172A" Padding="0" />
                                <Button Grid.Column="1" Content="+" Background="Transparent" BorderThickness="0" Foreground="#166534" FontSize="18" FontWeight="Bold" Click="NewCategory_Click" VerticalAlignment="Center" Margin="8,0,0,0" Cursor="Hand" />
                            </Grid>
                        </Border>
                        
                        <!-- Category Style Selection (Mini Row) -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <TextBlock Text="ICON" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border Background="#166534" Width="32" Height="32" CornerRadius="6" Margin="0,0,4,0">
                                    <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.41,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.59,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                                </Border>
                                <Border Background="#F1F5F9" Width="32" Height="32" CornerRadius="6" Margin="0,0,4,0">
                                    <Path Data="M10,2H14A2,2 0 0,1 16,4V6H20A2,2 0 0,1 22,8V19A2,2 0 0,1 20,21H4A2,2 0 0,1 2,19V8A2,2 0 0,1 4,6H8V4A2,2 0 0,1 10,2M14,6V4H10V6H14Z" Fill="#64748B" Width="14" Height="14" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Grid.Column="2">
                                <TextBlock Text="COLOR" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Ellipse Width="12" Height="12" Fill="#166534" Margin="0,0,6,0"/>
                                <Ellipse Width="12" Height="12" Fill="#3B82F6" Margin="0,0,6,0"/>
                                <Ellipse Width="12" Height="12" Fill="#EF4444" Margin="0,0,6,0"/>
                                <Ellipse Width="12" Height="12" Fill="#F59E0B" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Frequency -->
                    <StackPanel Grid.Row="4" Margin="0,0,0,20">
                        <TextBlock Text="FREQUENCY" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                            <Grid>
                                <Grid.Resources>
                                    <Style TargetType="RadioButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border x:Name="border" Background="Transparent" CornerRadius="8" Padding="0,8" Cursor="Hand">
                                                        <TextBlock x:Name="txt" Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="White"/>
                                                            <Setter TargetName="txt" Property="Foreground" Value="#166534"/>
                                                            <Setter TargetName="txt" Property="FontWeight" Value="Bold"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Grid.Resources>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="FreqDaily" Grid.Column="0" Content="Daily" GroupName="Frequency" IsChecked="True" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqWeekly" Grid.Column="1" Content="Weekly" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqMonthly" Grid.Column="2" Content="Monthly" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqSpecific" Grid.Column="3" Content="Specific" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                            </Grid>
                        </Border>
                        
                        <!-- Specific Schedule Display -->
                        <Border x:Name="SchedulePanel" Visibility="Collapsed" Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                            <Grid>
                                <TextBlock Text="SCHEDULE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="DayMonday" Content="M" Width="28" Height="28" Background="#166534" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DayTuesday" Content="T" Width="28" Height="28" Background="#E2E8F0" Foreground="#64748B" FontSize="11" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DayWednesday" Content="W" Width="28" Height="28" Background="#166534" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DayThursday" Content="T" Width="28" Height="28" Background="#E2E8F0" Foreground="#64748B" FontSize="11" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DayFriday" Content="F" Width="28" Height="28" Background="#166534" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DaySaturday" Content="S" Width="28" Height="28" Background="#E2E8F0" Foreground="#64748B" FontSize="11" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DaySunday" Content="S" Width="28" Height="28" Background="#E2E8F0" Foreground="#64748B" FontSize="11" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Goal & Units -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GOAL / TARGET" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12">
                                <TextBox x:Name="GoalBox" Tag="20" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#0F172A" Padding="0" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="UNITS" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12">
                                <ComboBox x:Name="UnitsCombo" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#0F172A" Padding="0">
                                    <ComboBoxItem Content="mins" />
                                    <ComboBoxItem Content="hours" />
                                    <ComboBoxItem Content="pages" />
                                    <ComboBoxItem Content="count" />
                                    <ComboBoxItem Content="custom" />
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Footer Actions -->
                    <Grid Grid.Row="7" Margin="0,32,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" Background="Transparent" BorderThickness="0" Margin="0,0,24,0" Cursor="Hand" Click="CancelAddHabit_Click"/>
                            <Button Background="#166534" BorderThickness="0" Padding="24,14" Cursor="Hand" Click="PlantHabit_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="12"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                    <TextBlock Text="Plant Habit" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- Dimming overlay for when Create Category is open -->
                    <Border Grid.RowSpan="8" Background="#4D000000" CornerRadius="15" Margin="-30" Visibility="{Binding IsCreateCategoryModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>
        </Grid>

        <!-- ========== CREATE CATEGORY MODAL ========== -->
        <Grid Visibility="{Binding IsCreateCategoryModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <Border Background="Transparent" />
            <Border Background="{DynamicResource CardBgBrush}" 
                    CornerRadius="15" 
                    Margin="0" 
                    Padding="30" 
                    Width="600" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5" />
                </Border.Effect>
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Create New Category" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" />
                            <TextBlock Text="Give your habit category a name, color and icon." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="CloseCreateCategoryModal_Click" Cursor="Hand">
                            <TextBlock Text="âś•" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" />
                        </Button>
                    </Grid>

                    <!-- Category Name -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CATEGORY NAME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox x:Name="CategoryNameBoxCreateCategory" Tag="e.g., Health &amp; Fitness" Height="40" Padding="12,8,12,8" />
                    </StackPanel>

                    <!-- Choose Icon -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CHOOSE ICON" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="IconBtnCategory1" Content="âś“" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="CategoryIconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtnCategory2" Content="đź“‹" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="CategoryIconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtnCategory3" Content="đźŽŻ" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="CategoryIconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtnCategory4" Content="đź’Ş" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="CategoryIconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtnCategory5" Content="đź§ " Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Click="CategoryIconButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Choose Color -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CHOOSE COLOR" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ColorBtnCategory1" Width="40" Height="40" Background="#328A5D" BorderThickness="0" Margin="0,0,12,0" Click="CategoryColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtnCategory2" Width="40" Height="40" Background="#0066CC" BorderThickness="0" Margin="0,0,12,0" Click="CategoryColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtnCategory3" Width="40" Height="40" Background="#FF6B6B" BorderThickness="0" Margin="0,0,12,0" Click="CategoryColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtnCategory4" Width="40" Height="40" Background="#FFD93D" BorderThickness="0" Margin="0,0,12,0" Click="CategoryColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtnCategory5" Width="40" Height="40" Background="#9B59B6" BorderThickness="0" Click="CategoryColorButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Cancel" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMainBrush}" FontSize="13" FontWeight="Bold" Click="CancelCreateCategory_Click" Cursor="Hand" Margin="0,0,12,0" Width="70" />
                        <Button Content="Create Category" Background="#FF328A5D" BorderThickness="0" Foreground="White" FontSize="13" FontWeight="Bold" Click="CreateCategoryButton_Click" Cursor="Hand" Width="130" Height="40" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
