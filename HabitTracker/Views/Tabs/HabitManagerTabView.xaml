<UserControl x:Class="HabitTracker.Views.Tabs.HabitManagerTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <!-- Main Content -->
        <Grid Margin="40,20,20,20">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAddHabitModalOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15" KernelType="Gaussian" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>

                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding HabitsManager, Source={StaticResource Loc}}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                <TextBlock Text="{Binding WhatPlanToAchieve, Source={StaticResource Loc}}" 
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
            
            <Button Grid.Column="1" VerticalAlignment="Top"
                    Click="AddHabit_Click" 
                    Background="#166534" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    FontSize="16"
                    Padding="24,14" 
                    BorderThickness="0" 
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Add Habit" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="12" Margin="0,0,0,24">
            <TextBox x:Name="SearchBox" Tag="Search habits..." Height="44" Background="Transparent" BorderThickness="0" Padding="16,0" VerticalContentAlignment="Center" Foreground="{DynamicResource TextMainBrush}" />
        </Border>

        <!-- Filters -->
        <Grid Grid.Row="2" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="PRIORITY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <TextBlock Text="All Priorities" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextMainBrush}"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                <TextBlock Text="STATUS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <TextBlock Text="Active Habits" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextMainBrush}"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                <TextBlock Text="FREQUENCY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,4"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Height="44">
                    <TextBlock Text="Every Day" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextMainBrush}"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Habits List (Scrollable) -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Table Headers -->
            <Border Grid.Row="0" Margin="0,0,0,8" Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="HABIT DETAILS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="1" Text="FREQUENCY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="ACTIONS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Scrollable Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <ItemsControl ItemsSource="{Binding Habits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="4" ShadowDepth="2" Direction="270" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Border Background="#ECFDF5" Width="40" Height="40" CornerRadius="8">
                                            <TextBlock Text="{Binding Icon, FallbackValue=💧}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="16,0,0,0" />
                                    </StackPanel>
                                    
                                    <Border Grid.Column="1" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Height="24" HorizontalAlignment="Center" Padding="8,0">
                                        <TextBlock Text="{Binding Period}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                                    </Border>
                                    
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Click="EditHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" Margin="0,0,4,0" ToolTip="Edit">
                                            <TextBlock Text="✏️" FontSize="14" />
                                        </Button>
                                        <Button Click="DeleteHabit_Click" DataContext="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" ToolTip="Delete">
                                            <TextBlock Text="🗑️" FontSize="14" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        </Grid>

        <!-- ========== ADD HABIT MODAL ========== -->
        <Grid Visibility="{Binding IsAddHabitModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <Border Background="#4D000000" />
            
            <Grid Width="600" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                <!-- Shadow Border (separate to prevent ComboBox popup clipping bug in WPF) -->
                <Border Background="White" CornerRadius="15">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5" />
                    </Border.Effect>
                </Border>
                
                <!-- Main Content Border -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" Padding="30">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Habit Name -->
                        <RowDefinition Height="Auto"/> <!-- Type & Priority -->
                        <RowDefinition Height="Auto"/> <!-- Frequency -->
                        <RowDefinition Height="Auto"/> <!-- Frequency -->
                        <RowDefinition Height="Auto"/> <!-- Goal & Units -->
                        <RowDefinition Height="*"/>    <!-- Spacer -->
                        <RowDefinition Height="Auto"/> <!-- Footer Actions -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Add New Habit" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Plant a new seed for your personal growth journey." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseAddHabitModal_Click">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="#64748B" Stretch="Uniform" Width="14"/>
                        </Button>
                    </Grid>

                    <!-- Habit Name -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="HABIT NAME" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12">
                            <TextBox x:Name="HabitNameBox" Text="e.g., Daily Meditation" VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#94A3B8" Padding="0" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" />
                        </Border>
                    </StackPanel>

                    <!-- Type & Priority -->
                    <Grid Grid.Row="2" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="HABIT TYPE" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="TypeNumericBtn" Grid.Column="0" Content="Numeric" Background="White" BorderThickness="0" Foreground="#166534" FontWeight="Bold" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="TypeCheckboxBtn" Grid.Column="1" Content="Checkbox" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="TypeTimerBtn" Grid.Column="2" Content="Timer" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="TypeButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PRIORITY" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PriorityLowBtn" Grid.Column="0" Content="Low" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="PriorityMediumBtn" Grid.Column="1" Content="Medium" Background="White" BorderThickness="0" Foreground="#166534" FontWeight="Bold" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="PriorityHighBtn" Grid.Column="2" Content="High" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" Click="PriorityButton_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Icon Selection for Habit -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,20">
                        <TextBlock Text="ICON" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <WrapPanel>
                                <Button x:Name="IconBtn1" Content="❤️" Width="44" Height="44" Padding="0" Background="#166534" Foreground="White" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn2" Content="💪" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn3" Content="🧠" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn4" Content="📖" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn5" Content="🏃" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn6" Content="🧘" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn7" Content="💧" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn8" Content="🎯" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn9" Content="✏️" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="IconBtn10" Content="🌱" Width="44" Height="44" Padding="0" Background="#F1F5F9" FontSize="16" Margin="0,0,6,6" Click="HabitIconButton_Click" Cursor="Hand" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Frequency -->
                    <StackPanel Grid.Row="4" Margin="0,0,0,20">
                        <TextBlock Text="FREQUENCY" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <Border Background="#F1F5F9" CornerRadius="12" Padding="4">
                            <Grid>
                                <Grid.Resources>
                                    <Style TargetType="RadioButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border x:Name="border" Background="Transparent" CornerRadius="8" Padding="0,8" Cursor="Hand">
                                                        <TextBlock x:Name="txt" Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="White"/>
                                                            <Setter TargetName="txt" Property="Foreground" Value="#166534"/>
                                                            <Setter TargetName="txt" Property="FontWeight" Value="Bold"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Grid.Resources>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="FreqDaily" Grid.Column="0" Content="Daily" GroupName="Frequency" IsChecked="True" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqWeekly" Grid.Column="1" Content="Weekly" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqMonthly" Grid.Column="2" Content="Monthly" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                                <RadioButton x:Name="FreqSpecific" Grid.Column="3" Content="Specific" GroupName="Frequency" Checked="FreqRadio_Checked"/>
                            </Grid>
                        </Border>
                        
                        <!-- Specific Schedule Display -->
                        <Border x:Name="SchedulePanel" Visibility="Collapsed" Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                            <Grid>
                                <TextBlock Text="SCHEDULE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="DayMonday" Content="M" Width="28" Height="28" Background="#166534" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DayTuesday" Content="T" Width="28" Height="28" Background="#E2E8F0" Foreground="#64748B" FontSize="11" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DayWednesday" Content="W" Width="28" Height="28" Background="#166534" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DayThursday" Content="T" Width="28" Height="28" Background="#E2E8F0" Foreground="#64748B" FontSize="11" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DayFriday" Content="F" Width="28" Height="28" Background="#166534" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DaySaturday" Content="S" Width="28" Height="28" Background="#E2E8F0" Foreground="#64748B" FontSize="11" Margin="0,0,4,0" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="DaySunday" Content="S" Width="28" Height="28" Background="#E2E8F0" Foreground="#64748B" FontSize="11" Click="DayButton_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style></Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Goal & Units -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GOAL / TARGET" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12">
                                <TextBox x:Name="GoalBox" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#0F172A" Padding="0" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="UNITS" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12">
                                <ComboBox x:Name="UnitsCombo" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#0F172A" Padding="0">
                                    <ComboBoxItem Content="mins" />
                                    <ComboBoxItem Content="hours" />
                                    <ComboBoxItem Content="pages" />
                                    <ComboBoxItem Content="count" />
                                    <ComboBoxItem Content="custom" />
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Footer Actions -->
                    <Grid Grid.Row="7" Margin="0,32,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" Background="Transparent" BorderThickness="0" Margin="0,0,24,0" Cursor="Hand" Click="CancelAddHabit_Click"/>
                            <Button Background="#166534" BorderThickness="0" Padding="24,14" Cursor="Hand" Click="PlantHabit_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="12"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                    <TextBlock Text="Plant Habit" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
        </Grid>


    </Grid>
</UserControl>
