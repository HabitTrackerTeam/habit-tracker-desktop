<UserControl x:Class="HabitTracker.Views.Tabs.StatisticsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent"
             FontFamily="Inter, Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="ChartLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Margin="40,32,40,20">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStatisticsModalOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15" KernelType="Gaussian" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,24" MinHeight="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                <TextBlock Text="{Binding Statistics, Source={StaticResource Loc}}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                <TextBlock Text="{Binding ViewProgressAchievements, Source={StaticResource Loc}}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            

        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Charts Row -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Growth Quotient Card -->
                <Border Grid.Column="0" Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="32">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <StackPanel VerticalAlignment="Top">
                            <TextBlock Text="{Binding GrowthQuotient, Source={StaticResource Loc}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            <TextBlock Text="{Binding GrowthQuotientDesc, Source={StaticResource Loc}}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" MaxWidth="280" HorizontalAlignment="Left" Margin="0,8,0,24"/>
                            <Border CornerRadius="20" Padding="12,6" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F0FDF4"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPositiveGrowthTrend}" Value="False">
                                                <Setter Property="Background" Value="#FEF2F2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="12" Height="12" Margin="0,0,4,0" Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Data" Value="M7,14L12,9L17,14H7Z"/>
                                                <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPositiveGrowthTrend}" Value="False">
                                                        <Setter Property="Data" Value="M7,10L12,15L17,10H7Z"/>
                                                        <Setter Property="Fill" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <TextBlock Text="{Binding GrowthQuotientTrend}" FontSize="13" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPositiveGrowthTrend}" Value="False">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Circular Score -->
                        <Grid HorizontalAlignment="Right" Width="160" Height="160">
                            <Ellipse Stroke="{DynamicResource InputBgBrush}" StrokeThickness="16"/>
                            <Path Stroke="{DynamicResource AccentGreenBrush}" StrokeThickness="16" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 80,80 m 0,-64 a 64,64 0 1 1 0,128 a 64,64 0 1 1 0,-128" 
                                  StrokeDashArray="{Binding GrowthQuotientDashArray}" Opacity="1">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthQuotient}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                                <Path.RenderTransform>
                                    <RotateTransform Angle="-90" CenterX="80" CenterY="80"/>
                                </Path.RenderTransform>
                            </Path>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding GrowthQuotient, StringFormat={}{0}%}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding OverallScore, Source={StaticResource Loc}}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Weekly Completion Section -->
                <Border Grid.Column="2" Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="32">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,32">
                            <StackPanel>
                                <TextBlock Text="{Binding WeeklyCompletion, Source={StaticResource Loc}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                <TextBlock Text="{Binding WeeklyCompletionDesc, Source={StaticResource Loc}}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                            <!-- Date Selector -->
                            <Border HorizontalAlignment="Right" Background="{DynamicResource InputBgBrush}" CornerRadius="8" Padding="6,4">
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding PreviousWeekCommand}" Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" Stretch="Uniform"/>
                                    </Button>
                                    
                                    <TextBlock Text="{Binding WeeklyCompletionDateRange}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" Margin="12,0"/>
                                    
                                    <Button Command="{Binding NextWeekCommand}" IsEnabled="{Binding CanNavigateNextWeek}" Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="1.0"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.3"/>
                                                        <Setter Property="Cursor" Value="Arrow"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Bar Chart Representation -->
                        <ItemsControl ItemsSource="{Binding WeeklyCompletionDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="7" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <Border Grid.Row="0" Width="16" Height="80" CornerRadius="8" Background="{DynamicResource InputBgBrush}" VerticalAlignment="Bottom" Margin="0,0,0,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFuture}" Value="True">
                                                            <Setter Property="Visibility" Value="Hidden"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border Width="16" Height="{Binding BarHeight}" 
                                                    CornerRadius="8" Background="{Binding BarColor}" VerticalAlignment="Bottom"/>
                                        </Border>
                                        
                                        <TextBlock Grid.Row="1" Text="{Binding DayName}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>



            <!-- Detailed Performance Table -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="{Binding DetailedPerformance, Source={StaticResource Loc}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                        <TextBlock Text="{Binding DetailedPerformanceDesc, Source={StaticResource Loc}}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Headers -->
                        <Border Grid.Row="0" Background="{DynamicResource AppBgBrush}" Padding="24,16" Margin="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding HabitNameHeader, Source={StaticResource Loc}}" Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ConsistencyLabel, Source={StaticResource Loc}}" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding TrendLabel, Source={StaticResource Loc}}" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding StreakLabel, Source={StaticResource Loc}}" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding ActionsLabel, Source={StaticResource Loc}}" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Dynamic Rows -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DetailedHabitPerformances}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="0,1,0,0" Padding="24,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="40" Height="40" Background="{DynamicResource InputBgBrush}" CornerRadius="8" Margin="0,0,16,0">
                                                    <TextBlock Text="{Binding HabitIcon}" Foreground="{DynamicResource TextMainBrush}" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding HabitName}" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                                    <TextBlock Text="{Binding HabitDescription}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Consistency, StringFormat={}{0}%}" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMainBrush}"/>
                                                <ProgressBar Value="{Binding Consistency}" Width="80" Height="4" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource AccentGreenBrush}" BorderThickness="0" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            
                                            <!-- Trend -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TrendText}" FontWeight="Bold" Margin="0,0,4,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPositiveTrend}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Path Width="10" Height="10" Stretch="Uniform">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Data" Value="M7,14L12,9L17,14H7Z"/>
                                                            <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPositiveTrend}" Value="False">
                                                                    <Setter Property="Data" Value="M7,10L12,15L17,10H7Z"/>
                                                                    <Setter Property="Fill" Value="#EF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </StackPanel>

                                            <Border Grid.Column="3" Background="#EEF2FF" CornerRadius="12" Padding="12,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M12,18C13.1,18 14,17.1 14,16C14,14.9 13.1,14 12,14C10.9,14 10,14.9 10,16C10,17.1 10.9,18 12,18M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2Z" Fill="#818CF8" Width="12" Height="12" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding CurrentStreak, StringFormat={}{0}d}" Foreground="#818CF8" FontWeight="Bold" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                            <Button Grid.Column="4" Content="{Binding ViewStatistics, Source={StaticResource Loc}}" 
                                                     Command="{Binding DataContext.OpenHabitStatisticsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                     CommandParameter="{Binding}"
                                                     Background="Transparent" Foreground="{DynamicResource AccentGreenBrush}" FontWeight="Bold" BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>

    <!-- Modal Overlay (Habit Statistics) -->
    <Grid Visibility="{Binding IsStatisticsModalOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="999">
        <Border Background="#4D000000" />
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="16" Margin="0" Padding="32" Width="950" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="25" ShadowDepth="10" />
            </Border.Effect>

            <Grid DataContext="{Binding SelectedHabitStats}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,32">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Margin="0,0,16,0">
                            <TextBlock Text="{Binding HabitIcon}" Foreground="{DynamicResource TextMainBrush}" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding HabitName}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            <TextBlock Text="{Binding HabitTypeName}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Content="✕" Command="{Binding DataContext.CloseHabitStatisticsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMutedBrush}" FontSize="20" FontWeight="Bold" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>

                <!-- Content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: KPI Cards -->
                    <StackPanel Grid.Column="0">
                        <!-- Streaks Row -->
                        <UniformGrid Columns="2" Margin="0,0,0,16">
                            <Border Background="{DynamicResource AppBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,8,0">
                                <StackPanel>
                                    <Viewbox Width="22" Height="22" HorizontalAlignment="Left" Margin="0,0,0,8">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67z" Fill="#F97316"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding CurrentStreak}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                    <TextBlock Text="{Binding CurrentStreakLabel, Source={StaticResource Loc}}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource AppBgBrush}" CornerRadius="12" Padding="20" Margin="8,0,0,0">
                                <StackPanel>
                                    <Viewbox Width="22" Height="22" HorizontalAlignment="Left" Margin="0,0,0,8">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M18 2H6v2H2v6c0 3.31 2.69 6 6 6h1.22c.81 1.45 2.16 2.52 3.78 2.87V21H9v2h6v-2h-4v-2.13c1.62-.35 2.97-1.42 3.78-2.87H16c3.31 0 6-2.69 6-6V4h-4V2zM4 10V6h2v4c0 2.21-1.79 4-4 4zm14 0c0-2.21 1.79-4 4-4v4c0 2.21 1.79 4-4 4z" Fill="#F59E0B"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding LongestStreak}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                    <TextBlock Text="{Binding LongestStreakLabel, Source={StaticResource Loc}}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Weekly Success -->
                        <Border Background="{DynamicResource AppBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="{Binding WeeklySuccessLabel, Source={StaticResource Loc}}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                    <TextBlock Text="{Binding WeeklySuccessRate, StringFormat={}{0}%}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar Value="{Binding WeeklySuccessRate}" Height="8" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource AccentGreenBrush}" BorderThickness="0"/>
                                <TextBlock Text="{Binding WeeklySuccessDesc, Source={StaticResource Loc}}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Completions -->
                        <Border Background="{DynamicResource AppBgBrush}" CornerRadius="12" Padding="20">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40" Background="#F3F4F6" CornerRadius="20" Margin="0,0,16,0">
                                    <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#6B7280" Width="20" Height="20" Stretch="Uniform" Margin="10"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalCompletions}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                    <TextBlock Text="{Binding TotalCompletionsLabel, Source={StaticResource Loc}}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right Column: Charts & Calendar -->
                    <StackPanel Grid.Column="2">
                        <!-- Mini Calendar -->
                        <Border Background="{DynamicResource AppBgBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="{Binding MiniCalendarMonthYear}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                    <TextBlock Text="{Binding MonthlyCompletions, Source={StaticResource Loc}}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                </Grid>
                                
                                <UniformGrid Columns="7" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding MondayShort, Source={StaticResource Loc}}" Style="{StaticResource ChartLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TuesdayShort, Source={StaticResource Loc}}" Style="{StaticResource ChartLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding WednesdayShort, Source={StaticResource Loc}}" Style="{StaticResource ChartLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding ThursdayShort, Source={StaticResource Loc}}" Style="{StaticResource ChartLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding FridayShort, Source={StaticResource Loc}}" Style="{StaticResource ChartLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SaturdayShort, Source={StaticResource Loc}}" Style="{StaticResource ChartLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SundayShort, Source={StaticResource Loc}}" Style="{StaticResource ChartLabelStyle}" Margin="0,0,0,8"/>
                                </UniformGrid>

                                <ItemsControl ItemsSource="{Binding MonthlyCompletions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="36" Margin="2">
                                                <Grid>
                                                    <Ellipse Fill="{Binding DotColor}" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsScheduled}" Value="False">
                                                                        <Setter Property="Opacity" Value="0.2"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding DayNumber}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DotColor}" Value="#E5E7EB">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Value Trend Chart (Conditional) -->
                        <Border Background="{DynamicResource AppBgBrush}" CornerRadius="12" Padding="24" Height="220"
                                Visibility="{Binding IsNumericOrTimer, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding ValueTrend, Source={StaticResource Loc}}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,16"/>
                                <lvc:CartesianChart Series="{Binding ChartSeries}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" Background="Transparent" Margin="0,0,0,0" Height="140" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</UserControl>
