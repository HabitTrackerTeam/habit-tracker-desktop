<UserControl x:Class="HabitTracker.Views.Tabs.StatisticsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views"
             Background="Transparent"
             FontFamily="Inter, Segoe UI">

    <UserControl.Resources>
        <Style x:Key="ChartLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="48, 40">
            
            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock Text="{Binding Statistics, Source={StaticResource Loc}}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                    <TextBlock Text="{Binding ViewProgressAchievements, Source={StaticResource Loc}}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="{DynamicResource AccentGreenBrush}" Foreground="White" FontWeight="Bold" FontSize="16" BorderThickness="0" Padding="24,14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,12V19H5V5H12V3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V12H19M12.5,3L15.03,5.53L10.5,10.06L11.94,11.5L16.47,6.97L19,9.5V3H12.5Z" Fill="White" Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform"/>
                        <TextBlock Text="Export to PDF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Top Charts Row -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Growth Quotient Card -->
                <Border Grid.Column="0" Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="32">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Growth Quotient" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            <TextBlock Text="Your overall habit performance score across all categories this week." FontSize="13" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" MaxWidth="280" HorizontalAlignment="Left" Margin="0,8,0,24"/>
                            <Border Background="#F0FDF4" CornerRadius="20" Padding="12,6" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M7,14L12,9L17,14H7Z" Fill="{DynamicResource AccentGreenBrush}" Width="12" Height="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="+12% from last month" Foreground="{DynamicResource AccentGreenBrush}" FontWeight="Bold" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Circular Score -->
                        <Grid HorizontalAlignment="Right" Width="160" Height="160">
                            <Ellipse Stroke="{DynamicResource InputBgBrush}" StrokeThickness="16"/>
                            <Path Stroke="{DynamicResource AccentGreenBrush}" StrokeThickness="16" StrokeStartLineCap="Round" 
                                  Data="M 80,80 m 0,-64 a 64,64 0 1 1 0,128 a 64,64 0 1 1 0,-128" 
                                  StrokeDashArray="8 1" Opacity="1"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="84%" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="OVERALL SCORE" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Growth Milestones -->
                <Border Grid.Column="2" Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Growth Milestones" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            <Path Data="M12,2L14.39,7.62L20.5,8.1L15.84,12.1L17.29,18.05L12,14.88L6.71,18.05L8.16,12.1L3.5,8.1L9.61,7.62L12,2Z" Fill="#D8B4FE" Width="16" Height="16" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- Milestone Progress Items -->
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16">
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="CONSISTENCY KING" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}"/>
                                    <TextBlock Text="18/20 DAYS" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar Value="90" Height="6" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource AccentGreenBrush}" BorderThickness="0"/>
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="READING LEVEL 3" FontSize="10" FontWeight="Bold" Foreground="#93C5FD"/>
                                    <TextBlock Text="450/500 PAGES" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar Value="90" Height="6" Background="{DynamicResource InputBgBrush}" Foreground="#93C5FD" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Weekly Completion & Top Habits Row -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Weekly Completion Section -->
                <Border Grid.Column="0" Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="32">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,32">
                            <StackPanel>
                                <TextBlock Text="Weekly Completion" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                <TextBlock Text="Habit performance score per day" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                            <!-- Date Selector -->
                            <Border HorizontalAlignment="Right" Background="{DynamicResource InputBgBrush}" CornerRadius="8" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" Margin="0,0,16,0"/>
                                    <TextBlock Text="10.05.2026 - 17.05.2026" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center"/>
                                    <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" Margin="16,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Bar Chart Representation -->
                        <UniformGrid Columns="7" Height="160" VerticalAlignment="Bottom">
                            <StackPanel VerticalAlignment="Bottom">
                                <Grid Height="120" Margin="8,0">
                                    <Border Width="16" Height="120" Background="{DynamicResource InputBgBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Border Width="16" Height="60" Background="{DynamicResource AccentGreenBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="MON" Style="{StaticResource ChartLabelStyle}"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom">
                                <Grid Height="120" Margin="8,0">
                                    <Border Width="16" Height="120" Background="{DynamicResource InputBgBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Border Width="16" Height="90" Background="{DynamicResource AccentGreenBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="TUE" Style="{StaticResource ChartLabelStyle}"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom">
                                <Grid Height="120" Margin="8,0">
                                    <Border Width="16" Height="120" Background="{DynamicResource InputBgBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Border Width="16" Height="110" Background="{DynamicResource AccentGreenBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="WED" Style="{StaticResource ChartLabelStyle}"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom">
                                <Grid Height="120" Margin="8,0">
                                    <Border Width="16" Height="120" Background="{DynamicResource InputBgBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Border Width="16" Height="80" Background="{DynamicResource AccentGreenBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="THU" Style="{StaticResource ChartLabelStyle}"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom">
                                <Grid Height="120" Margin="8,0">
                                    <Border Width="16" Height="120" Background="{DynamicResource InputBgBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Border Width="16" Height="120" Background="{DynamicResource AccentGreenBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="FRI" Style="{StaticResource ChartLabelStyle}"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom">
                                <Grid Height="120" Margin="8,0">
                                    <Border Width="16" Height="120" Background="{DynamicResource InputBgBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Border Width="16" Height="50" Background="{DynamicResource AccentGreenBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="SAT" Style="{StaticResource ChartLabelStyle}"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom">
                                <Grid Height="120" Margin="8,0">
                                    <Border Width="16" Height="120" Background="{DynamicResource InputBgBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Border Width="16" Height="40" Background="{DynamicResource AccentGreenBrush}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="SUN" Style="{StaticResource ChartLabelStyle}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Top Performance Habits -->
                <Border Grid.Column="2" Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Top Habits" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,24"/>
                        
                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Morning Meditation" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                <TextBlock Text="100%" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Value="100" Height="6" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource AccentGreenBrush}" BorderThickness="0"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Stay Hydrated" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                <TextBlock Text="98%" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Value="98" Height="6" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource AccentGreenBrush}" BorderThickness="0"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Read 20 Pages" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                <TextBlock Text="85%" FontSize="12" FontWeight="Bold" Foreground="#93C5FD" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Value="85" Height="6" Background="{DynamicResource InputBgBrush}" Foreground="#93C5FD" BorderThickness="0"/>
                        </StackPanel>

                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Gym Session" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                <TextBlock Text="70%" FontSize="12" FontWeight="Bold" Foreground="#D8B4FE" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Value="70" Height="6" Background="{DynamicResource InputBgBrush}" Foreground="#D8B4FE" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Detailed Performance Table -->
            <StackPanel>
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Detailed Performance" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                        <TextBlock Text="Click on any habit to see in-depth analytics" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <TextBlock Text="View All →" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource AccentGreenBrush}" FontWeight="Bold" Cursor="Hand"/>
                </Grid>

                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="16">
                    <StackPanel>
                        <!-- Headers -->
                        <Border Background="{DynamicResource AppBgBrush}" Padding="24,16" Margin="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="HABIT NAME" Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="1" Text="CONSISTENCY" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="TREND" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="STREAK" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="ACTIONS" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Row 1 -->
                        <Border BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="0,1,0,0" Padding="24,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="40" Height="40" Background="#F0FDF4" CornerRadius="8" Margin="0,0,16,0">
                                        <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.41,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.59,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" Fill="{DynamicResource AccentGreenBrush}" Width="18" Height="18" Stretch="Uniform"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Stay Hydrated" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                                        <TextBlock Text="8 Glasses / Day" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="98%" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMainBrush}"/>
                                    <ProgressBar Value="98" Width="80" Height="4" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource AccentGreenBrush}" BorderThickness="0" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="Stable" Foreground="{DynamicResource AccentGreenBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Border Grid.Column="3" Background="#EEF2FF" CornerRadius="12" Padding="12,4" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M12,18C13.1,18 14,17.1 14,16C14,14.9 13.1,14 12,14C10.9,14 10,14.9 10,16C10,17.1 10.9,18 12,18M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2Z" Fill="#818CF8" Width="12" Height="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="14d" Foreground="#818CF8" FontWeight="Bold" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <Button Grid.Column="4" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right">
                                    <Path Data="M14,3V5H17.59L7,15.59L8.41,17L19,6.41V10H21V3M19,19H5V5H12V3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V12H19V19Z" Fill="{DynamicResource TextMutedBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
