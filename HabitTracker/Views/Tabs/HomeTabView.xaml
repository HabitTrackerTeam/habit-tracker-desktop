<UserControl x:Class="HabitTracker.Views.Tabs.HomeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views">
    <Grid Margin="40,20,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Home, Source={StaticResource Loc}}" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding TodayDate}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}"
                CornerRadius="12" Padding="16" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock Text="{Binding MyHabits, Source={StaticResource Loc}}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,8" />
                <TextBlock Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap">
                    Personal habits will appear here.
                    <LineBreak/>
                    Select from the built-in list or create your own in the Habits Manager.
                </TextBlock>

                <ItemsControl ItemsSource="{Binding Habits}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,6" VerticalAlignment="Center">
                                <CheckBox Width="20" Height="20" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                <TextBox Width="100" Margin="10,0,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="12" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding MyNotes, Source={StaticResource Loc}}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,8" />
                <TextBox AcceptsReturn="True" TextWrapping="Wrap" Height="120" VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
