<UserControl x:Class="HabitTracker.Views.Tabs.HomeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <Path Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Fill="#64748B" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HabitItemStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsGreenHighlighted}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HabitCheckedBgBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource HabitCheckedBorderBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Box" Width="24" Height="24" CornerRadius="6" BorderBrush="#CBD5E1" BorderThickness="2" Background="Transparent">
                                <Path x:Name="CheckMark" Data="M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z" Fill="White" Width="14" Height="14" Stretch="Uniform" Visibility="Collapsed"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#166534"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#166534"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="*"/>    <!-- Body -->
        </Grid.RowDefinitions>

        <!-- Top Search/Actions Bar -->
        <Grid Grid.Row="0" Margin="48, 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="{Binding Home, Source={StaticResource Loc}}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource TextMainBrush}" 
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Style="{StaticResource IconButton}" Content="M21,19V20H3V19L5,17V11C5,7.9 7.03,5.17 10,4.29C10,4.19 10,4.1 10,4A2,2 0 0,1 12,2A2,2 0 0,1 14,4C14,4.1 14,4.19 14,4.29C16.97,5.17 19,7.9 19,11V17L21,19M12,22A2,2 0 0,1 10,20H14A2,2 0 0,1 12,22Z"/>
                <Button Style="{StaticResource IconButton}" Content="M12,18C8.69,18 6,15.31 6,12C6,8.69 8.69,6 12,6V18M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20Z"/>
            </StackPanel>
        </Grid>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="48, 0, 48, 48">
                
                <!-- Welcome Hero -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="24" Padding="40" Margin="0,0,0,32">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.03" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <!-- Binding TodayDate -->
                            <TextBlock Text="{Binding TodayDate}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            <TextBlock Text="{Binding DailyMotivation, Source={StaticResource Loc}}" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Circular Progress -->
                        <Grid Grid.Column="1" Width="120" Height="120">
                            <Ellipse Stroke="{DynamicResource InputBgBrush}" StrokeThickness="12"/>
                            <Path Stroke="{DynamicResource AccentGreenBrush}" StrokeThickness="12" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 60,60 m 0,-48 a 48,48 0 1 1 0,96 a 48,48 0 1 1 0,-96" 
                                  StrokeDashArray="4 1" Margin="0"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="65%" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DailyProgress, Source={StaticResource Loc}}" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Daily Habits List -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Path Data="M7,5H21V7H7V5M7,11H21V13H7V11M7,17H21V19H7V17M4,4.5A1.5,1.5 0 0,1 5.5,6A1.5,1.5 0 0,1 4,7.5A1.5,1.5 0 0,1 2.5,6A1.5,1.5 0 0,1 4,4.5M4,10.5A1.5,1.5 0 0,1 5.5,12A1.5,1.5 0 0,1 4,13.5A1.5,1.5 0 0,1 2.5,12A1.5,1.5 0 0,1 4,10.5M4,16.5A1.5,1.5 0 0,1 5.5,18A1.5,1.5 0 0,1 4,19.5A1.5,1.5 0 0,1 2.5,18A1.5,1.5 0 0,1 4,16.5Z" Fill="#166534" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <!-- Binding localized MyHabits -->
                            <TextBlock Text="{Binding MyHabits, Source={StaticResource Loc}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Fallback Content if Habits is empty -->
                        <TextBlock Text="{Binding DashboardHabitsPlaceholder, Source={StaticResource Loc}}" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Habits.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Habit Items -->
                        <ItemsControl ItemsSource="{Binding Habits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource HabitItemStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#F0FDF4" CornerRadius="12" Width="48" Height="48" Margin="0,0,16,0">
                                                <TextBlock Text="{Binding Icon, FallbackValue=🌱}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextMainBrush}"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Period}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <!-- Checkbox Habit Input -->
                                            <CheckBox Grid.Column="2" 
                                                      Style="{StaticResource ModernCheckBox}"
                                                      IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                      Visibility="{Binding IsCheckboxType, Converter={StaticResource BoolToVis}}"
                                                      VerticalAlignment="Center"/>
                                                      
                                            <!-- Numeric/Timer Habit Input -->
                                            <StackPanel Grid.Column="2" 
                                                        Orientation="Horizontal" 
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsNumericOrTimerType, Converter={StaticResource BoolToVis}}">
                                                <Border Background="{DynamicResource InputBgBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource InputBorderBrush}" Width="60" Height="36">
                                                    <TextBox Style="{StaticResource CenteredTextBoxStyle}"
                                                             Text="{Binding CurrentProgressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             VerticalContentAlignment="Center"
                                                             HorizontalContentAlignment="Center"
                                                             FontSize="14"
                                                             FontWeight="SemiBold"
                                                             Foreground="{DynamicResource TextMainBrush}"/>
                                                </Border>
                                                <TextBlock Text=" / " FontSize="14" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                <TextBlock Text="{Binding TargetFrequency}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding DisplayUnit}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Reflection Section -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Path Data="M14,10H19.5L14,4.5V10M5,3H15L21,9V21A2,2 0 0,1 19,23H5C3.89,23 3,22.1 3,21V5C3,3.89 3.89,3 5,3M5,5V7H11V5H5M5,9V11H13V9H5M5,13V15H19V13H5M5,17V19H19V17H5Z" Fill="#166534" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <!-- Binding localized MyNotes -->
                            <TextBlock Text="{Binding MyNotes, Source={StaticResource Loc}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="24" Height="400">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding DailyNotes, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,16"/>
                                <!-- Binding for the Notes Box -->
                                <TextBox Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="{DynamicResource TextMainBrush}">
                                    <TextBox.Resources>
                                        <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="How are you feeling today? Any breakthroughs or challenges? Write your thoughts here..." 
                                                           Foreground="#94A3B8" TextWrapping="Wrap" LineHeight="22" Width="200"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <TextBlock Grid.Row="2" Text="Auto-saved at 09:15 AM" VerticalAlignment="Bottom" HorizontalAlignment="Right" FontSize="10" Foreground="#CBD5E1"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
