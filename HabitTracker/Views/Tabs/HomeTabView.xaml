<UserControl x:Class="HabitTracker.Views.Tabs.HomeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HabitTracker"
             xmlns:views="clr-namespace:HabitTracker.Views"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <Path Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Fill="#64748B" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HabitItemStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPartiallyCompleted}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource HabitCheckedBorderBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsGreenHighlighted}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HabitCheckedBgBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource HabitCheckedBorderBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Box" Width="24" Height="24" CornerRadius="6" BorderBrush="#CBD5E1" BorderThickness="2" Background="Transparent">
                                <Path x:Name="CheckMark" Data="M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z" Fill="White" Width="14" Height="14" Stretch="Uniform" Visibility="Collapsed"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#166534"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#166534"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="HabitItemTemplate">
            <Border Style="{StaticResource HabitItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource InputBgBrush}" CornerRadius="12" Width="48" Height="48" Margin="0,0,16,0">
                        <TextBlock Text="{Binding Icon, FallbackValue=🌱}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="{DynamicResource TextMainBrush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextMainBrush}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayPeriod}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"/>
                            <!-- Progress indicator for weekly/monthly -->
                            <TextBlock Text="{Binding PeriodProgressText}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AccentGreenBrush}" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Period}" Value="weekly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Period}" Value="monthly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Period}" Value="Weekly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Period}" Value="Monthly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Checkbox Habit Input -->
                    <CheckBox Grid.Column="2" 
                                Style="{StaticResource ModernCheckBox}"
                                IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                Visibility="{Binding IsCheckboxType, Converter={StaticResource BoolToVis}}"
                                VerticalAlignment="Center"/>
                                
                    <!-- Numeric/Timer Habit Input -->
                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center"
                                Visibility="{Binding IsNumericOrTimerType, Converter={StaticResource BoolToVis}}">
                        <Border Background="{DynamicResource InputBgBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource InputBorderBrush}" Width="60" Height="36">
                            <TextBox Style="{StaticResource CenteredTextBoxStyle}"
                                        Text="{Binding CurrentProgressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextMainBrush}"/>
                        </Border>
                        <TextBlock Text=" / " FontSize="14" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBlock Text="{Binding TargetFrequency}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding DisplayUnit}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="40,32,40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="*"/>    <!-- Body -->
        </Grid.RowDefinitions>

        <!-- Top Search/Actions Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,24" MinHeight="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                <TextBlock Text="{Binding Home, Source={StaticResource Loc}}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextMainBrush}" />
                <TextBlock Text="{Binding HomeSubtitle, Source={StaticResource Loc}}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0, 0, 0, 48">
                
                <!-- Welcome Hero -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="24" Padding="40" Margin="0,0,0,32">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.03" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <!-- Binding TodayDate -->
                            <TextBlock Text="{Binding TodayDate}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            <TextBlock Text="{Binding DailyMotivation, Source={StaticResource Loc}}" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Circular Progress -->
                        <Grid Grid.Column="1" Width="120" Height="120">
                            <Ellipse Stroke="{DynamicResource InputBgBrush}" StrokeThickness="12"/>
                            <Path Stroke="{DynamicResource AccentGreenBrush}" StrokeThickness="{Binding DailyProgressStrokeThickness}" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 60,60 m 0,-48 a 48,48 0 1 1 0,96 a 48,48 0 1 1 0,-96" 
                                  StrokeDashArray="{Binding DailyProgressDashArray}" Margin="0"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DailyProgressText}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DailyProgress, Source={StaticResource Loc}}" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Daily Habits List -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Path Data="M23,12L20.56,9.22L20.9,5.54L17.29,4.72L15.4,1.54L12,3L8.6,1.54L6.71,4.72L3.1,5.53L3.44,9.21L1,12L3.44,14.78L3.1,18.47L6.71,19.29L8.6,22.47L12,21L15.4,22.46L17.29,19.28L20.9,18.46L20.56,14.78L23,12M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9L10,17Z" Fill="#166534" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <!-- Binding localized MyHabits -->
                            <TextBlock Text="{Binding MyHabits, Source={StaticResource Loc}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Fallback Content if Habits is empty -->
                        <TextBlock Text="{Binding DashboardHabitsPlaceholder, Source={StaticResource Loc}}" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DailyHabits.Count}" Value="0"/>
                                                <Condition Binding="{Binding WeeklyHabits.Count}" Value="0"/>
                                                <Condition Binding="{Binding MonthlyHabits.Count}" Value="0"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Daily Habits -->
                        <StackPanel Margin="0,0,0,16">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DailyHabits.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding TodaySection, Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding DailyHabits}" ItemTemplate="{StaticResource HabitItemTemplate}"/>
                        </StackPanel>

                        <!-- Weekly Habits Divider -->
                        <StackPanel Margin="0,0,0,16">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WeeklyHabits.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Height="1" Background="{DynamicResource InputBorderBrush}" Margin="0,0,0,16"/>
                            <TextBlock Text="{Binding ThisWeekSection, Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding WeeklyHabits}" ItemTemplate="{StaticResource HabitItemTemplate}"/>
                        </StackPanel>

                        <!-- Monthly Habits Divider -->
                        <StackPanel Margin="0,0,0,16">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MonthlyHabits.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Height="1" Background="{DynamicResource InputBorderBrush}" Margin="0,0,0,16"/>
                            <TextBlock Text="{Binding ThisMonthSection, Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding MonthlyHabits}" ItemTemplate="{StaticResource HabitItemTemplate}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Reflection Section -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Path Data="M21,2C21,2 21,2 21,2C21,2 21,2 21,2V2.5V3L20,4H19L18.5,4.5L18,5H17L16,6H15C13,8 11.5,10.5 11,13C10,11 8,9.5 6,9C6.34,10 7.03,10.87 8,11.5L4.5,15H3C2,16 1,17.5 1,19V22H4L7,19.5L10.5,16C11.13,16.97 12,17.66 13,18C12.5,16 11,14 13,13C15.5,12.5 18,11 20,9V8L20.5,7.5L21,7V6L21.5,5.5L22,5V4V3C22,2 21.5,2 21,2Z" Fill="#166534" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <!-- Binding localized MyNotes -->
                            <TextBlock Text="{Binding MyNotes, Source={StaticResource Loc}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="24" Height="400">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.02" ShadowDepth="0"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding DailyNotes, Source={StaticResource Loc}}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,16"/>
                                <!-- Binding for the Notes Box -->
                                <TextBox Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="{DynamicResource TextMainBrush}"
                                         Text="{Binding DailyNoteContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Resources>
                                        <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="How are you feeling today? Any breakthroughs or challenges? Write your thoughts here..." 
                                                           Foreground="#94A3B8" TextWrapping="Wrap" LineHeight="22" Width="200"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <TextBlock Grid.Row="2" Text="{Binding DailyNoteStatusText}" VerticalAlignment="Bottom" HorizontalAlignment="Right" FontSize="10" Foreground="#CBD5E1"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
