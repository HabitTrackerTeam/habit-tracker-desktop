<Window x:Class="HabitTracker.Views.CreateCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New Category"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Width="430"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Background="#E0000000">
        <Border Background="White" CornerRadius="16" Margin="10">
            <StackPanel Margin="0">
                <!-- Header -->
                <Border Background="White" CornerRadius="16,16,0,0" Margin="0">
                    <StackPanel Margin="24,24,24,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Create New Category" FontSize="20" FontWeight="Bold" Foreground="#FF4E606C" />
                                <TextBlock Text="Give your habit category a name, color and icon." FontSize="12" Foreground="#FF8B9AA2" Margin="0,6,0,0" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="CloseButton_Click" Margin="0,0,0,0">
                                <TextBlock Text="✕" FontSize="18" Foreground="#FF8B9AA2" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Main Content -->
                <StackPanel Margin="24,20,24,24">
                    <!-- Category Name -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CATEGORY NAME" FontSize="11" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,6" />
                        <TextBox x:Name="CategoryNameBox" Tag="e.g., Health &amp; Fitness" Height="40" Padding="12,8,12,8" />
                    </StackPanel>

                    <!-- Choose Icon -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CHOOSE ICON" FontSize="11" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="IconBtn1" Content="✓" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="IconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtn2" Content="📋" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="IconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtn3" Content="🎯" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="IconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtn4" Content="💪" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Margin="0,0,12,0" Click="IconButton_Click" Cursor="Hand" />
                            <Button x:Name="IconBtn5" Content="🧠" Width="44" Height="44" Background="Transparent" BorderBrush="#FFDDE2E5" BorderThickness="1" FontSize="16" Click="IconButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Choose Color -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CHOOSE COLOR" FontSize="11" FontWeight="Bold" Foreground="#FF8B9AA2" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ColorBtn1" Width="40" Height="40" Background="#328A5D" BorderThickness="0" Margin="0,0,12,0" Click="ColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtn2" Width="40" Height="40" Background="#0066CC" BorderThickness="0" Margin="0,0,12,0" Click="ColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtn3" Width="40" Height="40" Background="#FF6B6B" BorderThickness="0" Margin="0,0,12,0" Click="ColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtn4" Width="40" Height="40" Background="#FFD93D" BorderThickness="0" Margin="0,0,12,0" Click="ColorButton_Click" Cursor="Hand" />
                            <Button x:Name="ColorBtn5" Width="40" Height="40" Background="#9B59B6" BorderThickness="0" Click="ColorButton_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Cancel" Background="Transparent" BorderThickness="0" Foreground="#FF4E606C" FontSize="13" FontWeight="Bold" Click="CancelButton_Click" Cursor="Hand" Margin="0,0,12,0" Width="70" />
                        <Button Content="Create Category" Background="#FF328A5D" BorderThickness="0" Foreground="White" FontSize="13" FontWeight="Bold" Click="CreateButton_Click" Cursor="Hand" Width="130" Height="40" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
